<% content_for :title, "AI pricing news — LLM releases, price changes & market moves — tokenprice.fyi" %>
<% content_for :description, "A daily feed of AI API pricing news: model releases, price changes, and market moves, filtered to what's relevant and newest first." %>
<% content_for :canonical, news_url %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        name: "AI pricing news",
        url: news_url,
        description: "A daily feed of AI API pricing news, newest first.",
        isPartOf: { "@type": "WebSite", "@id": "#{request.base_url}/#website" }
      }) %>
<% end %>

<div class="news-page">
  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <header class="news-header">
    <h1 class="news-h1">News</h1>
    <p class="news-subtitle">
      AI-pricing headlines as they surface — model releases, price changes, and
      market moves, scanned daily and filtered to what's relevant.
    </p>
  </header>

  <%# ── Funnel cross-link ──────────────────────────────────────────────── %>
  <%# /news is the unedited feed; the entries that mark a real pricing milestone
      are hand-curated into the dated /events timeline. Naming the relationship
      keeps the two pages reading as one funnel rather than duplicates. %>
  <div class="news-funnel">
    <span class="news-funnel-ic" aria-hidden="true"><%= icon(:calendar, size: 17) %></span>
    <span>Every relevant headline we scan, unedited and newest first. The ones
      that mark a real pricing milestone are hand-curated into the
      <%= link_to "dated Events timeline →", events_path %></span>
  </div>

  <%# ── Feed ───────────────────────────────────────────────────────────── %>
  <div class="tp-card news-card">
    <% if @items.any? %>
      <% @items_by_day.each do |day, items| %>
        <section class="n-day">
          <h2 class="n-day-head">
            <%= fmt_date_full(day) %>
            <span class="n-day-cnt"><%= items.size %> item<%= "s" unless items.size == 1 %></span>
          </h2>
          <ul class="n-list">
            <%= render partial: "news/item", collection: items, as: :item %>
          </ul>
        </section>
      <% end %>

      <% if @has_more %>
        <div class="n-sentinel">
          <%= link_to "Load more", news_path(page: @page + 1), class: "n-more" %>
        </div>
      <% end %>
    <% else %>
      <div class="tp-empty">
        <div class="tp-empty-icon"><%= icon(:empty, size: 26) %></div>
        <p class="font-medium">No news tracked yet.</p>
        <p class="text-sm mt-1" style="color:var(--color-slate-400)">
          Releases, price changes, and market moves will appear here as they're scanned.
        </p>
      </div>
    <% end %>
  </div>
</div>

<style>
/* ── News page ───────────────────────────────────────────────────────── */
.news-page {
  max-width: 800px;
  padding-top: 36px;
  padding-bottom: 64px;
}
.news-header { margin-bottom: 18px; }
.news-h1 {
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -0.033em;
  line-height: 1.05;
  color: var(--color-slate-900);
}
.news-subtitle {
  margin-top: 14px;
  max-width: 54ch;
  color: var(--color-slate-500);
  font-size: 17px;
  line-height: 1.6;
}

/* ── Funnel cross-link ───────────────────────────────────────────────── */
.news-funnel {
  display: flex;
  align-items: flex-start;
  gap: 11px;
  margin: 18px 0 22px;
  padding: 12px 16px;
  border: 1px solid var(--color-slate-200);
  border-radius: var(--radius-md);
  background: var(--color-slate-50);
  font-size: 13.5px;
  line-height: 1.55;
  color: var(--color-slate-600);
}
.news-funnel-ic { color: var(--color-slate-400); flex: none; margin-top: 1px; }
.news-funnel a { color: var(--color-indigo-600); font-weight: 600; text-decoration: none; white-space: nowrap; }
.news-funnel a:hover { text-decoration: underline; text-underline-offset: 2px; }

/* ── Feed card ───────────────────────────────────────────────────────── */
.news-card { padding: 4px 28px 12px; }
@media (max-width: 560px) { .news-card { padding: 4px 18px 10px; } }

/* Day header — sticks just below the nav on a long feed. */
.n-day-head {
  position: sticky;
  top: var(--nav-h);
  z-index: 5;
  margin: 0;
  padding: 16px 0 11px;
  background: #fff;
  font-family: var(--font-mono);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--color-slate-800);
  display: flex;
  align-items: baseline;
  gap: 10px;
}
.n-day-head::after { content: ""; flex: 1; height: 1px; background: var(--color-slate-100); align-self: center; }
.n-day-cnt { font-size: 11px; font-weight: 600; color: var(--color-slate-400); }

.n-list { list-style: none; margin: 0; padding: 0; }
.n-item {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4px 16px;
  padding: 15px 0;
  border-top: 1px solid var(--color-slate-100);
}
.n-item:first-child { border-top: none; }
.n-main { min-width: 0; }

.n-title {
  font-size: 16px;
  font-weight: 600;
  letter-spacing: -0.015em;
  line-height: 1.35;
  color: var(--color-slate-900);
  text-decoration: none;
}
.n-title:hover { color: var(--color-indigo-700); text-decoration: underline; text-underline-offset: 3px; }
.n-ext { color: var(--color-slate-300); margin-left: 5px; vertical-align: -1px; }
.n-title:hover .n-ext { color: var(--color-indigo-400); }

.n-rat {
  margin: 5px 0 0;
  font-size: 14px;
  line-height: 1.5;
  color: var(--color-slate-500);
  max-width: 66ch;
}

.n-meta { display: flex; align-items: center; gap: 10px; margin-top: 10px; flex-wrap: wrap; }
.n-src {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .03em;
  color: var(--color-slate-400);
}
.n-linked {
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  font-weight: 600;
  color: var(--color-indigo-600);
  text-decoration: none;
  padding: 2px 9px;
  border-radius: var(--radius-pill);
  background: var(--color-indigo-50);
}
.n-linked:hover { text-decoration: underline; text-underline-offset: 2px; }

.n-aside { justify-self: end; align-self: start; padding-top: 2px; }

/* ── Load more ───────────────────────────────────────────────────────── */
.n-sentinel { display: flex; justify-content: center; padding: 22px 0 10px; }
.n-more {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-indigo-600);
  text-decoration: none;
  padding: 8px 18px;
  border: 1px solid var(--color-slate-200);
  border-radius: var(--radius-pill);
  transition: background .16s var(--ease-default), border-color .16s var(--ease-default);
}
.n-more:hover { background: var(--color-slate-50); border-color: var(--color-slate-300); }
</style>
