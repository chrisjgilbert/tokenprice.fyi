<% content_for :title, "LLM pricing over time — tokenprice.fyi" %>
<% content_for :description, "Price history for every tracked LLM model, with market events and preset comparisons." %>
<% content_for :canonical, trends_url %>

<div class="trends-page">
  <%# ── Page header ───────────────────────────────────────────────────── %>
  <div class="trends-header">
    <h1 class="trends-h1">Pricing over time</h1>
    <p class="trends-subtitle">Prices for every tracked model from launch to now, with the market events that moved them marked. Pick a preset or build your own.</p>
  </div>

  <%# ── Main layout: sidebar + chart ────────────────────────────────── %>
  <div
    class="trends-layout"
    data-controller="trends-chart"
    data-trends-chart-models-value="<%= html_escape(@models_json) %>"
    data-trends-chart-events-value="<%= html_escape(@all_events_json) %>"
  >
    <%# ── Sidebar ─────────────────────────────────────────────────────── %>
    <aside class="trends-sidebar">
      <%# Card 1: Presets %>
      <div class="tp-card trends-sidebar-card">
        <div class="trends-card-inner">
          <span class="tp-field-label">Presets</span>
          <div class="trends-preset-list" data-trends-chart-target="presetList">
            <button
              class="trends-preset-btn active"
              data-action="click->trends-chart#selectPreset"
              data-preset="all"
            >All time</button>
            <button
              class="trends-preset-btn"
              data-action="click->trends-chart#selectPreset"
              data-preset="frontier"
            >All frontier</button>
            <button
              class="trends-preset-btn"
              data-action="click->trends-chart#selectPreset"
              data-preset="anthropic-vs-openai"
            >Anthropic vs OpenAI</button>
            <button
              class="trends-preset-btn"
              data-action="click->trends-chart#selectPreset"
              data-preset="budget"
            >Budget tier</button>
            <button
              class="trends-preset-btn"
              data-action="click->trends-chart#selectPreset"
              data-preset="the-cuts"
            >Biggest price cuts</button>
          </div>
        </div>
      </div>

      <%# Card 2: Model picker %>
      <div class="tp-card trends-sidebar-card">
        <div class="trends-card-inner">
          <span class="tp-field-label">
            Models&nbsp;<span class="trends-sel-count" data-trends-chart-target="selCount" style="display:none">·&nbsp;<span class="trends-sel-n">0</span></span>
          </span>
          <div class="trends-model-list" data-trends-chart-target="modelList">
            <%# Populated by Stimulus from JSON %>
          </div>
        </div>
      </div>
    </aside>

    <%# ── Chart card ──────────────────────────────────────────────────── %>
    <div class="tp-card trends-chart-card">
      <%# Toolbar %>
      <div class="trends-toolbar">
        <div class="trends-toolbar-left">
          <span class="trends-toolbar-label">Metric</span>
          <div class="tp-seg" role="group" aria-label="Metric">
            <button class="on" data-action="click->trends-chart#setMetric" data-metric="input">Input</button>
            <button data-action="click->trends-chart#setMetric" data-metric="output">Output</button>
          </div>
          <span class="trends-toolbar-label" style="margin-left: 8px;">Range</span>
          <div class="tp-seg" role="group" aria-label="Time range" data-trends-chart-target="timeRange">
            <button data-action="click->trends-chart#setTimeRange" data-range="3m">3M</button>
            <button data-action="click->trends-chart#setTimeRange" data-range="6m">6M</button>
            <button data-action="click->trends-chart#setTimeRange" data-range="1y">1Y</button>
            <button class="on" data-action="click->trends-chart#setTimeRange" data-range="all">All</button>
          </div>
          <span class="trends-toolbar-label" style="margin-left: 8px;">Scale</span>
          <div class="tp-seg" role="group" aria-label="Price axis scale" data-trends-chart-target="scaleSeg">
            <button class="on" data-action="click->trends-chart#setScale" data-scale="log">Log</button>
            <button data-action="click->trends-chart#setScale" data-scale="linear">Linear</button>
          </div>
        </div>
        <div class="trends-toolbar-right">
          <label class="trends-toggle-label">
            <span>Average</span>
            <button
              class="trends-toggle on"
              role="switch"
              aria-checked="true"
              data-action="click->trends-chart#toggleAvg"
              data-trends-chart-target="avgToggle"
            ><span class="trends-toggle-knob"></span></button>
          </label>
          <label class="trends-toggle-label">
            <span>Events</span>
            <button
              class="trends-toggle on"
              role="switch"
              aria-checked="true"
              data-action="click->trends-chart#toggleEvents"
              data-trends-chart-target="eventsToggle"
            ><span class="trends-toggle-knob"></span></button>
          </label>
          <div class="trends-events-popover-wrap" data-trends-chart-target="eventsPopoverWrap">
            <button
              class="tp-btn tp-btn-ghost tp-btn-sm"
              data-action="click->trends-chart#toggleEventsPopover"
              data-trends-chart-target="eventsPopoverBtn"
              aria-haspopup="dialog"
              aria-expanded="false"
            >
              <%= icon(:calendar) %>
              Market events
            </button>
            <div class="trends-events-popover" data-trends-chart-target="eventsPopover">
              <div class="trends-popover-header">Market events that reset pricing</div>
              <div class="trends-popover-list" data-trends-chart-target="eventsPopoverList">
                <%# Populated by Stimulus %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# SVG Chart area %>
      <div class="trends-chart-area" data-trends-chart-target="chartArea">
        <div class="trends-empty-state" data-trends-chart-target="emptyState">
          <div class="tp-empty">
            <div class="tp-empty-icon"><%= icon(:trend_down, size: 26) %></div>
            <p class="font-medium">Select at least one model to plot.</p>
            <p class="text-sm mt-1" style="color:var(--color-slate-400)">Choose a preset or pick models from the sidebar.</p>
          </div>
        </div>
        <svg
          class="trends-svg"
          data-trends-chart-target="svg"
          viewBox="0 0 880 380"
          preserveAspectRatio="xMidYMid meet"
          aria-label="Model price history chart"
          role="img"
        ></svg>
        <div class="trends-tip" data-trends-chart-target="tooltip"></div>
        <div class="trends-evt-tip" data-trends-chart-target="eventTooltip"></div>
      </div>

      <%# Legend %>
      <div class="trends-legend" data-trends-chart-target="legend"></div>
    </div>
  </div>
</div>

<style>
/* ── Trends page layout ─────────────────────────────────────────────── */
.trends-page {
  padding-top: 36px;
  padding-bottom: 60px;
}
.trends-header {
  margin-bottom: 28px;
}
.trends-h1 {
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -0.033em;
  line-height: 1.05;
  color: var(--color-slate-900);
}
.trends-subtitle {
  margin-top: 14px;
  max-width: 40em;
  color: var(--color-slate-500);
  font-size: 17px;
  line-height: 1.6;
}

/* ── 2-column grid ──────────────────────────────────────────────────── */
.trends-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 22px;
  align-items: start;
}
@media (max-width: 860px) {
  .trends-layout {
    grid-template-columns: 1fr;
  }
  .trends-sidebar {
    position: static !important;
  }
  .trends-model-list { max-height: 240px; }
}

/* ── Sidebar ─────────────────────────────────────────────────────────── */
.trends-sidebar {
  position: sticky;
  top: 78px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.trends-sidebar-card {
  overflow: hidden;
}
.trends-card-inner {
  padding: 18px;
}

/* ── Presets ─────────────────────────────────────────────────────────── */
.trends-preset-list {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}
.trends-preset-btn {
  padding: 7px 12px;
  border-radius: var(--radius-pill);
  border: 1px solid var(--color-slate-300);
  background: #fff;
  font-size: 12.5px;
  font-weight: 600;
  cursor: pointer;
  color: var(--color-slate-500);
  white-space: nowrap;
  transition: all .15s var(--ease-default);
  font-family: var(--font-sans);
}
.trends-preset-btn:hover {
  border-color: var(--color-indigo-400);
  color: var(--color-indigo-700);
}
.trends-preset-btn.active {
  background: var(--color-indigo-600);
  border-color: var(--color-indigo-600);
  color: #fff;
}

/* ── Model list ──────────────────────────────────────────────────────── */
.trends-sel-count {
  color: var(--color-indigo-600);
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
}
.trends-model-list {
  max-height: 340px;
  overflow-y: auto;
  margin: 0 -6px;
  padding: 0 6px;
}
.trends-model-list::-webkit-scrollbar { width: 4px; }
.trends-model-list::-webkit-scrollbar-thumb { background: var(--color-slate-200); border-radius: 2px; }

.trends-group-header {
  position: sticky;
  top: 0;
  z-index: 1;
  padding: 12px 8px 5px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--color-slate-400);
  background: #fff;
}
.trends-model-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  border: none;
  background: transparent;
  width: 100%;
  text-align: left;
  font-family: var(--font-sans);
  transition: background .12s var(--ease-default);
  user-select: none;
}
.trends-model-row:hover { background: var(--color-slate-100); }
.trends-swatch {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex: none;
  transition: all .14s var(--ease-default);
}
.trends-model-name {
  flex: 1;
  font-size: 13.5px;
  font-weight: 500;
  color: var(--color-slate-800);
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.trends-model-row[data-on="true"] .trends-model-name {
  font-weight: 600;
}
.trends-model-price {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-slate-400);
  white-space: nowrap;
  flex: none;
}

/* ── Chart card ──────────────────────────────────────────────────────── */
.trends-chart-card {
  min-width: 0;
  overflow: hidden;
}

/* ── Toolbar ─────────────────────────────────────────────────────────── */
.trends-toolbar {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 22px 8px;
  flex-wrap: wrap;
}
.trends-toolbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.trends-toolbar-right {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-left: auto;
}
.trends-toolbar-label {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--color-slate-400);
}

/* Events toggle */
.trends-toggle-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 500;
  color: var(--color-slate-500);
  cursor: pointer;
  user-select: none;
}
.trends-toggle {
  position: relative;
  width: 36px;
  height: 21px;
  border-radius: var(--radius-pill);
  background: var(--color-slate-300);
  border: none;
  cursor: pointer;
  transition: background .18s var(--ease-default);
  flex: none;
  padding: 0;
}
.trends-toggle.on { background: var(--color-indigo-600); }
.trends-toggle-knob {
  position: absolute;
  top: 2px;
  left: 2px;
  width: 17px;
  height: 17px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 1px 3px rgba(0,0,0,.15);
  transition: transform .18s var(--ease-default);
}
.trends-toggle.on .trends-toggle-knob { transform: translateX(15px); }

/* Market events button override */
.trends-toolbar .tp-btn-sm {
  border-radius: var(--radius-md);
}
.trends-toolbar .tp-btn-ghost[aria-expanded="true"] {
  border-color: var(--color-indigo-400);
  background: var(--color-indigo-50);
  color: var(--color-indigo-700);
}

/* Events popover */
.trends-events-popover-wrap {
  position: relative;
}
.trends-events-popover {
  position: absolute;
  top: calc(100% + 9px);
  right: 0;
  z-index: 40;
  width: 360px;
  max-width: 86vw;
  background: #fff;
  border: 1px solid var(--color-slate-200);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  opacity: 0;
  transform: translateY(-6px) scale(.99);
  pointer-events: none;
  transition: opacity .16s var(--ease-default), transform .16s var(--ease-default);
}
.trends-events-popover.open {
  opacity: 1;
  transform: none;
  pointer-events: auto;
}
.trends-popover-header {
  padding: 14px 16px;
  border-bottom: 1px solid var(--color-slate-200);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--color-slate-400);
}
.trends-popover-list {
  max-height: 340px;
  overflow-y: auto;
  padding: 6px;
}
.trends-event-row {
  padding: 12px 11px;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: background .12s var(--ease-default);
}
.trends-event-row:hover { background: var(--color-indigo-50); }
.trends-event-row.out-of-range { opacity: 0.38; cursor: default; }
.trends-event-row.out-of-range:hover { background: transparent; }
.trends-event-title {
  font-size: 13.5px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--color-slate-800);
}
.trends-event-note {
  display: block;
  font-size: 12.5px;
  color: var(--color-slate-500);
  line-height: 1.45;
  margin-top: 3px;
}
.trends-event-date {
  display: block;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--color-rose-600);
  margin-top: 6px;
}

/* ── Chart area ──────────────────────────────────────────────────────── */
.trends-chart-area {
  position: relative;
  padding: 18px 22px 4px;
}
.trends-empty-state {
  display: none;
}
.trends-empty-state.visible {
  display: block;
}
.trends-svg {
  width: 100%;
  height: auto;
  display: block;
  overflow: visible;
}
.trends-svg.hidden { display: none; }

/* SVG chart elements */
.tc-grid { stroke: var(--color-slate-100); stroke-width: 1; }
.tc-grid-v { stroke: var(--color-slate-50); }
.tc-axis { font-family: var(--font-mono); font-size: 10.5px; fill: var(--color-slate-400); }
.tc-line {
  fill: none;
  stroke-width: 2.4;
  stroke-linejoin: round;
  stroke-linecap: round;
  transition: opacity .16s var(--ease-default), stroke-width .16s var(--ease-default);
}
.tc-line.tc-dim { opacity: .16; }
.tc-line.tc-focus { stroke-width: 3.4; }
.tc-pt {
  stroke-width: 2;
  transition: opacity .16s var(--ease-default);
}
.tc-pt.tc-dim { opacity: .14; }
.tc-event {
  stroke: var(--color-rose-400, #fb7185);
  stroke-width: 1.4;
  stroke-dasharray: 3 4;
  opacity: .5;
  pointer-events: none;
}
.tc-avg-line {
  stroke-dasharray: 7 4;
  stroke-width: 2.8;
  opacity: .92;
}
.tc-cross {
  stroke: var(--color-slate-400);
  stroke-width: 1;
  stroke-dasharray: 4 4;
  pointer-events: none;
}
.tc-hoverdot {
  stroke: #fff;
  stroke-width: 2.5;
  pointer-events: none;
}

/* Event marker badges */
.tc-evt-badge { cursor: pointer; }
.tc-evt-mark { fill: var(--color-rose-500); transition: fill .14s var(--ease-default); }
.tc-evt-badge:hover .tc-evt-mark,
.tc-evt-badge.on .tc-evt-mark { fill: var(--color-rose-600); }

/* Focused single-model tooltip card */
.trends-tip, .trends-evt-tip {
  position: absolute;
  pointer-events: none;
  z-index: 6;
  background: #fff;
  border: 1px solid var(--color-slate-200);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: 12px 14px;
  opacity: 0;
  transition: opacity .12s var(--ease-default);
  transform: translateX(14px);
}
.trends-tip { top: 6px; min-width: 168px; }
.trends-tip.flip, .trends-evt-tip.flip { transform: translateX(calc(-100% - 14px)); }
.ttc-name {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: -0.01em;
}
.ttc-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex: none;
}
.ttc-price {
  font-family: var(--font-mono);
  font-size: 23px;
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-top: 7px;
  color: var(--color-slate-900);
}
.ttc-price small {
  font-size: 11px;
  font-weight: 500;
  color: var(--color-slate-400);
  letter-spacing: 0;
}
.ttc-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-slate-400);
  margin-top: 3px;
}

.trends-evt-tip { top: 32px; min-width: 210px; max-width: 270px; }
.et-kind {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: .05em;
  text-transform: uppercase;
  font-weight: 600;
  margin-bottom: 6px;
}
.et-market { color: var(--color-rose-600); }
.et-title {
  font-weight: 600;
  font-size: 14px;
  letter-spacing: -0.01em;
}
.et-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-slate-400);
  margin: 3px 0 7px;
}
.et-note {
  font-size: 12.5px;
  color: var(--color-slate-500);
  line-height: 1.45;
}

/* ── Legend ──────────────────────────────────────────────────────────── */
.trends-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 14px 22px 16px;
  border-top: 1px solid var(--color-slate-100);
  min-height: 36px;
}
.trends-legend-item {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12.5px;
  color: var(--color-slate-500);
  padding: 4px 9px;
  border-radius: var(--radius-pill);
  cursor: default;
  transition: background .14s var(--ease-default);
}
.trends-legend-item:hover {
  background: var(--color-slate-100);
  color: var(--color-slate-900);
}
.trends-legend-line {
  width: 16px;
  height: 3px;
  border-radius: 2px;
  flex: none;
}
.trends-legend-line-dashed {
  height: 0;
  border-top: 2px dashed var(--color-slate-500);
  background: none !important;
}
.trends-legend-delta {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: -0.02em;
  padding: 1px 6px;
  border-radius: var(--radius-pill);
}
.trends-legend-delta.down { color: var(--color-emerald-700); background: var(--color-emerald-50); }
.trends-legend-delta.up   { color: var(--color-rose-700);    background: var(--color-rose-50); }
.trends-legend-evt {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  color: var(--color-slate-400);
  margin-left: auto;
  padding: 4px 0;
}
.trends-legend-dash {
  width: 16px;
  border-top: 2px dashed var(--color-rose-400, #fb7185);
}

.trends-empty-chart {
  padding: 70px 20px;
  text-align: center;
  color: var(--color-slate-400);
}
</style>
