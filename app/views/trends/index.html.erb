<% content_for :title, "How LLM pricing is changing in #{@year} — tokenprice.fyi" %>

<section class="mb-10">
  <h1 class="text-3xl font-bold tracking-tight">How pricing is changing</h1>
  <p class="mt-2 max-w-2xl text-slate-600">The cheapest frontier intelligence, who has cut prices, and what shipped this year.</p>
</section>

<section class="mb-12">
  <h2 class="mb-4 text-lg font-semibold">Cheapest frontier models</h2>
  <ol class="space-y-2">
    <% max = @frontier_ranked.map { |m| m.blended_per_mtok.to_f }.max %>
    <% @frontier_ranked.each_with_index do |model, i| %>
      <% pct = max.zero? ? 0 : (model.blended_per_mtok.to_f / max * 100).round %>
      <li>
        <%= link_to model_path(model), class: "group block rounded-xl border border-slate-200 bg-white p-4 hover:border-indigo-200" do %>
          <div class="flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-500"><%= i + 1 %></span>
              <div>
                <p class="font-medium group-hover:text-indigo-600"><%= model.name %></p>
                <p class="text-xs text-slate-500"><%= model.provider.name %></p>
              </div>
            </div>
            <p class="text-sm font-semibold tabular-nums"><%= usd(model.blended_per_mtok) %><span class="font-normal text-slate-400"> /1M blended</span></p>
          </div>
          <div class="mt-3 h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-indigo-500" style="width: <%= [pct, 4].max %>%"></div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ol>
</section>

<section class="mb-12">
  <h2 class="mb-4 text-lg font-semibold">Recent price moves</h2>
  <% if @movers.any? %>
    <div class="grid gap-3 sm:grid-cols-2">
      <% @movers.each do |model| %>
        <%= link_to model_path(model), class: "block rounded-xl border border-slate-200 bg-white p-4 hover:border-indigo-200" do %>
          <div class="flex items-center justify-between">
            <p class="font-medium"><%= model.name %></p>
            <%= price_change_badge(model.blended_change_since_launch) %>
          </div>
          <p class="mt-1 text-sm text-slate-500">
            <%= usd(model.launch_price.input_per_mtok) %> → <%= usd(model.current_input) %> input ·
            <%= usd(model.launch_price.output_per_mtok) %> → <%= usd(model.current_output) %> output
          </p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500">No tracked price changes yet — they’ll show up here as prices move.</p>
  <% end %>
</section>

<section>
  <h2 class="mb-4 text-lg font-semibold">Released in <%= @year %></h2>
  <% if @timeline.any? %>
    <ol class="relative ml-3 border-l border-slate-200">
      <% @timeline.each do |model| %>
        <li class="mb-5 ml-5">
          <span class="absolute -left-1.5 mt-1.5 h-3 w-3 rounded-full border-2 border-white bg-indigo-500"></span>
          <time class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= model.released_on.strftime("%-d %b") %></time>
          <p class="mt-0.5">
            <%= link_to model.name, model_path(model), class: "font-medium hover:text-indigo-600" %>
            <span class="text-slate-400">·</span>
            <span class="text-sm text-slate-500"><%= model.provider.name %> · in <%= usd(model.current_input) %> / out <%= usd(model.current_output) %></span>
          </p>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="text-sm text-slate-500">No dated releases recorded for <%= @year %> yet.</p>
  <% end %>
</section>
