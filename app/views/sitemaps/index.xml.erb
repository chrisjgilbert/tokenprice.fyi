<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <%# Category tab URLs come off the ModelCategory registry, so a new tab needs
      no sitemap edit (the registry is the source of truth). Language owns the
      root URL at top priority; the rest sit just below it. %>
  <% ModelCategory.all.each do |category| %>
    <url><loc><%= send("#{category.path_name}_url") %></loc><lastmod><%= @catalog_date %></lastmod><changefreq>daily</changefreq><priority><%= category.path_name == :root ? "1.0" : "0.9" %></priority></url>
  <% end %>
  <url><loc><%= events_url %></loc><lastmod><%= @catalog_date %></lastmod><changefreq>daily</changefreq><priority>0.8</priority></url>
  <url><loc><%= compare_url %></loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc><%= sources_url %></loc><changefreq>monthly</changefreq><priority>0.5</priority></url>
  <url><loc><%= learn_url %></loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc><%= how_pricing_works_url %></loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  <url><loc><%= learn_reasoning_url %></loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  <url><loc><%= learn_feature_costs_url %></loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  <url><loc><%= learn_cost_cutting_url %></loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  <% @providers.each do |provider| %>
    <url><loc><%= provider_url(provider) %></loc><lastmod><%= @catalog_date %></lastmod><changefreq>daily</changefreq><priority>0.7</priority></url>
  <% end %>
  <% @models.each do |model| %>
    <url>
      <loc><%= model_url(model) %></loc>
      <lastmod><%= model.updated_at.utc.strftime("%Y-%m-%d") %></lastmod>
      <changefreq>weekly</changefreq><priority>0.8</priority>
    </url>
  <% end %>
</urlset>
