<% content_for :title, "Estimate your workload — what will it cost? · tokenprice.fyi" %>
<% content_for :description, "Describe your AI workload or set the fields, then see what it costs on every model — the cheapest equivalent on prices synced daily and kept as history, where the money goes, and a shareable permalink." %>
<% content_for :canonical, cost_url %>

<% examples = [
     "Support bot over our docs, 5k chats/day, 3 turns each",
     "Summarize 2,000 news articles a day into 3 bullets",
     "Coding agent: plan, edit, review — ~40k runs/month",
     "Classify 1M tickets per month by topic"
   ] %>
<% tiers = [["any", "Any"], ["small", "Small+"], ["mid", "Mid+"], ["frontier", "Frontier"]] %>
<% selected_base = @models.any? { |m| m.slug == @profile.base } ? @profile.base : @estimate.baseline&.slug %>

<header class="co-head reveal">
  <div class="co-eyebrow">
    <span class="nav-dot"></span>
    <span class="tp-section-label">Estimator</span>
    <span class="co-beta">part of the price index</span>
  </div>
  <h1>Price your workload across every model.</h1>
  <p>Describe it in a sentence or set the fields — then see the bill on every model, the <strong>cheapest equivalent</strong> that still fits, and where the money goes. Prices synced daily, kept as history.</p>
</header>

<div class="co-layout">
  <%# ── INPUT: describe on-ramp + always-visible editable profile ── %>
  <section class="card co-input reveal" style="animation-delay:.06s">
    <%# Describe-in-a-sentence: a full navigation that heuristic-fills the fields. %>
    <%= form_with url: cost_path, method: :get, class: "est-describe", data: { turbo_action: "advance" } do %>
      <label class="est-describe-l" for="describe"><%= co_icon(:spark, size: 16) %>Describe your workload — or skip straight to the fields below</label>
      <div class="est-describe-row">
        <%= text_area_tag :describe, params[:describe], id: "describe", rows: 1, class: "co-ta",
              placeholder: "e.g. “support bot over our docs, 5k chats/day, 3 turns each”" %>
        <button class="tp-btn tp-btn-primary" type="submit"><%= co_icon(:spark) %>Estimate</button>
      </div>
      <div class="co-chips">
        <% examples.each do |ex| %>
          <%= link_to ex, cost_path(describe: ex), class: "co-chip" %>
        <% end %>
      </div>
    <% end %>

    <%# Workload profile: every edit re-renders the result frame and updates the URL. %>
    <%= form_with url: cost_path, method: :get,
          data: { controller: "cost-form", turbo_frame: "cost_result", turbo_action: "replace" } do %>
      <%= hidden_field_tag :summary, @profile.summary, id: nil %>
      <div class="co-profile-h">
        <span class="co-ph-t"><%= co_icon(:edit, size: 15) %>Workload profile</span>
        <span class="co-ph-s">Tweak anything — the board updates live.</span>
      </div>
      <div class="co-grid">
        <% [["sys", "System / reused tokens", "cached & repeated each call", @profile.sys, 10],
            ["fresh", "Fresh input tokens", "new per request", @profile.fresh, 10],
            ["out", "Output tokens", "the model's answer", @profile.out, 10],
            ["req", "Requests / month", "monthly volume", @profile.req, 1000]].each do |key, label, hint, val, step| %>
          <div class="co-field">
            <label for="<%= key %>"><%= label %> <span class="co-hint"><%= hint %></span></label>
            <%= number_field_tag key, val, id: key, min: (key == "req" ? 1 : 0), step: step, class: "co-num num",
                  data: { action: "input->cost-form#edit" } %>
          </div>
        <% end %>

        <div class="co-field">
          <label>Cache hit rate <span class="co-slider-val" data-cost-form-target="cacheValue"><%= @profile.cache %>%</span></label>
          <%= range_field_tag :cache, @profile.cache, min: 0, max: 95, step: 5, class: "co-range",
                data: { action: "input->cost-form#cache change->cost-form#submit" } %>
          <span class="co-hint" style="font-size:11.5px">share of system tokens served from cache</span>
        </div>

        <div class="co-field">
          <label>Minimum capability</label>
          <div class="co-tierseg" role="radiogroup" aria-label="Minimum capability">
            <% tiers.each do |value, label| %>
              <label class="<%= 'on' if @profile.tier == value %>">
                <%= radio_button_tag :tier, value, @profile.tier == value, class: "sr-only",
                      data: { action: "change->cost-form#submit" } %>
                <%= label %>
              </label>
            <% end %>
          </div>
        </div>

        <div class="co-field" style="grid-column:1/-1">
          <label for="base">Compare against (baseline)</label>
          <%= select_tag :base,
                options_for_select(@models.map { |m| [ "#{m.name} · #{m.provider_name}", m.slug ] }, selected_base),
                id: "base", class: "co-select", data: { action: "change->cost-form#submit" } %>
        </div>
      </div>
    <% end %>
  </section>

  <%# ── OUTPUT: the optimizer result frame + the two demand probes ── %>
  <section class="co-out" id="co-out" aria-live="polite">
    <%= turbo_frame_tag "cost_result" do %>
      <%= render "costs/result", estimate: @estimate, profile: @profile, sort: @sort %>
    <% end %>

    <%# Demand probes sit outside the result frame so a submitted opt-in
        survives subsequent live edits. %>
    <%= render "signal_signups/probe", frame_id: "probe_measure_cost", variant: "measure",
          payload: @profile.to_query.to_query, title: nil, body: nil, error: nil %>
    <%= render "signal_signups/probe", frame_id: "probe_alert_cost", variant: "alert",
          payload: @profile.to_query.to_query,
          title: "Alert me when this estimate changes",
          body: "Prices move often. Get an email the moment a change shifts this bill — we'll name the model and the new number.", error: nil %>
  </section>
</div>
