<% content_for :title, "Model guide by task — starting options and per-call costs — tokenprice.fyi" %>
<% content_for :description, "Common AI feature patterns broken into steps, each with a starting model suggestion and an estimated per-call cost." %>
<% content_for :canonical, guide_url %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "Starting models by task",
        itemListElement: @patterns.each_with_index.map { |p, i|
          { "@type": "ListItem", position: i + 1, name: p.label, url: guide_task_url(p.slug) }
        }
      }) %>
<% end %>

<header class="led-head reveal">
  <div class="led-eyebrow">
    <span class="nav-dot"></span>
    <span class="tp-section-label">Guide</span>
  </div>
  <h1>Starting models, by task.</h1>
  <p>Most AI features run as a chain of calls, each with a different job. Most steps run on a small model; the step that needs a capable one is rarely the step that drives the bill. Each pattern below breaks into steps, with a starting model and an estimated per-call cost for each.</p>
</header>

<section class="led-series">
  <div class="led-grid">
    <% @patterns.each_with_index do |pattern, i| %>
      <%= link_to guide_task_path(pattern.slug), class: "card led-card reveal", style: "animation-delay:#{(0.04 * i).round(2)}s" do %>
        <h4><%= pattern.label %></h4>
        <p><%= pattern.blurb %></p>
        <div class="led-card-foot">
          <span><%= pluralize(pattern.steps.size, "step") %></span>
          <span class="go"><%= safe_join([ "View pipeline", co_icon(:arrow_right, size: 14) ]) %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
