<%# A capture-only demand probe inside its own Turbo Frame.
    locals: frame_id, variant ("measure"|"alert"), payload, title, body, error (optional) %>
<%= turbo_frame_tag frame_id do %>
  <% if variant == "measure" %>
    <div class="probe probe-measure">
      <div class="probe-glow"></div>
      <div class="probe-head">
        <span class="probe-lock"><%= co_icon(:lock, size: 22) %></span>
        <div class="probe-head-t">
          <span class="probe-tag"><%= co_icon(:spark, size: 13) %>Coming soon · the measure product</span>
          <h3>Measure your <em>real</em> usage</h3>
        </div>
      </div>
      <p class="probe-lede">Paste a production trace or connect your provider data and get your <strong>exact</strong> cost per call — then the same cheapest-equivalent recommendation, on the calls you actually ship.</p>
      <div class="probe-feats">
        <span class="probe-feat"><%= co_icon(:trace, size: 14) %>Paste a trace</span>
        <span class="probe-feat"><%= co_icon(:plug, size: 14) %>Connect your data</span>
        <span class="probe-feat"><%= co_icon(:check, size: 14) %>Exact cost &amp; savings</span>
      </div>
      <%= render "signal_signups/probe_form",
            frame_id: frame_id, variant: "measure", kind: "measure_interest",
            payload: payload, title: nil, body: nil, error: error,
            button_label: "Notify me", button_class: "tp-btn tp-btn-primary" %>
      <p class="probe-fine">No spam — one note when it ships. This is the separate measure product, not part of the estimator.</p>
    </div>
  <% else %>
    <div class="probe probe-alert">
      <div class="probe-alert-head">
        <span class="probe-bell"><%= co_icon(:bell, size: 19) %></span>
        <div>
          <h4><%= title.presence || "Alert me when this price changes" %></h4>
          <p><%= body.presence || "We watch list prices across every provider. Get an email the moment a change moves this number — no dashboard to check." %></p>
        </div>
      </div>
      <%= render "signal_signups/probe_form",
            frame_id: frame_id, variant: "alert", kind: "price_alert",
            payload: payload, title: title, body: body, error: error,
            button_label: "Alert me", button_class: "tp-btn tp-btn-ghost tp-btn-sm" %>
    </div>
  <% end %>
<% end %>
