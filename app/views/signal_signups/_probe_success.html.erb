<%# Success state — replaces the probe card inside its frame. locals: frame_id, variant, email %>
<%= turbo_frame_tag frame_id do %>
  <div class="probe probe-<%= variant %> is-done">
    <% if variant == "measure" %><div class="probe-glow"></div><% end %>
    <div class="probe-ok">
      <span class="probe-ok-ic"><%= co_icon(:check, size: 18) %></span>
      <div>
        <% if variant == "measure" %>
          <strong>You're on the list.</strong> We'll email <span data-probe-email><%= email %></span> when trace and data import go live.
        <% else %>
          <strong>Watching this one.</strong> We'll email <span data-probe-email><%= email %></span> when the price changes.
        <% end %>
      </div>
    </div>
  </div>
<% end %>
