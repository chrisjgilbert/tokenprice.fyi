<%# locals: frame_id, variant, kind, payload, title, body, error, button_label, button_class %>
<%= form_with url: signal_signups_path, method: :post, class: "probe-form", data: { turbo_frame: frame_id } do %>
  <%= hidden_field_tag :kind, kind %>
  <%= hidden_field_tag :variant, variant %>
  <%= hidden_field_tag :frame_id, frame_id %>
  <%= hidden_field_tag :payload, payload %>
  <%= hidden_field_tag :title, title %>
  <%= hidden_field_tag :body, body %>
  <div class="probe-field">
    <%= email_field_tag :email, nil, class: "probe-email", placeholder: "you@company.com",
          "aria-label": (variant == "measure" ? "Email to be notified" : "Email for price alerts"),
          autocomplete: "email", required: true %>
    <button class="<%= button_class %>" type="submit"><%= co_icon(:bell) %><%= button_label %></button>
  </div>
  <% if error.present? %><p class="probe-err"><%= error %></p><% end %>
<% end %>
