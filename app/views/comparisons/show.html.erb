<% both = @left && @right %>
<% content_for :title, both ? "#{@left.name} vs #{@right.name} — tokenprice.fyi" : "Compare LLM API prices — tokenprice.fyi" %>
<% content_for :description, both ? "#{@left.name} vs #{@right.name}: input, output, and cached token rates compared side by side." : "Compare LLM API token prices side by side — input, output, and cached rates per 1M tokens." %>
<%# Collapse every ?a=&b= permutation onto one param-free URL. %>
<% content_for :canonical, compare_url %>

<%# ── Header ──────────────────────────────────────────────────────────────── %>
<section class="mb-8">
  <h1 class="text-4xl font-semibold tracking-tight text-slate-900">Compare two models</h1>
  <p class="mt-2 text-slate-500 text-base">Select any two models. Input, output, cached, and context rarely move together — the cheaper model on one line isn't always the cheaper one on the next.</p>
</section>

<%# ── Selector row + comparison table ─────────────────────────────────────── %>
<%# Wrapped in a frame so this content can also be loaded scoped to the compare
    dialog's nested frame on the homepage, without duplicating any of the
    comparison logic above. Renders identically on the standalone /compare page.
    The page-specific <style> block lives inside the frame too (not above it):
    when this content loads scoped into the dialog's frame, Turbo only keeps
    markup inside the matching <turbo-frame>, so a <style> tag outside it would
    silently stop applying in the embedded case. %>
<%= turbo_frame_tag "comparison" do %>
<style>
/* ── Comparison table ─────────────────────────────────────────────────── */
.cmp-table {
  border: 1px solid var(--color-slate-200);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  background: #fff;
}
.cmp-row {
  display: grid;
  grid-template-columns: minmax(120px, 200px) 1fr 1fr;
  border-bottom: 1px solid var(--color-slate-100);
}
.cmp-row:last-child { border-bottom: none; }
.cmp-row .lbl {
  padding: 17px 20px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--color-slate-400);
  background: var(--color-slate-50);
  display: flex;
  align-items: center;
  border-right: 1px solid var(--color-slate-100);
  font-family: var(--font-mono);
}
.cmp-cell {
  padding: 17px 20px;
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 16px;
  border-right: 1px solid var(--color-slate-100);
  position: relative;
  transition: background .25s var(--ease-default);
}
.cmp-cell:last-child { border-right: none; }
.cmp-cell .val {
  font-family: var(--font-mono);
  font-weight: 600;
  letter-spacing: -0.02em;
}
.cmp-cell.txt .val {
  font-family: var(--font-sans);
  font-weight: 500;
}
.cmp-desc {
  font-weight: 400;
  font-size: 14px;
  line-height: 1.5;
  color: var(--color-slate-600);
}
.cmp-cell.win { background: var(--color-emerald-50); }
.cmp-cell.win .val { color: var(--color-emerald-700); }
/* Accent row for I/O price */
.cmp-row.accent .lbl {
  background: var(--color-indigo-50);
  color: var(--color-indigo-400);
  border-right-color: var(--color-indigo-100);
}
.cmp-row.accent { border-bottom-color: var(--color-indigo-100); }
.cmp-row.accent .cmp-cell { border-right-color: var(--color-indigo-100); }

/* Win checkmark */
.cmp-win-mark {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--color-emerald-500);
  display: inline-grid;
  place-items: center;
  flex: none;
  opacity: 0;
  transform: scale(.4);
  transition: opacity .2s var(--ease-out), transform .22s var(--ease-out);
}
.cmp-win-mark svg { width: 11px; height: 11px; color: #fff; }
.cmp-cell.win .cmp-win-mark { opacity: 1; transform: scale(1); }

/* ── Selector buttons ──────────────────────────────────────────────────── */
.sel-btn {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 13px;
  padding: 16px;
  background: #fff;
  border: 1px solid var(--color-slate-200);
  border-radius: 16px;
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  text-align: left;
  transition: border-color .18s var(--ease-default), box-shadow .18s var(--ease-default);
}
.sel-btn:hover { border-color: var(--color-indigo-200); }
.sel-btn[aria-expanded="true"] {
  border-color: var(--color-indigo-400);
  box-shadow: 0 0 0 4px var(--color-indigo-100);
}

/* ── Popover ───────────────────────────────────────────────────────────── */
.sel-wrap { position: relative; }
.cmp-pop {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  right: 0;
  z-index: 40;
  background: #fff;
  border: 1px solid var(--color-slate-200);
  border-radius: 16px;
  box-shadow: var(--shadow-lg);
  padding: 10px;
  max-height: 340px;
  display: flex;
  flex-direction: column;
  opacity: 0;
  transform: translateY(-6px);
  pointer-events: none;
  transition: opacity .16s var(--ease-default), transform .16s var(--ease-default);
}
.cmp-pop.open {
  opacity: 1;
  transform: none;
  pointer-events: auto;
}
.cmp-pop-search {
  position: relative;
  flex: none;
  margin-bottom: 8px;
}
.cmp-pop-search svg {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  width: 16px;
  height: 16px;
  color: var(--color-slate-400);
  pointer-events: none;
}
.cmp-pop-search input {
  width: 100%;
  height: 40px;
  padding: 0 12px 0 36px;
  border: 1px solid var(--color-slate-200);
  border-radius: 10px;
  background: var(--color-slate-50);
  font-family: var(--font-sans);
  font-size: 14px;
  color: var(--color-slate-900);
  outline: none;
  transition: border-color .16s var(--ease-default), box-shadow .16s var(--ease-default);
}
.cmp-pop-search input::placeholder { color: var(--color-slate-400); }
.cmp-pop-search input:focus {
  border-color: var(--color-indigo-400);
  box-shadow: 0 0 0 3px var(--color-indigo-100);
  background: #fff;
}
.cmp-pop-list {
  overflow-y: auto;
  flex: 1;
  list-style: none;
  margin: 0;
  padding: 0;
}
.cmp-pop-item {
  display: flex;
  align-items: center;
  gap: 11px;
  width: 100%;
  padding: 10px 11px;
  border: none;
  border-radius: 10px;
  background: transparent;
  cursor: pointer;
  font-family: var(--font-sans);
  text-align: left;
  transition: background .14s var(--ease-default);
}
.cmp-pop-item:hover { background: var(--color-slate-50); }
.cmp-pop-item.current { background: var(--color-indigo-50); }
.cmp-pop-item.current .cmp-pop-item-name { color: var(--color-indigo-700); }
.cmp-pop-item[aria-disabled="true"] { opacity: .4; pointer-events: none; cursor: default; }
.cmp-pop-item-info { flex: 1; min-width: 0; }
.cmp-pop-item-name { font-size: 14px; font-weight: 600; letter-spacing: -0.02em; color: var(--color-slate-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cmp-pop-item-price { font-size: 12px; font-family: var(--font-mono); color: var(--color-slate-400); letter-spacing: -0.01em; }

/* ── Swap button ───────────────────────────────────────────────────────── */
.cmp-swap-btn {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1.5px solid var(--color-slate-300);
  background: #fff;
  display: inline-grid;
  place-items: center;
  cursor: pointer;
  flex: none;
  margin: auto;
  box-shadow: var(--shadow-xs);
  transition: border-color .18s var(--ease-default), background .18s var(--ease-default), transform .25s var(--ease-default);
  color: var(--color-slate-500);
}
.cmp-swap-btn:hover {
  border-color: var(--color-indigo-400);
  background: var(--color-indigo-50);
  color: var(--color-indigo-600);
  transform: rotate(180deg);
}
.cmp-swap-btn svg { width: 18px; height: 18px; }

/* ── Selector grid ─────────────────────────────────────────────────────── */
.cmp-selectors {
  display: grid;
  grid-template-columns: 42px 1fr 1fr;
  gap: 12px;
  align-items: start;
  margin-bottom: 28px;
}
@media (max-width: 720px) {
  .cmp-selectors {
    grid-template-columns: 1fr 1fr;
  }
  .cmp-swap-col { display: none; }
}
/* Below ~520px two model cards side by side get too cramped to read (the wider
   one clips), and the three-column comparison rows overflow the viewport and
   are clipped by the table's overflow:hidden — the values become unreachable.
   Stack the selectors, and give each metric a full-width label with the two
   models side by side beneath it. */
@media (max-width: 520px) {
  .cmp-selectors { grid-template-columns: 1fr; }
  .cmp-row { grid-template-columns: 1fr 1fr; }
  .cmp-row .lbl {
    grid-column: 1 / -1;
    border-right: none;
    border-bottom: 1px solid var(--color-slate-100);
    padding: 11px 16px;
  }
  .cmp-row.accent .lbl { border-bottom-color: var(--color-indigo-100); }
  .cmp-cell {
    padding: 14px 16px;
    font-size: 15px;
    align-items: baseline;
    gap: 7px;
  }
}

/* Selector info layout */
.sel-btn-info { flex: 1; min-width: 0; }
.sel-btn-name { font-size: 15px; font-weight: 600; letter-spacing: -0.02em; color: var(--color-slate-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sel-btn-sub  { font-size: 12px; color: var(--color-slate-400); margin-top: 2px; }
.sel-btn-caret { flex: none; color: var(--color-slate-400); width: 17px; height: 17px; }

/* ── Provider square sizes ─────────────────────────────────────────────── */
.tp-prov-sq-sel {
  width: 38px;
  height: 38px;
  border-radius: 11px;
  font-size: 16px;
}
</style>
<div data-controller="compare"
     data-compare-slug-a-value="<%= @left&.slug %>"
     data-compare-slug-b-value="<%= @right&.slug %>">

  <div class="cmp-selectors">
    <%# Swap button %>
    <div class="cmp-swap-col" style="display:flex; align-items:center; justify-content:center; padding-top:4px;">
      <button class="cmp-swap-btn"
              data-action="click->compare#swap"
              data-compare-target="swapBtn"
              aria-label="Swap models"
              title="Swap sides">
        <%= raw ApplicationHelper::ICONS[:swap] %>
      </button>
    </div>

    <%# Selector A %>
    <div class="sel-wrap">
      <button class="sel-btn"
              aria-expanded="false"
              aria-haspopup="listbox"
              data-compare-target="btnA"
              data-action="click->compare#toggleA">
        <%= provider_square(@left.provider, size: :md) if @left %>
        <% unless @left %>
          <span class="tp-prov-sq tp-prov-sq-md" style="background:#6366f1">?</span>
        <% end %>
        <span class="sel-btn-info">
          <span class="sel-btn-name"><%= @left&.name || "Select a model" %></span>
          <span class="sel-btn-sub">
            <% if @left %>
              <%= @left.provider.name %> · <%= @left.tier&.titleize %>
            <% else %>
              Choose model A
            <% end %>
          </span>
        </span>
        <span class="sel-btn-caret"><%= raw ApplicationHelper::ICONS[:chevron_down] %></span>
      </button>

      <div class="cmp-pop" data-compare-target="popA" aria-label="Select model A">
        <div class="cmp-pop-search">
          <%= raw ApplicationHelper::ICONS[:search] %>
          <input type="search"
                 placeholder="Search models…"
                 autocomplete="off"
                 aria-label="Search models"
                 data-compare-target="searchA"
                 data-action="input->compare#searchA">
        </div>
        <ul class="cmp-pop-list" data-compare-target="listA" role="listbox">
          <% @all_models.each do |m| %>
            <li data-model-name="<%= m.name %>" data-model-provider="<%= m.provider.name %>" role="option" aria-selected="<%= @left&.slug == m.slug ? 'true' : 'false' %>">
              <button class="cmp-pop-item <%= 'current' if @left&.slug == m.slug %>"
                      data-action="click->compare#pick"
                      data-side="A"
                      data-slug="<%= m.slug %>"
                      aria-disabled="<%= @right&.slug == m.slug ? 'true' : 'false' %>">
                <%= provider_square(m.provider, size: :sm) %>
                <span class="cmp-pop-item-info">
                  <span class="cmp-pop-item-name"><%= m.name %></span>
                  <span class="cmp-pop-item-price"><%= picker_price(m) %></span>
                </span>
              </button>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <%# Selector B %>
    <div class="sel-wrap">
      <button class="sel-btn"
              aria-expanded="false"
              aria-haspopup="listbox"
              data-compare-target="btnB"
              data-action="click->compare#toggleB">
        <%= provider_square(@right.provider, size: :md) if @right %>
        <% unless @right %>
          <span class="tp-prov-sq tp-prov-sq-md" style="background:#6366f1">?</span>
        <% end %>
        <span class="sel-btn-info">
          <span class="sel-btn-name"><%= @right&.name || "Select a model" %></span>
          <span class="sel-btn-sub">
            <% if @right %>
              <%= @right.provider.name %> · <%= @right.tier&.titleize %>
            <% else %>
              Choose model B
            <% end %>
          </span>
        </span>
        <span class="sel-btn-caret"><%= raw ApplicationHelper::ICONS[:chevron_down] %></span>
      </button>

      <div class="cmp-pop" data-compare-target="popB" aria-label="Select model B">
        <div class="cmp-pop-search">
          <%= raw ApplicationHelper::ICONS[:search] %>
          <input type="search"
                 placeholder="Search models…"
                 autocomplete="off"
                 aria-label="Search models"
                 data-compare-target="searchB"
                 data-action="input->compare#searchB">
        </div>
        <ul class="cmp-pop-list" data-compare-target="listB" role="listbox">
          <% @all_models.each do |m| %>
            <li data-model-name="<%= m.name %>" data-model-provider="<%= m.provider.name %>" role="option" aria-selected="<%= @right&.slug == m.slug ? 'true' : 'false' %>">
              <button class="cmp-pop-item <%= 'current' if @right&.slug == m.slug %>"
                      data-action="click->compare#pick"
                      data-side="B"
                      data-slug="<%= m.slug %>"
                      aria-disabled="<%= @left&.slug == m.slug ? 'true' : 'false' %>">
                <%= provider_square(m.provider, size: :sm) %>
                <span class="cmp-pop-item-info">
                  <span class="cmp-pop-item-name"><%= m.name %></span>
                  <span class="cmp-pop-item-price"><%= picker_price(m) %></span>
                </span>
              </button>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <%# ── Comparison table ─────────────────────────────────────────────────── %>
  <% if @left && @right %>
    <%
      # Determine numeric winner: :a, :b, or nil
      winner_for = ->(a_val, b_val, comparison) do
        next nil if comparison == :none
        next nil if a_val.nil? && b_val.nil?
        if comparison == :lower_better
          a = a_val.nil? ? Float::INFINITY  : a_val.to_f
          b = b_val.nil? ? Float::INFINITY  : b_val.to_f
        else
          a = a_val.nil? ? -Float::INFINITY : a_val.to_f
          b = b_val.nil? ? -Float::INFINITY : b_val.to_f
        end
        next nil if a == b
        comparison == :lower_better ? (a < b ? :a : :b) : (a > b ? :a : :b)
      end
    %>

    <div class="cmp-table">

      <%# Shown first — more useful context than the numbers below. Hand-rolled,
          not folded into numeric_rows/text_rows: it hides entirely when both
          sides lack a description, unlike that loop's always-dash-fill rows. %>
      <% if @left.description.present? || @right.description.present? %>
        <div class="cmp-row">
          <div class="lbl">Description</div>
          <% [@left, @right].each do |m| %>
            <div class="cmp-cell txt">
              <span class="val cmp-desc">
                <%= m.description.presence || content_tag(:span, "—", class: "tp-muted-dash") %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Row 1 — I/O price (accent, no winner) %>
      <div class="cmp-row accent">
        <div class="lbl">I/O price /1M</div>
        <div class="cmp-cell">
          <span class="val"><%= io_price(@left) %></span>
        </div>
        <div class="cmp-cell">
          <span class="val"><%= io_price(@right) %></span>
        </div>
      </div>

      <%
        numeric_rows = [
          { label: "Input /1M",      a_val: @left.current_input,         b_val: @right.current_input,         cmp: :lower_better,  fmt: :usd },
          { label: "Output /1M",     a_val: @left.current_output,        b_val: @right.current_output,        cmp: :lower_better,  fmt: :usd },
          { label: "Cached in /1M",  a_val: @left.current_cached_input,  b_val: @right.current_cached_input,  cmp: :lower_better,  fmt: :usd },
          { label: "Context",        a_val: @left.context_window,        b_val: @right.context_window,        cmp: :higher_better, fmt: :tokens },
        ]
        text_rows = [
          { label: "Δ input since launch",  a_val: @left.input_change_since_launch,  b_val: @right.input_change_since_launch,  fmt: :change },
          { label: "Δ output since launch", a_val: @left.output_change_since_launch, b_val: @right.output_change_since_launch, fmt: :change },
          { label: "Tier",     a_val: tier_badge(@left.tier),   b_val: tier_badge(@right.tier),   fmt: :raw  },
          { label: "Released", a_val: fmt_date(@left.released_on), b_val: fmt_date(@right.released_on), fmt: :text },
          { label: "Status",   a_val: status_badge(@left.status),  b_val: status_badge(@right.status),  fmt: :raw  },
          { label: "Provider", a_val: nil, b_val: nil, fmt: :provider },
        ]
      %>

      <%# Numeric rows with winner highlighting %>
      <% numeric_rows.each_with_index do |row, i| %>
        <% w = winner_for.call(row[:a_val], row[:b_val], row[:cmp]) %>
        <div class="cmp-row">
          <div class="lbl"><%= row[:label] %></div>
          <% [:a, :b].each do |side| %>
            <% val    = side == :a ? row[:a_val] : row[:b_val] %>
            <% is_win = w == side %>
            <div class="cmp-cell <%= 'win' if is_win %>">
              <span class="cmp-win-mark" aria-hidden="true" style="transition-delay:<%= is_win ? "#{i * 90}ms" : '0ms' %>">
                <%= raw ApplicationHelper::ICONS[:check] %>
              </span>
              <span class="val">
                <% if row[:fmt] == :usd %>
                  <%= usd(val) %>
                <% elsif row[:fmt] == :tokens %>
                  <%= tokens_short(val) %>
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Text / non-comparable rows %>
      <% text_rows.each do |row| %>
        <div class="cmp-row">
          <div class="lbl"><%= row[:label] %></div>
          <% [:a, :b].each do |side| %>
            <div class="cmp-cell txt">
              <span class="val">
                <% if row[:fmt] == :provider %>
                  <% m = side == :a ? @left : @right %>
                  <div style="display:flex;align-items:center;gap:9px">
                    <%= provider_square(m.provider, size: :md) %>
                    <span><%= m.provider.name %></span>
                  </div>
                <% elsif row[:fmt] == :change %>
                  <% v = side == :a ? row[:a_val] : row[:b_val] %>
                  <%= v ? price_change_badge(v) : content_tag(:span, "—", class: "tp-muted-dash") %>
                <% elsif row[:fmt] == :raw %>
                  <% v = side == :a ? row[:a_val] : row[:b_val] %>
                  <%= v.present? ? raw(v) : content_tag(:span, "—", class: "tp-muted-dash") %>
                <% else %>
                  <% v = side == :a ? row[:a_val] : row[:b_val] %>
                  <%= v.present? ? v : content_tag(:span, "—", class: "tp-muted-dash") %>
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

    </div><%# /.cmp-table %>
  <% else %>
    <p class="text-slate-500">Pick two models above to compare them.</p>
  <% end %>

</div><%# /[data-controller="compare"] %>
<% end %><%# /turbo_frame_tag "comparison" %>
