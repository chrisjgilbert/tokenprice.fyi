<%# The embed result — the emb-out panel inside the model's estimate frame.
    locals: entry, here, cheapest, fresh, out, req, in_pos, out_pos, deep_link %>
<%= turbo_frame_tag "estimate_embed_#{entry.slug}" do %>
  <div class="emb-out">
    <span class="emb-out-l">Estimated spend on <%= entry.name %></span>
    <div class="emb-total num"><%= co_money(here.monthly) %></div>
    <div class="emb-per num"><%= co_per_call(here.per_req) %> / request · <%= co_kfmt(fresh) %> in · <%= co_kfmt(out) %> out · <%= co_kfmt(req) %> req/mo</div>

    <% if cheapest && cheapest.slug != entry.slug && cheapest.monthly < here.monthly * 0.97 %>
      <div class="emb-cheapest on">
        <span class="tp-delta tp-delta-down"><%= co_icon(:trend_down, size: 13) %><%= CostFormat.pct(cheapest.monthly, here.monthly).abs %>%</span>
        <span>
          <%= link_to model_path(cheapest.slug) do %><%= provider_square(cheapest.entry.provider) %><%= cheapest.entry.name %><% end %>
          would run this for <strong><%= co_money(cheapest.monthly) %>/mo</strong> — save <%= co_money(here.monthly - cheapest.monthly) %>/mo.
        </span>
      </div>
    <% else %>
      <div class="emb-cheapest flat"><%= co_icon(:check) %><span><%= entry.name %> is already the cheapest model for this workload shape.</span></div>
    <% end %>

    <%= link_to deep_link, class: "tp-btn tp-btn-primary emb-cta" do %><%= co_icon(:spark) %>Open in full estimator<%= co_icon(:arrow_right) %><% end %>
  </div>
<% end %>
