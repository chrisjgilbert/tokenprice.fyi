<li class="ev-item" data-kind="<%= event.kind %>">
  <span class="ev-node ev-<%= event.kind %>" aria-hidden="true">
    <%= icon(event_kind_icon(event.kind), size: 14) %>
  </span>
  <div class="ev-body">
    <div class="ev-meta">
      <time class="ev-date" datetime="<%= event.date.iso8601 %>"><%= fmt_date_full(event.date) %></time>
      <span class="tp-badge tp-kind-<%= event.kind %>"><%= event_kind_label(event.kind) %></span>
    </div>

    <h3 class="ev-title">
      <% if event.model %>
        <%= link_to event.title, model_path(event.model) %>
      <% else %>
        <%= event.title %>
      <% end %>
    </h3>

    <% if event.note.present? %>
      <p class="ev-note"><%= event.note %></p>
    <% end %>

    <% if event.so_what.present? %>
      <p class="ev-sowhat"><%= event.so_what %></p>
    <% end %>

    <% if event.kind == "launch" && (m = event.model) %>
      <div class="ev-tags">
        <%= link_to provider_path(event.provider), class: "ev-provider" do %>
          <%= provider_square(event.provider, size: :sm) %>
          <span><%= event.provider.name %></span>
        <% end %>
        <%= tier_badge(m.tier) %>
        <span class="ev-tag"><%= io_price(m, tag: true) %></span>
        <% if m.context_window %>
          <span class="ev-tag num"><%= tokens_short(m.context_window) %> ctx</span>
        <% end %>
      </div>
    <% elsif event.kind == "reprice" && (mv = event.move) %>
      <div class="ev-tags">
        <%= link_to provider_path(event.provider), class: "ev-provider" do %>
          <%= provider_square(event.provider, size: :sm) %>
          <span><%= event.provider.name %></span>
        <% end %>
        <%= price_change_badge(mv.input) %>
        <%= price_change_badge(mv.output) %>
        <% if mv.input %>
          <span class="ev-tag num"><%= usd_plain(mv.from.input_per_mtok) %> → <%= usd_plain(mv.to.input_per_mtok) %> in</span>
        <% end %>
        <% if mv.output %>
          <span class="ev-tag num"><%= usd_plain(mv.from.output_per_mtok) %> → <%= usd_plain(mv.to.output_per_mtok) %> out</span>
        <% end %>
      </div>
    <% elsif event.citations.present? %>
      <div class="ev-cites">
        <span class="ev-cites-label">Sources</span>
        <% event.citations.each do |citation| %>
          <%= link_to citation_host(citation["url"]), citation["url"], class: "ev-cite",
                title: citation["title"].presence, target: "_blank", rel: "noopener" %>
        <% end %>
      </div>
    <% elsif event.source_url.present? %>
      <%= link_to event.source_url, class: "ev-source", target: "_blank", rel: "noopener" do %>
        Source <%= icon(:external, size: 13) %>
      <% end %>
    <% end %>
  </div>
</li>
