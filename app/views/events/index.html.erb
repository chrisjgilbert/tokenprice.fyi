<% content_for :title, "Market events — LLM pricing & launch timeline — tokenprice.fyi" %>
<% content_for :description, "A dated timeline of LLM market events and model launches, newest first." %>
<% content_for :canonical, events_url %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: "Market events",
        url: events_url,
        description: "A timeline of LLM market events and model launches, newest first.",
        isPartOf: { "@type": "WebSite", "@id": "#{request.base_url}/#website" }
      }) %>
<% end %>

<div class="events-page">
  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <header class="events-header">
    <h1 class="events-h1">Market events</h1>
    <p class="events-subtitle">
      Every market event and model launch we've tracked —
      <span class="num"><%= @market_count %></span> market events and
      <span class="num"><%= @launch_count %></span> launches<% if @earliest_year %>, going back to
      <span class="num"><%= @earliest_year %></span><% end %>.
      Curated from the headlines we scan each day.
    </p>
  </header>

  <%# ── Recent price changes ────────────────────────────────────────────── %>
  <%# The catalog's price moves in the last 30 days — the web home for the Slack
      price-moves digest, moved here when the flagship-trends page was retired. %>
  <% if @recent_price_moves&.any? %>
    <%= render "recent_price_changes", moves: @recent_price_moves %>
  <% end %>

  <%# ── Filter ─────────────────────────────────────────────────────────── %>
  <%# Each tab is a link to that kind's first page — filtering happens on the
      server, so the count reflects the whole timeline, not just what's loaded. %>
  <div class="events-toolbar">
    <div class="tp-seg events-seg" role="group" aria-label="Filter events by kind">
      <%= link_to events_path, class: ("on" if @kind.nil?), data: { kind: "all" },
            "aria-current": ("page" if @kind.nil?) do %>
        All <span class="events-seg-n"><%= @total_count %></span>
      <% end %>
      <%= link_to events_path(kind: "market"), class: ("on" if @kind == "market"), data: { kind: "market" },
            "aria-current": ("page" if @kind == "market") do %>
        Market <span class="events-seg-n"><%= @market_count %></span>
      <% end %>
      <%= link_to events_path(kind: "launch"), class: ("on" if @kind == "launch"), data: { kind: "launch" },
            "aria-current": ("page" if @kind == "launch") do %>
        Launches <span class="events-seg-n"><%= @launch_count %></span>
      <% end %>
    </div>
  </div>

  <%# ── Timeline ───────────────────────────────────────────────────────── %>
  <div class="tp-card events-card">
    <% if @events.any? %>
      <div data-controller="events-infinite">
        <div class="events-timeline" id="ev-timeline" data-events-infinite-target="timeline">
          <% @events_by_year.each do |year, events| %>
            <%= render "events/year_group", year: year, events: events %>
          <% end %>
        </div>
        <%= render "events/sentinel", has_more: @has_more, next_page: @next_page, kind: @kind %>
      </div>
    <% elsif @kind %>
      <div class="tp-empty">
        <div class="tp-empty-icon"><%= icon(:calendar, size: 26) %></div>
        <p class="font-medium">No <%= event_kind_noun(@kind) %> tracked.</p>
        <p class="text-sm mt-1" style="color:var(--color-slate-400)">
          <%= link_to "See all events", events_path, class: "text-indigo-600 hover:underline" %>.
        </p>
      </div>
    <% else %>
      <div class="tp-empty">
        <div class="tp-empty-icon"><%= icon(:calendar, size: 26) %></div>
        <p class="font-medium">No market events recorded yet.</p>
        <p class="text-sm mt-1" style="color:var(--color-slate-400)">Launches and market events will appear here as they're tracked.</p>
      </div>
    <% end %>
  </div>
</div>

<style>
/* ── Events page ─────────────────────────────────────────────────────── */
.events-page {
  max-width: 840px;
  padding-top: 36px;
  padding-bottom: 64px;
}
.events-header { margin-bottom: 24px; }
.events-h1 {
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -0.033em;
  line-height: 1.05;
  color: var(--color-slate-900);
}
.events-subtitle {
  margin-top: 14px;
  max-width: 50em;
  color: var(--color-slate-500);
  font-size: 17px;
  line-height: 1.6;
}

/* ── Filter toolbar ──────────────────────────────────────────────────── */
.events-toolbar {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}
.events-seg-n {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  margin-left: 5px;
  opacity: .55;
}
.tp-seg .on .events-seg-n { opacity: .8; }

/* ── Timeline card ───────────────────────────────────────────────────── */
/* No `overflow` here on purpose: a clipping context would become the scroll
   container for the sticky year headers and pin them inside the card instead
   of below the nav. */
.events-card { padding: 6px 28px; }
@media (max-width: 560px) { .events-card { padding: 6px 18px; } }

.events-timeline { position: relative; }

/* Year header — sticks just below the nav as you scroll a long timeline. */
.ev-year-group { position: relative; }
.ev-year {
  position: sticky;
  top: var(--nav-h);
  z-index: 5;
  margin: 0;
  padding: 16px 0 12px 50px;
  background: #fff;
  font-family: var(--font-mono);
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-slate-900);
}
/* Hairline under each sticky year so it reads as a divider when pinned. */
.ev-year::after {
  content: "";
  position: absolute;
  left: 50px; right: 0; bottom: 0;
  height: 1px;
  background: var(--color-slate-100);
}

/* ── Timeline rail + items ───────────────────────────────────────────── */
.ev-list { position: relative; list-style: none; margin: 0; padding: 0; }
/* The spine: one continuous line down the node column, spanning from the first
   node's centre to the last. Offsets (30px / 34px) are item padding-top + node
   radius, so the line lands on node centres and stays correct when filtering
   hides items and the list re-flows — no per-item tail to trim. */
.ev-list::before {
  content: "";
  position: absolute;
  left: 15px;
  top: 30px;
  bottom: 34px;
  width: 2px;
  background: var(--color-slate-200);
}
.ev-item {
  position: relative;
  display: grid;
  grid-template-columns: 32px 1fr;
  column-gap: 18px;
  padding: 14px 0 18px;
}

.ev-node {
  grid-column: 1;
  align-self: start;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  color: #fff;
  position: relative;
  z-index: 1;
  box-shadow: 0 0 0 4px #fff; /* halo so the spine doesn't touch the node */
}
.ev-node svg { width: 14px; height: 14px; }
.ev-market { background: var(--color-rose-500); }
.ev-launch { background: var(--color-emerald-500); }

.ev-body { grid-column: 2; min-width: 0; padding-top: 1px; }

.ev-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 5px;
}
.ev-date {
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--color-slate-400);
}
.ev-title {
  font-size: 16.5px;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.3;
  color: var(--color-slate-900);
}
.ev-title a {
  color: inherit;
  text-decoration: none;
  transition: color .14s var(--ease-default);
}
.ev-title a:hover {
  color: var(--color-indigo-700);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.ev-desc {
  margin-top: 6px;
  font-size: 14.5px;
  line-height: 1.55;
  color: var(--color-slate-600);
  max-width: 62ch;
}
.ev-note {
  margin-top: 5px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--color-slate-500);
  max-width: 62ch;
}

/* Launch metadata row + market source link */
.ev-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-top: 12px;
}
.ev-provider {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 3px 8px 3px 5px;
  border-radius: var(--radius-pill);
  font-size: 12.5px;
  font-weight: 600;
  color: var(--color-slate-600);
  text-decoration: none;
  transition: background .14s var(--ease-default), color .14s var(--ease-default);
}
.ev-provider:hover { background: var(--color-slate-100); color: var(--color-slate-900); }
.ev-tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: var(--radius-pill);
  background: var(--color-slate-100);
  font-size: 12px;
  font-weight: 600;
  color: var(--color-slate-600);
}
.ev-tag .tp-io { font-size: 12px; }
.ev-source {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-top: 11px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--color-indigo-600);
  text-decoration: none;
}
.ev-source:hover { color: var(--color-indigo-700); text-decoration: underline; text-underline-offset: 2px; }

/* The LLM-written "so what": why the event matters, set apart from the factual note. */
.ev-sowhat {
  margin-top: 9px;
  padding-left: 11px;
  border-left: 2px solid var(--color-rose-500);
  font-size: 14px;
  line-height: 1.55;
  color: var(--color-slate-600);
  max-width: 62ch;
}
.ev-cites {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-top: 11px;
}
.ev-cites-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--color-slate-400);
}
.ev-cite {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--color-indigo-600);
  text-decoration: none;
}
.ev-cite:hover { color: var(--color-indigo-700); text-decoration: underline; text-underline-offset: 2px; }

/* ── Infinite-scroll sentinel ────────────────────────────────────────── */
/* Sits below the timeline; the controller loads the next page as it nears the
   viewport. The "Load more" link is the no-JS fallback, hidden once the
   controller connects (it sets data-events-infinite-connected, which the
   selector below keys off) so the observer is the only trigger. */
.ev-sentinel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 20px 0 10px;
  min-height: 24px;
}
.ev-more {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-indigo-600);
  text-decoration: none;
}
.ev-more:hover { color: var(--color-indigo-700); text-decoration: underline; text-underline-offset: 2px; }

/* The spinner shows only while a fetch is in flight (controller toggles
   .is-loading); the fallback link hides once the controller has connected. */
.ev-spinner { display: none; }
[data-events-infinite-connected] .ev-more { display: none; }
[data-events-infinite-connected] .ev-sentinel.is-loading .ev-spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid var(--color-slate-200);
  border-top-color: var(--color-indigo-500);
  border-radius: 50%;
  animation: tp-spin .7s linear infinite;
}
@keyframes tp-spin { to { transform: rotate(360deg); } }

.ev-sentinel-end { padding: 24px 0 8px; }
.ev-end {
  font-size: 12.5px;
  color: var(--color-slate-400);
  font-weight: 500;
}
</style>
