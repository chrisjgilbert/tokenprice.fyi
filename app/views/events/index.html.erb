<% content_for :title, "Market events — LLM pricing & launch timeline — tokenprice.fyi" %>
<% content_for :description, "A dated timeline of LLM market events and model launches — every price cut, repricing, and release tracked here, newest first." %>
<% content_for :canonical, events_url %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: "Market events",
        url: events_url,
        description: "A timeline of LLM market events and model launches, newest first.",
        isPartOf: { "@type": "WebSite", name: "tokenprice.fyi", url: root_url }
      }) %>
<% end %>

<div class="events-page" data-controller="events-filter">
  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <header class="events-header">
    <h1 class="events-h1">Market events</h1>
    <p class="events-subtitle">
      Every price cut, repricing, and model launch we've tracked —
      <span class="num"><%= @market_count %></span> market events and
      <span class="num"><%= @launch_count %></span> launches<% if @earliest_year %>, going back to
      <span class="num"><%= @earliest_year %></span><% end %>.
    </p>
  </header>

  <%# ── Filter ─────────────────────────────────────────────────────────── %>
  <div class="events-toolbar">
    <div class="tp-seg events-seg" role="group" aria-label="Filter events by kind">
      <button class="on" type="button" data-kind="all" aria-pressed="true"
              data-events-filter-target="tab"
              data-action="events-filter#select">
        All <span class="events-seg-n"><%= @events.size %></span>
      </button>
      <button type="button" data-kind="market" aria-pressed="false"
              data-events-filter-target="tab"
              data-action="events-filter#select">
        Market <span class="events-seg-n"><%= @market_count %></span>
      </button>
      <button type="button" data-kind="launch" aria-pressed="false"
              data-events-filter-target="tab"
              data-action="events-filter#select">
        Launches <span class="events-seg-n"><%= @launch_count %></span>
      </button>
    </div>
    <p class="events-status" role="status" aria-live="polite" data-events-filter-target="status"></p>
  </div>

  <%# ── Timeline ───────────────────────────────────────────────────────── %>
  <div class="tp-card events-card">
    <% if @events.any? %>
      <div class="events-timeline" data-events-filter-target="timeline">
        <% @events_by_year.each do |year, events| %>
          <section class="ev-year-group" data-events-filter-target="yearGroup">
            <h2 class="ev-year"><%= year %></h2>
            <ol class="ev-list">
              <% events.each do |event| %>
                <li class="ev-item" data-kind="<%= event.kind %>" data-events-filter-target="item">
                  <span class="ev-node ev-<%= event.kind %>" aria-hidden="true">
                    <%= icon(event_kind_icon(event.kind), size: 14) %>
                  </span>
                  <div class="ev-body">
                    <div class="ev-meta">
                      <time class="ev-date" datetime="<%= event.date.iso8601 %>"><%= fmt_date_full(event.date) %></time>
                      <span class="tp-badge tp-kind-<%= event.kind %>"><%= event_kind_label(event.kind) %></span>
                    </div>

                    <h3 class="ev-title">
                      <% if event.model %>
                        <%= link_to event.title, model_path(event.model) %>
                      <% else %>
                        <%= event.title %>
                      <% end %>
                    </h3>

                    <% if event.note.present? %>
                      <p class="ev-note"><%= event.note %></p>
                    <% end %>

                    <% if event.kind == "launch" && (m = event.model) %>
                      <div class="ev-tags">
                        <%= link_to provider_path(event.provider), class: "ev-provider" do %>
                          <%= provider_square(event.provider, size: :sm) %>
                          <span><%= event.provider.name %></span>
                        <% end %>
                        <%= tier_badge(m.tier) %>
                        <span class="ev-tag"><%= io_price(m, tag: true) %></span>
                        <% if m.context_window %>
                          <span class="ev-tag num"><%= tokens_short(m.context_window) %> ctx</span>
                        <% end %>
                      </div>
                    <% elsif event.source_url.present? %>
                      <%= link_to event.source_url, class: "ev-source", target: "_blank", rel: "noopener" do %>
                        Source <%= icon(:external, size: 13) %>
                      <% end %>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ol>
          </section>
        <% end %>

        <%# Shown by the filter controller only when a filter hides everything. %>
        <div class="ev-empty" data-events-filter-target="empty" hidden>
          <div class="tp-empty">
            <div class="tp-empty-icon"><%= icon(:calendar, size: 26) %></div>
            <p class="font-medium">No events of this kind yet.</p>
          </div>
        </div>
      </div>
    <% else %>
      <div class="tp-empty">
        <div class="tp-empty-icon"><%= icon(:calendar, size: 26) %></div>
        <p class="font-medium">No market events recorded yet.</p>
        <p class="text-sm mt-1" style="color:var(--color-slate-400)">Launches and price moves will appear here as they're tracked.</p>
      </div>
    <% end %>
  </div>
</div>

<style>
/* ── Events page ─────────────────────────────────────────────────────── */
.events-page {
  max-width: 840px;
  padding-top: 36px;
  padding-bottom: 64px;
}
.events-header { margin-bottom: 24px; }
.events-h1 {
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -0.033em;
  line-height: 1.05;
  color: var(--color-slate-900);
}
.events-subtitle {
  margin-top: 14px;
  max-width: 50em;
  color: var(--color-slate-500);
  font-size: 17px;
  line-height: 1.6;
}

/* ── Filter toolbar ──────────────────────────────────────────────────── */
.events-toolbar {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}
.events-seg-n {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  margin-left: 5px;
  opacity: .55;
}
.tp-seg button.on .events-seg-n { opacity: .8; }
.events-status {
  font-size: 13px;
  color: var(--color-slate-500);
  font-weight: 500;
}

/* ── Timeline card ───────────────────────────────────────────────────── */
/* No `overflow` here on purpose: a clipping context would become the scroll
   container for the sticky year headers and pin them inside the card instead
   of below the nav. */
.events-card { padding: 6px 28px; }
@media (max-width: 560px) { .events-card { padding: 6px 18px; } }

.events-timeline { position: relative; }

/* Year header — sticks just below the nav as you scroll a long timeline. */
.ev-year-group { position: relative; }
.ev-year {
  position: sticky;
  top: var(--nav-h);
  z-index: 5;
  margin: 0;
  padding: 16px 0 12px 50px;
  background: #fff;
  font-family: var(--font-mono);
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-slate-900);
}
/* Hairline under each sticky year so it reads as a divider when pinned. */
.ev-year::after {
  content: "";
  position: absolute;
  left: 50px; right: 0; bottom: 0;
  height: 1px;
  background: var(--color-slate-100);
}

/* ── Timeline rail + items ───────────────────────────────────────────── */
.ev-list { position: relative; list-style: none; margin: 0; padding: 0; }
/* The spine: one continuous line down the node column, spanning from the first
   node's centre to the last. Offsets (30px / 34px) are item padding-top + node
   radius, so the line lands on node centres and stays correct when filtering
   hides items and the list re-flows — no per-item tail to trim. */
.ev-list::before {
  content: "";
  position: absolute;
  left: 15px;
  top: 30px;
  bottom: 34px;
  width: 2px;
  background: var(--color-slate-200);
}
.ev-item {
  position: relative;
  display: grid;
  grid-template-columns: 32px 1fr;
  column-gap: 18px;
  padding: 14px 0 18px;
}

.ev-node {
  grid-column: 1;
  align-self: start;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  color: #fff;
  position: relative;
  z-index: 1;
  box-shadow: 0 0 0 4px #fff; /* halo so the spine doesn't touch the node */
}
.ev-node svg { width: 14px; height: 14px; }
.ev-market { background: var(--color-rose-500); }
.ev-launch { background: var(--color-emerald-500); }

.ev-body { grid-column: 2; min-width: 0; padding-top: 1px; }

.ev-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 5px;
}
.ev-date {
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--color-slate-400);
}
.ev-title {
  font-size: 16.5px;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.3;
  color: var(--color-slate-900);
}
.ev-title a {
  color: inherit;
  text-decoration: none;
  transition: color .14s var(--ease-default);
}
.ev-title a:hover {
  color: var(--color-indigo-700);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.ev-note {
  margin-top: 5px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--color-slate-500);
  max-width: 62ch;
}

/* Launch metadata row + market source link */
.ev-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-top: 12px;
}
.ev-provider {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 3px 8px 3px 5px;
  border-radius: var(--radius-pill);
  font-size: 12.5px;
  font-weight: 600;
  color: var(--color-slate-600);
  text-decoration: none;
  transition: background .14s var(--ease-default), color .14s var(--ease-default);
}
.ev-provider:hover { background: var(--color-slate-100); color: var(--color-slate-900); }
.ev-tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: var(--radius-pill);
  background: var(--color-slate-100);
  font-size: 12px;
  font-weight: 600;
  color: var(--color-slate-600);
}
.ev-tag .tp-io { font-size: 12px; }
.ev-source {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-top: 11px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--color-indigo-600);
  text-decoration: none;
}
.ev-source:hover { color: var(--color-indigo-700); text-decoration: underline; text-underline-offset: 2px; }

/* Hidden by the filter (kept out of layout + a11y tree). */
.ev-item[hidden], .ev-year-group[hidden] { display: none; }
.ev-empty { padding: 8px 0 20px; }
</style>
