<%# Live-data widget: "output costs N× input — today's spread across models".
    Server-rendered from PriceCatalog so the education layer is always current.
    locals: compact (default false), caption (optional), models (optional — an
    already-loaded catalog to reuse so the page loads it once). %>
<% compact = local_assigns.fetch(:compact, false) %>
<% models_local = local_assigns[:models] %>
<%# Cache the widget body on the latest catalog price update (+ the compact/caption
    variants, which change the markup) — it's pure live-price content, identical
    across every page that embeds it until a price moves. A model-set fingerprint
    (the passed-in local's slugs, nil for the default catalog) discriminates a
    caller that hands us a different set. The PriceCatalog.models fallback lives
    INSIDE the block so a cache hit skips that AiModel.listed.includes(...) load. %>
<% set_key = models_local&.map(&:slug) %>
<%# Reuse a caller-supplied freshness timestamp when given, so a page that
    already resolved PriceCatalog.last_modified doesn't issue a second query. %>
<% last_modified = local_assigns[:last_modified] || PriceCatalog.last_modified %>
<% cache [ :io_ratio_widget, last_modified, set_key, compact, local_assigns[:caption] ] do %>
<% models = models_local || PriceCatalog.models %>
<% priced = models.select { |m| m.status != "legacy" && m.input.to_f.positive? && m.output } %>
<% if priced.any? %>
  <% ratios = priced.map { |m| m.output / m.input }.sort %>
  <% median = ratios[ratios.size / 2] %>
  <% lo, hi = ratios.minmax %>
  <%# one representative (cheapest by input+output) model per provider, capped at 6 %>
  <% rows = priced.group_by(&:provider_slug).map { |_, ms| ms.min_by { |m| m.input + m.output } }
                  .sort_by { |m| m.input + m.output }.first(6) %>
  <% max_out = rows.map(&:output).max %>
  <div class="lw<%= ' is-compact' if compact %>">
    <div class="lw-head">
      <span class="lw-live"><%= co_icon(:live, size: 12) %>Live · prices today</span>
      <h4>Output costs <span class="lw-stat"><%= median.round(1) %>×</span> input, on average</h4>
      <p>Output costs more than input across every provider. Across <%= priced.size %> models the multiple ranges from <strong><%= lo.round(1) %>×</strong> to <strong><%= hi.round(1) %>×</strong>.</p>
    </div>
    <div class="lw-bars">
      <% rows.each do |m| %>
        <% iw = [ 2.5, m.input / max_out * 100 ].max %>
        <% ow = [ 2.5, m.output / max_out * 100 ].max %>
        <%= link_to model_path(m.slug), class: "lw-bar" do %>
          <span class="lw-bar-id">
            <%= provider_square(m.provider) %>
            <span class="lw-bar-nm"><%= m.name %><span class="lw-bar-px"><%= usd_plain(m.input) %> in · <%= usd_plain(m.output) %> out</span></span>
          </span>
          <span class="lw-bar-track">
            <span class="lw-seg in" style="width:<%= iw %>%"></span>
            <span class="lw-seg out" style="width:<%= ow %>%"></span>
          </span>
          <span class="lw-bar-x"><%= (m.output / m.input).round(1) %>×</span>
        <% end %>
      <% end %>
    </div>
    <div class="lw-foot">
      <span class="lw-key"><span class="dot in"></span>input / 1M</span>
      <span class="lw-key"><span class="dot out"></span>output / 1M</span>
      <span class="lw-note">per 1M tokens · tap a row for its history</span>
    </div>
  </div>
  <% if local_assigns[:caption] %><p class="lw-cap"><%= caption %></p><% end %>
<% end %>
<% end %>
