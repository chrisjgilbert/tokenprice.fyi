<%# A filter facet: a dropdown-popover button at every viewport width. The
    button opens a native popover panel (positioned by popover_controller)
    carrying the controls, an optional header (e.g. provider's select-all row),
    and an optional folded-in legend.

    locals: name, label, panel_id, icon (optional, defaults to the facet name),
            count_badge (optional — renders an empty numeric badge slot instead
            of the single-value chip text; for the multi-select provider facet),
            close_on_change (optional, defaults true — a single-select facet
            closes its popover the instant a choice is made; a multi-select
            facet like provider must stay open so further boxes stay reachable),
            legend_button, legend_entries (optional together — folds a legend
            into the panel; omit for a facet with no legend, e.g. provider).
    Yields the control inputs (the pills/checkboxes). %>
<div class="tp-filter-group tp-facet">
  <button type="button" class="tp-facet-chip" popovertarget="<%= panel_id %>"
          aria-label="Filter by <%= name %>" aria-haspopup="listbox" aria-expanded="false">
    <%= icon(local_assigns.fetch(:icon, name.to_sym), size: 16) %>
    <span class="tp-facet-chip-label"><%= label %></span>
    <% if local_assigns[:count_badge] %>
      <span class="tp-facet-chip-count" data-facet-chip-count="<%= name %>" hidden></span>
    <% else %>
      <span class="tp-facet-chip-val" data-facet-chip="<%= name %>"></span>
    <% end %>
    <span class="tp-facet-caret"><%= icon(:chevron_down, size: 14) %></span>
  </button>

  <% close_on_change = local_assigns.fetch(:close_on_change, true) %>
  <div id="<%= panel_id %>" class="tp-facet-panel" popover
       data-controller="popover"
       data-action="toggle->popover#position<%= ' change->popover#close' if close_on_change %>">
    <p class="tp-facet-panel-title"><%= label %></p>
    <%= yield %>
    <% if local_assigns[:legend_entries] %>
      <div class="tp-facet-legend">
        <%= render "facet_legend_list", title: legend_button, entries: legend_entries %>
      </div>
    <% end %>
  </div>
</div>
