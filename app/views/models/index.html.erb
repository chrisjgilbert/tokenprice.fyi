<% content_for :title, "LLM API price tracker — tokenprice.fyi" %>
<%# Own the head term and name the providers, rather than inheriting the layout default. ~155 chars. %>
<% content_for :description, "Compare LLM API token prices for Claude, GPT-5, Gemini, Grok, and DeepSeek. Input, output, and cached rates per 1M tokens, updated daily." %>
<%# Canonicalise away the tier/sort/dir permutations so they don't read as duplicates. %>
<% content_for :canonical, root_url %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "LLM API pricing",
        itemListElement: @models.each_with_index.map { |m, i|
          { "@type": "ListItem", position: i + 1, name: m.name, url: model_url(m) }
        }
      }) %>
<% end %>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 40px;
    align-items: start;
    margin-bottom: 64px;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
  }

  /* Eyebrow pill */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--color-indigo-50);
    border: 1px solid var(--color-indigo-100);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-indigo-700);
    letter-spacing: .04em;
    margin-bottom: 20px;
  }
  .hero-eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-indigo-500);
    box-shadow: 0 0 0 3px var(--color-indigo-200);
    animation: tp-pulse 2.4s var(--ease-default) infinite;
    flex: none;
  }

  /* Hero headline */
  .hero-h1 {
    font-size: clamp(32px, 4vw, 46px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    color: var(--color-slate-900);
    margin-bottom: 18px;
  }
  .hero-h1 .accent { color: var(--color-indigo-600); }

  .hero-sub {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-slate-500);
    max-width: 500px;
    margin-bottom: 36px;
  }

  /* Hero stats row */
  .hero-stats {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .hero-stat-val {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-slate-900);
    display: block;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 12px;
    color: var(--color-slate-400);
    font-weight: 500;
    margin-top: 5px;
    display: block;
    letter-spacing: .01em;
  }

  /* Hero CTAs: task guide + how pricing works */
  .hero-cta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 28px; }

  /* Latest update card */
  .hero-card {
    border-radius: var(--radius-xl);
    background: linear-gradient(160deg, #14163a, #1e2150 55%, #2a2f6e);
    border: 1px solid rgba(99,102,241,.22);
    box-shadow: 0 24px 64px -16px rgba(79,70,229,.38), 0 4px 16px rgba(0,0,0,.28);
    position: relative;
    overflow: hidden;
    padding: 28px;
  }
  /* Radial indigo glow */
  .hero-card::before {
    content: "";
    position: absolute;
    top: -40px;
    right: -40px;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(99,102,241,.28) 0%, transparent 70%);
    pointer-events: none;
  }
  /* Faint grid overlay */
  .hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    border-radius: inherit;
  }
  .hero-card-inner { position: relative; z-index: 1; }

  .hero-card-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: .1em;
    color: rgba(165,180,252,.9);
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .hero-card-tag svg { width: 13px; height: 13px; }

  .hero-card-headline { margin-bottom: 18px; }
  .hero-card-title {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 8px;
  }
  .hero-card-title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast, .15s) var(--ease-default);
  }
  .hero-card-title a:hover {
    color: var(--color-indigo-300, #a5b4fc);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-card-kind-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .01em;
    margin-bottom: 8px;
  }
  .hero-card-kind-chip.launch {
    background: rgba(16,185,129,.15);
    color: #6ee7b7;
    border: 1px solid rgba(16,185,129,.25);
  }
  .hero-card-kind-chip.market {
    background: rgba(244,63,94,.12);
    color: #fda4af;
    border: 1px solid rgba(244,63,94,.22);
  }
  .hero-card-kind-chip.reprice {
    background: rgba(99,102,241,.15);
    color: #c7d2fe;
    border: 1px solid rgba(99,102,241,.28);
  }

  .hero-card-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(148,163,184,.8);
    margin-bottom: 8px;
  }
  .hero-card-note {
    font-size: 13.5px;
    color: rgba(203,213,225,.85);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .hero-card-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 10px;
  }
  .hero-card-chip {
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    color: rgba(203,213,225,.9);
  }

  /* Filters card */
  .filters-card {
    background: #fff;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    margin-bottom: 16px;
    overflow: hidden;
  }
  .filters-top {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    flex-wrap: wrap;
  }
  .filters-divider {
    height: 1px;
    background: var(--color-slate-100);
    border: none;
    margin: 0;
  }
  .filters-bottom {
    padding: 14px 20px;
  }

  /* Result bar */
  .result-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .result-count {
    font-size: 13px;
    color: var(--color-slate-500);
    font-weight: 500;
  }

  /* ── Announcement banner ───────────────────────────── */
  .tp-banner {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 18px;
    margin-bottom: 32px;
    border-radius: var(--radius-lg);
    background: linear-gradient(120deg, #14163a, #2a2f6e);
    border: 1px solid rgba(99,102,241,.3);
    box-shadow: 0 8px 24px -12px rgba(79,70,229,.4);
    color: #fff;
    text-decoration: none;
    transition: transform .15s var(--ease-default), box-shadow .15s var(--ease-default);
  }
  .tp-banner:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 32px -12px rgba(79,70,229,.5);
  }
  .tp-banner-pill {
    flex: none;
    padding: 3px 10px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    background: rgba(165,180,252,.18);
    color: #c7d2fe;
    border: 1px solid rgba(165,180,252,.3);
  }
  .tp-banner-text {
    flex: 1;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    color: rgba(226,232,240,.95);
    min-width: 0;
  }
  .tp-banner-arrow {
    flex: none;
    font-size: 15px;
    color: #c7d2fe;
    transition: transform .15s var(--ease-default);
  }
  .tp-banner:hover .tp-banner-arrow { transform: translateX(3px); }
</style>

<%# ── ANNOUNCEMENT BANNER ────────────────────────────────────────── %>
<%= link_to "https://www.anthropic.com/news/fable-mythos-access",
      class: "tp-banner", target: "_blank", rel: "noopener" do %>
  <span class="tp-banner-pill">Update</span>
  <span class="tp-banner-text">Anthropic suspends Fable 5 access</span>
  <span class="tp-banner-arrow">→</span>
<% end %>

<%# ── HERO (outside Turbo Frame) ─────────────────────────────────── %>
<% if @all_events %>
  <%
    recent_events = hero_events(@all_events)
    primary_event = recent_events[0]
    secondary_event = recent_events[1]
  %>

  <div class="hero-grid">
    <%# Left column: the price-index hero %>
    <div>
      <div class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        Live LLM API price index
      </div>

      <h1 class="hero-h1">
        LLM API pricing, tracked from launch.
      </h1>

      <p class="hero-sub">
        <span class="num"><%= @all_models_count %></span> models across
        <span class="num"><%= @providers_count %></span> providers — input, output, and cached rates
        per 1M tokens, updated daily, with full price history.
      </p>

      <div class="hero-cta">
        <%= link_to guide_path, class: "tp-btn tp-btn-primary" do %>Find a model for your task<% end %>
        <%= link_to how_pricing_works_path, class: "tp-btn tp-btn-ghost" do %>How pricing works<% end %>
      </div>
    </div>

    <%# Right column: latest update card %>
    <div class="hero-card">
      <div class="hero-card-inner">
        <div class="hero-card-tag">
          <%= icon(:spark, size: 13) %>
          Latest changes
        </div>

        <% if primary_event %>
          <div class="hero-card-headline">
            <div>
              <span class="hero-card-kind-chip <%= primary_event.kind %>">
                <%= hero_kind_chip_label(primary_event.kind) %>
              </span>
            </div>
            <div class="hero-card-title">
              <% if primary_event.model %>
                <%= link_to primary_event.title, model_path(primary_event.model) %>
              <% elsif primary_event.source_url.present? %>
                <%= link_to primary_event.title, primary_event.source_url, target: "_blank", rel: "noopener" %>
              <% else %>
                <%= primary_event.title %>
              <% end %>
            </div>
            <div class="hero-card-date"><%= fmt_date_full(primary_event.date) %></div>
            <% if primary_event.note.present? %>
              <div class="hero-card-note"><%= primary_event.note %></div>
            <% end %>
            <% if primary_event.kind == "launch" && (m = primary_event.model) %>
              <div class="hero-card-chips">
                <%= tier_badge(m.tier) %>
                <span class="hero-card-chip tp-io-light"><%= io_price(m, light: true) %></span>
                <% if m.context_window %>
                  <span class="hero-card-chip num"><%= tokens_short(m.context_window) %> ctx</span>
                <% end %>
              </div>
            <% elsif primary_event.kind == "reprice" && (mv = primary_event.move) %>
              <div class="hero-card-chips">
                <%= price_change_badge(mv.input) %>
                <%= price_change_badge(mv.output) %>
                <% if mv.input %>
                  <span class="hero-card-chip num"><%= usd_plain(mv.from.input_per_mtok) %> → <%= usd_plain(mv.to.input_per_mtok) %> in</span>
                <% end %>
                <% if mv.output %>
                  <span class="hero-card-chip num"><%= usd_plain(mv.from.output_per_mtok) %> → <%= usd_plain(mv.to.output_per_mtok) %> out</span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if secondary_event %>
          <div style="margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.08);display:flex;align-items:baseline;gap:8px;flex-wrap:wrap">
            <span class="hero-card-kind-chip <%= secondary_event.kind %>" style="font-size:10px;padding:2px 7px">
              <%= hero_kind_chip_label(secondary_event.kind) %>
            </span>
            <span style="font-size:13px;font-weight:500;color:#e8eaf0;flex:1;min-width:0">
              <% if secondary_event.model %>
                <%= link_to secondary_event.title, model_path(secondary_event.model), style: "color:inherit;text-decoration:none" %>
              <% elsif secondary_event.source_url.present? %>
                <%= link_to secondary_event.title, secondary_event.source_url, target: "_blank", rel: "noopener", style: "color:inherit;text-decoration:none" %>
              <% else %>
                <%= secondary_event.title %>
              <% end %>
            </span>
            <span style="font-size:11px;color:rgba(200,205,220,.5);white-space:nowrap"><%= fmt_date_full(secondary_event.date) %></span>
          </div>
        <% end %>

        <div style="margin-top:16px">
          <% if primary_event&.model %>
            <%= link_to model_path(primary_event.model), class: "tp-btn tp-btn-ghost tp-btn-sm", style: "color:#fff;background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.14);width:100%;justify-content:center" do %>
              Full price history →
            <% end %>
          <% elsif primary_event&.source_url.present? %>
            <%= link_to primary_event.source_url, class: "tp-btn tp-btn-ghost tp-btn-sm", target: "_blank", rel: "noopener", style: "color:#fff;background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.14);width:100%;justify-content:center" do %>
              Read more →
            <% end %>
          <% else %>
            <%= link_to events_path, class: "tp-btn tp-btn-ghost tp-btn-sm", style: "color:#fff;background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.14);width:100%;justify-content:center" do %>
              All changes →
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# ── FILTERS (outside Turbo Frame) ──────────────────────────────── %>
<p class="tp-section-label mb-4">Price table</p>

<% sort_params = { sort: (@sort unless @sort == ModelsController::DEFAULT_SORT),
                   dir:  (@dir  unless @dir  == ModelsController::DEFAULT_DIR) }.compact %>

<%= form_with url: root_path, method: :get, id: "filters", role: "search", "aria-label": "Filter models",
      data: { controller: "filters",
              action: "submit->filters#clearPending formdata->filters#clean turbo:frame-load@document->filters#announce",
              turbo_frame: "models", turbo_action: "replace" } do %>
  <p class="sr-only" role="status" data-filters-target="status"></p>

  <div class="filters-card">
    <div class="filters-top">
      <%# Search %>
      <div class="tp-search">
        <%= icon(:search, size: 18) %>
        <label for="q" class="sr-only">Search models or providers</label>
        <%= search_field_tag :q, @query, placeholder: "anthropic, openai, gpt-4o, …", autocomplete: "off",
              data: { action: "input->filters#search" } %>
      </div>

      <%# Tier radio pills. Active state is driven by the checked radio in CSS
          (.tp-pill:has(input:checked)), not a render-time class — the pills sit
          outside the Turbo frame the form replaces, so a class wouldn't refresh. %>
      <div class="tp-filter-group">
        <div class="tp-pills" role="group" aria-label="Filter by tier">
          <% tier_pill_options.each do |label, value| %>
            <%= filter_pill :tier, value, label, checked: @tier == value.presence %>
          <% end %>
        </div>
        <%= render "filter_legend", id: "tier-legend", title: "Tiers",
              button_label: "What the tiers mean", entries: tier_legend_entries %>
      </div>

      <%# Modality radio pills — only the classes present among listed models. %>
      <% if @modality_classes.size > 1 %>
        <div class="tp-filter-group">
          <div class="tp-pills" role="group" aria-label="Filter by modality">
            <%= filter_pill :modality, "", "All", checked: @modality.nil? %>
            <% @modality_classes.each do |klass| %>
              <%= filter_pill :modality, klass, ModalityClass.label(klass), checked: @modality == klass %>
            <% end %>
          </div>
          <%= render "filter_legend", id: "modality-legend", title: "Modality categories",
                button_label: "What the modality categories mean",
                entries: ModalityClass.legend_entries(@modality_classes) %>
        </div>
      <% end %>
    </div>

    <hr class="filters-divider">

    <%# Provider checkboxes %>
    <div class="filters-bottom">
      <fieldset>
        <legend class="sr-only">Filter by provider</legend>
        <details class="tp-provider-details" <%= 'open' if @provider_slugs.any? %>>
          <summary class="tp-provider-summary">
            <span class="tp-provider-summary-text">
              <% if @provider_slugs.any? %>
                <%= pluralize(@provider_slugs.size, "provider") %> selected
              <% else %>
                All <%= @providers.size %> providers
              <% end %>
            </span>
            <span class="tp-provider-caret"><%= icon(:chevron_down, size: 14) %></span>
          </summary>
          <div class="tp-check-row" style="margin-top: 12px">
            <% @providers.each do |provider| %>
              <% checked = @provider_slugs.empty? || @provider_slugs.include?(provider.slug) %>
              <label class="tp-check">
                <input type="checkbox" name="providers[]" value="<%= provider.slug %>"
                       id="provider_<%= provider.slug %>"
                       <% if checked %>checked<% end %>
                       data-action="change->filters#submit">
                <%= provider_square(provider, size: :sm) %>
                <span class="tp-check-box">
                  <%= icon(:check, size: 12) %>
                </span>
                <%= provider.name %>
              </label>
            <% end %>
          </div>
        </details>
      </fieldset>
    </div>
  </div>

  <noscript>
    <%= submit_tag "Apply filters", name: nil,
          class: "tp-btn tp-btn-primary tp-btn-sm mb-4" %>
  </noscript>
<% end %>

<%# ── TABLE (Turbo Frame — refreshed on filter changes) ───────────── %>
<% filter_params = { tier: @tier, modality: @modality, q: @query.presence, providers: @provider_slugs.presence }.compact %>

<%# target="_top": links in here (model/provider rows, clear-filters) are real
    page navigations — only the sort links opt back into the frame. %>
<%= turbo_frame_tag "models", target: "_top" do %>
  <%# Default sort travels implicitly, keeping filter-submit URLs clean. %>
  <%= hidden_field_tag :sort, @sort, form: "filters", id: nil if sort_params.key?(:sort) %>
  <%= hidden_field_tag :dir, @dir, form: "filters", id: nil if sort_params.key?(:dir) %>

  <div class="result-bar">
    <p class="result-count" data-models-count><%= pluralize(@models.size, "model") %> of <%= AiModel.listed.count %></p>
    <% if filter_params.any? %>
      <%= link_to "Clear filters", root_path(sort_params), class: "text-sm font-medium text-indigo-600 hover:underline" %>
    <% end %>
  </div>

  <div class="tp-table-wrap">
    <div class="tp-table-scroll">
      <table class="tp-data">
        <thead>
          <% th_cls = ->(key) {
               cls = "sortable"
               cls += " sort-active" if @sort == key
               cls += " desc" if @sort == key && @dir == "desc"
               cls
             } %>
          <tr>
            <th scope="col" class="<%= th_cls.('name') %>" aria-sort="<%= aria_sort_for('name', current_sort: @sort, current_dir: @dir) %>">
              <%= sort_link "Model", "name", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
            <th scope="col" class="<%= th_cls.('tier') %>" aria-sort="<%= aria_sort_for('tier', current_sort: @sort, current_dir: @dir) %>">
              <%= sort_link "Tier", "tier", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
            <th scope="col" class="numeric <%= th_cls.('input') %>" aria-sort="<%= aria_sort_for('input', current_sort: @sort, current_dir: @dir) %>">
              <%= sort_link "Input /1M", "input", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
            <th scope="col" class="numeric <%= th_cls.('output') %>" aria-sort="<%= aria_sort_for('output', current_sort: @sort, current_dir: @dir) %>">
              <%= sort_link "Output /1M", "output", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
            <th scope="col" class="numeric <%= th_cls.('cached') %>" aria-sort="<%= aria_sort_for('cached', current_sort: @sort, current_dir: @dir) %>">
              <%= sort_link "Cached in /1M", "cached", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
            <th scope="col" class="numeric <%= th_cls.('context') %>" aria-sort="<%= aria_sort_for('context', current_sort: @sort, current_dir: @dir) %>">
              <%= sort_link "Context", "context", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
            <th scope="col" class="numeric <%= th_cls.('change') %>" aria-sort="<%= aria_sort_for('change', current_sort: @sort, current_dir: @dir) %>" title="Change in input price from launch to now">
              <%= sort_link "Δ input", "change", current_sort: @sort, current_dir: @dir, filters: filter_params %>
            </th>
          </tr>
        </thead>
        <tbody>
          <% if @models.empty? %>
            <tr>
              <td colspan="7">
                <div class="tp-empty">
                  <div class="tp-empty-icon">
                    <%= icon(:empty, size: 26) %>
                  </div>
                  <p class="text-base font-semibold text-slate-700 mb-2">No models match your filters</p>
                  <%= link_to "Clear all filters", root_path(sort_params), class: "text-sm font-medium text-indigo-600 hover:underline" %>
                </div>
              </td>
            </tr>
          <% else %>
            <% @models.each do |model| %>
              <%# Highlight the sorted column %>
              <% sort_col = @sort %>
              <%# Russian-doll cache: the row content is keyed on the model and its
                  latest price point, plus the active sort — the sorted column gets
                  a `tp-col-highlight` class, so a sort-blind key would serve a row
                  highlighting the wrong column. Key on the price point's updated_at
                  (not effective_on) so a same-day in-place correction busts the row. %>
              <% cache [ model, model.current_price&.updated_at, sort_col ] do %>
              <tr class="clickable <%= 'tp-row-suspended' if model.suspended? %>" onclick="location.href='<%= j(model_path(model)) %>'">
                <td class="<%= sort_col == 'name' ? 'tp-col-highlight' : '' %>">
                  <div class="tp-model-cell">
                    <%= link_to model_path(model) do %>
                      <%= provider_square(model.provider, size: :md) %>
                    <% end %>
                    <div class="tp-model-meta">
                      <div class="tp-model-name">
                        <%= link_to model.name, model_path(model), style: "color:inherit;text-decoration:none" %>
                      </div>
                      <div class="tp-model-sub">
                        <%= link_to model.provider.name, provider_path(model.provider),
                              class: "tp-prov-name hover:underline" %>
                        <%= status_badge(model.status) %>
                        <%= modality_badge(model) %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="<%= sort_col == 'tier' ? 'tp-col-highlight' : '' %>">
                  <%= tier_badge(model.tier) %>
                </td>
                <% if ModalityClass.directory_class?(model.modality_class) %>
                  <%# A directory-class row bills in a native unit, not per token:
                      its native price ("$0.04 / image") when recorded, the honest
                      "not yet tracked" note when not — one cell spanning the three
                      per-token columns, rather than three dashes that read as free. %>
                  <td class="numeric <%= 'tp-col-highlight' if %w[input output cached].include?(sort_col) %>" colspan="3">
                    <span class="<%= 'tp-price-untracked' if directory_row?(model) %>"><%= native_price_display(model) %></span>
                  </td>
                <% else %>
                  <td class="numeric <%= sort_col == 'input' ? 'tp-col-highlight' : '' %>">
                    <%= usd(model.current_input) %>
                  </td>
                  <td class="numeric <%= sort_col == 'output' ? 'tp-col-highlight' : '' %>">
                    <%= usd(model.current_output) %>
                  </td>
                  <td class="numeric <%= sort_col == 'cached' ? 'tp-col-highlight' : '' %>">
                    <%= usd(model.current_cached_input) %>
                  </td>
                <% end %>
                <td class="numeric <%= sort_col == 'context' ? 'tp-col-highlight' : '' %>">
                  <%= tokens_short(model.context_window) %>
                </td>
                <td class="numeric <%= sort_col == 'change' ? 'tp-col-highlight' : '' %>">
                  <% if model.input_change_since_launch %>
                    <%= price_change_badge(model.input_change_since_launch) %>
                  <% else %>
                    <span class="tp-muted-dash">—</span>
                  <% end %>
                </td>
              </tr>
              <% end %>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<p class="mt-4 text-xs text-slate-400">
  Sorted by output price by default — output tokens are typically 3–5× more expensive than input and dominate the bill for generation-heavy workloads. Sort by input or cached input when your mix differs.
</p>
