<%# Title, description, and canonical are per pricing-category (set on the
    controller from ModelCategory) — each tab is its own indexable URL, and the
    canonical still folds away the sort/dir permutations within a tab. %>
<% content_for :title, @page_title %>
<% content_for :description, @page_description %>
<% content_for :canonical, @canonical_url %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: @category.label,
        itemListElement: @models.each_with_index.map { |m, i|
          { "@type": "ListItem", position: i + 1, name: m.name, url: model_url(m) }
        }
      }) %>
<% end %>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 40px;
    align-items: start;
    margin-bottom: 64px;
    position: relative;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
  }

  /* Ambient depth: a slow-drifting glow plus a few of this tab's own numbers
     (already stated in the subhead) floating at low opacity in the gap
     between the columns — texture, not a new claim, tuned to stay clear of
     both the headline text and the card. */
  .hero-grid::before {
    content: "";
    position: absolute;
    top: -80px;
    right: 6%;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,.14) 0%, rgba(99,102,241,0) 70%);
    pointer-events: none;
    z-index: 0;
    animation: hero-glow-drift 16s ease-in-out infinite alternate;
  }
  @keyframes hero-glow-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-20px, 16px) scale(1.06); }
  }

  .hero-float-chip {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 600;
    padding: 5px 11px;
    border-radius: 999px;
    color: var(--color-indigo-600);
    background: rgba(99,102,241,.08);
    border: 1px solid rgba(99,102,241,.16);
    animation: hero-chip-float 7s ease-in-out infinite;
  }
  @keyframes hero-chip-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-9px); }
  }
  /* Both chips report short, digit-bounded counts (unlike the category's
     billing_noun, whose length swings from "per 1M tokens" to "per search
     or per 1M tokens" across tabs — too variable to place safely, so it's
     not used here). The gap between the columns is too narrow, at any
     width, to clear both the card AND the headline/subhead lines the left
     column can wrap to — so both chips sit low, below where even the
     longest tab's left-column content (language's 3-line subhead) ends,
     leaving only the card's left edge to stay clear of. Verified at
     >=1200px, hence the raised breakpoint below (wider than the grid's own
     900px column-collapse point). */
  .hero-float-chip.c1 { top: 62%; left: 51%; animation-delay: 0s;   opacity: .8; }
  .hero-float-chip.c2 { top: 80%; left: 47%; animation-delay: 1.4s; opacity: .5; }
  @media (max-width: 1200px) {
    .hero-grid::before,
    .hero-float-chip { display: none; }
  }

  /* Eyebrow pill */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--color-indigo-50);
    border: 1px solid var(--color-indigo-100);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-indigo-700);
    letter-spacing: .04em;
    margin-bottom: 20px;
  }
  .hero-eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-indigo-500);
    box-shadow: 0 0 0 3px var(--color-indigo-200);
    animation: tp-pulse 2.4s var(--ease-default) infinite;
    flex: none;
  }

  /* Hero headline */
  .hero-h1 {
    font-size: clamp(32px, 4vw, 46px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    color: var(--color-slate-900);
    margin-bottom: 18px;
  }
  .hero-h1 .accent { color: var(--color-indigo-600); }

  .hero-sub {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-slate-500);
    max-width: 500px;
    margin-bottom: 36px;
  }

  /* Hero stats row */
  .hero-stats {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .hero-stat-val {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-slate-900);
    display: block;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 12px;
    color: var(--color-slate-400);
    font-weight: 500;
    margin-top: 5px;
    display: block;
    letter-spacing: .01em;
  }

  /* Hero CTA: how pricing works */
  .hero-cta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 28px; }

  /* Sheen sweep on the primary CTA's hover, scoped to the hero only — this
     is not a global button restyle. */
  .hero-cta .tp-btn-primary { position: relative; overflow: hidden; }
  .hero-cta .tp-btn-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 20%, rgba(255,255,255,.35) 42%, transparent 64%);
    transform: translateX(-120%);
    transition: transform .6s var(--ease-out);
  }
  .hero-cta .tp-btn-primary:hover::before { transform: translateX(120%); }

  /* Latest update card */
  .hero-card {
    border-radius: var(--radius-xl);
    background: linear-gradient(160deg, #14163a, #1e2150 55%, #2a2f6e);
    background-size: 220% 220%;
    border: 1px solid rgba(99,102,241,.22);
    box-shadow: 0 24px 64px -16px rgba(79,70,229,.38), 0 4px 16px rgba(0,0,0,.28);
    position: relative;
    overflow: hidden;
    padding: 28px;
    animation: hero-card-breathe 16s ease infinite;
  }
  @keyframes hero-card-breathe {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  /* Radial indigo glow */
  .hero-card::before {
    content: "";
    position: absolute;
    top: -40px;
    right: -40px;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(99,102,241,.28) 0%, transparent 70%);
    pointer-events: none;
  }
  /* Faint grid overlay */
  .hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    border-radius: inherit;
  }
  .hero-card-inner { position: relative; z-index: 1; }

  .hero-card-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: .1em;
    color: rgba(165,180,252,.9);
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .hero-card-tag svg { width: 13px; height: 13px; }
  .hero-card-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    flex: none;
    box-shadow: 0 0 0 0 rgba(52,211,153,.55);
    animation: hero-live-pulse 1.8s ease-out infinite;
  }
  @keyframes hero-live-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(52,211,153,.55); }
    70%  { box-shadow: 0 0 0 8px rgba(52,211,153,0); }
    100% { box-shadow: 0 0 0 0 rgba(52,211,153,0); }
  }

  .hero-card-headline { margin-bottom: 18px; }
  .hero-card-title {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 8px;
  }
  .hero-card-title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast, .15s) var(--ease-default);
  }
  .hero-card-title a:hover {
    color: var(--color-indigo-300, #a5b4fc);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-card-kind-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: .01em;
    margin-bottom: 8px;
  }
  .hero-card-kind-chip.launch {
    background: rgba(16,185,129,.15);
    color: #6ee7b7;
    border: 1px solid rgba(16,185,129,.25);
  }
  .hero-card-kind-chip.market {
    background: rgba(244,63,94,.12);
    color: #fda4af;
    border: 1px solid rgba(244,63,94,.22);
  }

  .hero-card-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(148,163,184,.8);
    margin-bottom: 8px;
  }
  .hero-card-desc {
    font-size: 13.5px;
    color: rgba(226,232,240,.9);
    line-height: 1.5;
    margin-bottom: 10px;
  }
  .hero-card-note {
    font-size: 13.5px;
    color: rgba(203,213,225,.85);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .hero-card-sowhat {
    font-size: 13px;
    color: rgba(226,232,240,.92);
    line-height: 1.5;
    padding-left: 10px;
    border-left: 2px solid rgba(244,63,94,.7);
    margin-bottom: 12px;
  }
  .hero-card-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 10px;
  }
  .hero-card-chip {
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    color: rgba(203,213,225,.9);
  }

  /* Mini-timeline rows below the headline event — one per additional recent
     event, so several launches/market events can show at once instead of the
     hero having to pick a single "runner-up". */
  .hero-card-timeline-row {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Filters card: one row at every width — search box, then the
     provider / modality dropdown buttons. The card's overflow is open (not
     hidden) so a facet's popover panel isn't clipped by the card bounds. */
  .filters-card {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    margin-bottom: 16px;
    padding: 16px;
    overflow: visible;
  }
  .filters-card fieldset { display: contents; }

  @media (max-width: 760px) {
    .tp-search { flex-basis: 100%; min-width: 0; }
  }

  /* Result bar */
  .result-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .result-count {
    font-size: 13px;
    color: var(--color-slate-500);
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-grid::before,
    .hero-float-chip,
    .hero-card,
    .hero-card-live-dot,
    .hero-cta .tp-btn-primary::before {
      animation: none;
      transition: none;
    }
  }

</style>

<%# ── HERO (outside Turbo Frame) ─────────────────────────────────── %>
<% if @all_events %>
  <%
    recent_events = hero_events(@all_events)
    primary_event = recent_events[0]
    # Array#[1..] returns nil (not []) when the receiver itself is empty —
    # reachable if @all_events has zero events — so this guard is load-bearing,
    # not defensive dead code.
    rest_events = recent_events[1..] || []
  %>

  <div class="hero-grid">
    <%# Ambient chips: this tab's own counts, already stated in the subhead
        below — just reused as floating texture, not new claims. Both are
        short, digit-bounded strings by construction (unlike billing_noun,
        which swings too wide across tabs to place safely — see the CSS
        note on .hero-float-chip). Hidden below 1150px alongside the glow. %>
    <span class="hero-float-chip c1"><%= @category_counts[@category.slug] %> models</span>
    <span class="hero-float-chip c2"><%= @providers_count %> providers</span>

    <%# Left column: the price-index hero. Copy is per-category (ModelCategory),
        so a directory tab never claims per-token rates or full history. The
        subhead is a format string filled with this category's own model count
        (not the whole catalog) and the provider count. %>
    <div>
      <div class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        <%= @category.hero_eyebrow %>
      </div>

      <h1 class="hero-h1">
        <%= @category.hero_heading %>
      </h1>

      <p class="hero-sub">
        <%# Subhead is a trusted registry constant; the only interpolations are
            integer counts wrapped in a .num span. sanitize with a span allowlist
            makes that safety explicit rather than blanket-trusting with raw. %>
        <%= sanitize(@category.hero_subhead % {
              models: tag.span(@category_counts[@category.slug], class: "num"),
              providers: tag.span(@providers_count, class: "num")
            }, tags: %w[span], attributes: %w[class]) %>
      </p>

      <div class="hero-cta">
        <% if @category.language? %>
          <%= link_to how_pricing_works_path, class: "tp-btn tp-btn-primary" do %>How pricing works<% end %>
        <% else %>
          <%= link_to sources_path, class: "tp-btn tp-btn-primary" do %>How prices are sourced<% end %>
        <% end %>
        <%= link_to "#price-table", class: "tp-btn tp-btn-ghost", data: { controller: "smooth-scroll", action: "click->smooth-scroll#jump" } do %>View models<% end %>
      </div>
    </div>

    <%# Right column: latest update card %>
    <div class="hero-card">
      <div class="hero-card-inner">
        <div class="hero-card-tag">
          <span class="hero-card-live-dot"></span>
          <%= icon(:spark, size: 13) %>
          Latest events
        </div>

        <% launch_model = primary_event.model if primary_event&.kind == "launch" %>
        <% if primary_event %>
          <div class="hero-card-headline">
            <div>
              <span class="hero-card-kind-chip <%= primary_event.kind %>">
                <%= hero_kind_chip_label(primary_event.kind) %>
              </span>
            </div>
            <div class="hero-card-title">
              <% if primary_event.model %>
                <%= link_to primary_event.title, model_path(primary_event.model) %>
              <% else %>
                <%= primary_event.title %>
              <% end %>
            </div>
            <div class="hero-card-date"><%= fmt_date_full(primary_event.date) %></div>
            <% if launch_model&.description.present? %>
              <div class="hero-card-desc"><%= launch_model.description %></div>
            <% end %>
            <% if primary_event.so_what.present? %>
              <div class="hero-card-sowhat"><%= primary_event.so_what %></div>
            <% elsif primary_event.note.present? %>
              <div class="hero-card-note"><%= primary_event.note %></div>
            <% end %>
            <% if (m = launch_model) %>
              <div class="hero-card-chips">
                <span class="hero-card-chip tp-io-light"><%= io_price(m, light: true) %></span>
                <% if m.context_window %>
                  <span class="hero-card-chip num"><%= tokens_short(m.context_window) %> ctx</span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% rest_events.each do |event| %>
          <div class="hero-card-timeline-row">
            <span class="hero-card-kind-chip <%= event.kind %>" style="font-size:10px;padding:2px 7px">
              <%= hero_kind_chip_label(event.kind) %>
            </span>
            <span style="font-size:13px;font-weight:500;color:#e8eaf0;flex:1;min-width:0">
              <% if event.model %>
                <%= link_to event.title, model_path(event.model), style: "color:inherit;text-decoration:none" %>
              <% else %>
                <%= event.title %>
              <% end %>
            </span>
            <span style="font-size:11px;color:rgba(200,205,220,.5);white-space:nowrap"><%= fmt_date_full(event.date) %></span>
          </div>
        <% end %>

        <div style="margin-top:16px">
          <%= link_to events_path, class: "tp-btn tp-btn-ghost tp-btn-sm", style: "color:#fff;background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.14);width:100%;justify-content:center" do %>
            View timeline →
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# ── COMPARE TRAY WRAPPER ────────────────────────────────────────────
    Mounted outside turbo_frame_tag "models" deliberately: that frame
    re-renders on every filter/sort change, which would destroy and recreate
    a controller (and its selection state) mounted inside it. Spans the
    filters form, the table frame, the tray, and the compare dialog so
    selection survives filtering and the dialog can sit beside the tray. %>
<div data-controller="compare-tray" data-compare-tray-compare-path-value="<%= compare_path %>"
     data-action="turbo:frame-load@document->compare-tray#frameLoaded">

<%# ── FILTERS (outside Turbo Frame) ──────────────────────────────── %>
<p id="price-table" class="tp-section-label mb-4">Price table</p>

<%# Every filter/sort URL on this page must stay on the CURRENT category's path,
    so a sort inside the image tab reloads /image-generation, not /. The path
    helper prefix lives on the category (:root / :image_generation). %>
<% cat_path = ->(params = {}) { send("#{@category.path_name}_path", params) } %>

<%# The category tab strip — full-page navigation between pricing families, each
    its own indexable URL, so these are links rather than a client-side toggle. %>
<nav class="tp-tabs" aria-label="Pricing category"
     data-controller="tab-scroll" data-action="click->tab-scroll#save">
  <% ModelCategory.all.each do |category| %>
    <% current = category.slug == @category.slug %>
    <%= link_to send("#{category.path_name}_path"),
          class: "tp-tab#{' is-active' if current}",
          "aria-current": (current ? "page" : nil) do %>
      <span class="tp-tab-label"><%= category.label %></span>
      <span class="tp-tab-count"><%= @category_counts[category.slug] %></span>
    <% end %>
  <% end %>
</nav>

<%# Default sort/dir are the category's own, so a bare visit to a tab keeps the
    URL clean and the hidden sort fields stay off until the reader sorts. %>
<% sort_params = { sort: (@sort unless @sort == @category.default_sort),
                   dir:  (@dir  unless @dir  == @category.default_dir) }.compact %>

<%= form_with url: cat_path.call, method: :get, id: "filters", role: "search", "aria-label": "Filter models",
      data: { controller: "filters",
              action: "submit->filters#clearPending formdata->filters#clean turbo:frame-load@document->filters#announce",
              turbo_frame: "models", turbo_action: "replace" } do %>
  <p class="sr-only" role="status" data-filters-target="status"></p>

  <div class="filters-card">
    <%# Search %>
    <div class="tp-search">
      <%= icon(:search, size: 18) %>
      <label for="q" class="sr-only">Search models or providers</label>
      <%= search_field_tag :q, @query, placeholder: "anthropic, openai, gpt-4o, …", autocomplete: "off",
            data: { action: "input->filters#search" } %>
    </div>

    <%# Provider checkboxes. Field name is "providers[]" while the facet is named
        "provider", so it passes field: explicitly for the count/select-all wiring. %>
    <%= render layout: "facet", locals: {
          name: "provider", label: "Provider", panel_id: "provider-panel", icon: :server,
          field: "providers" } do %>
      <fieldset>
        <legend class="sr-only">Filter by provider</legend>
        <div class="tp-check-row">
          <% @providers.each do |provider| %>
            <% checked = @provider_slugs.empty? || @provider_slugs.include?(provider.slug) %>
            <%= filter_check "providers", provider.slug, checked: checked,
                  leading: provider_square(provider, size: :sm) do %>
              <%= provider.name %>
            <% end %>
          <% end %>
        </div>
      </fieldset>
    <% end %>

    <%# Modality checkboxes — only the classes present among listed models. %>
    <% if @modality_classes.size > 1 %>
      <%= render layout: "facet", locals: {
            name: "modality", label: "Modality", panel_id: "modality-panel", icon: :brackets,
            legend_button: "What the modality categories mean",
            legend_entries: ModalityClass.legend_entries(@modality_classes) } do %>
        <fieldset>
          <legend class="sr-only">Filter by modality</legend>
          <div class="tp-check-row">
            <% @modality_classes.each do |klass| %>
              <%= filter_check "modality", klass, checked: @modalities.empty? || @modalities.include?(klass) do %>
                <%= ModalityClass.label(klass) %>
              <% end %>
            <% end %>
          </div>
        </fieldset>
      <% end %>
    <% end %>
  </div>

  <noscript>
    <%= submit_tag "Apply filters", name: nil,
          class: "tp-btn tp-btn-primary tp-btn-sm mb-4" %>
  </noscript>
<% end %>

<%# ── COMPARE TOOLBAR (outside the Turbo Frame, so the mode toggle and its
    state survive filter/sort reloads) ───────────────────────────────
    Compare is opt-in: off by default so a row's only hover affordance is
    "click to open the model page". Turning it on reveals the per-row select
    checkboxes and switches a row click from navigate to select. %>
<div class="tp-table-toolbar">
  <button type="button" class="tp-btn tp-btn-ghost tp-btn-sm tp-compare-toggle"
          data-compare-tray-target="modeBtn"
          data-action="click->compare-tray#toggleMode"
          aria-pressed="false">
    <%= icon(:columns, size: 15) %>
    <span data-compare-tray-target="modeBtnLabel">Compare models</span>
  </button>
  <p class="tp-compare-hint">Pick two models to compare them side by side.</p>
</div>

<%# ── TABLE (Turbo Frame — refreshed on filter changes) ───────────── %>
<% filter_params = { modality: @modalities.presence, q: @query.presence, providers: @provider_slugs.presence }.compact %>

<%# target="_top": links in here (model/provider rows, clear-filters) are real
    page navigations — only the sort links opt back into the frame. %>
<%= turbo_frame_tag "models", target: "_top" do %>
  <%# Default sort travels implicitly, keeping filter-submit URLs clean. %>
  <%= hidden_field_tag :sort, @sort, form: "filters", id: nil if sort_params.key?(:sort) %>
  <%= hidden_field_tag :dir, @dir, form: "filters", id: nil if sort_params.key?(:dir) %>

  <div class="result-bar">
    <p class="result-count" data-models-count><%= pluralize(@models.size, "model") %> of <%= @category_counts[@category.slug] %></p>
    <% if filter_params.any? %>
      <%= link_to "Clear filters", cat_path.call(sort_params), class: "text-sm font-medium text-indigo-600 hover:underline" %>
    <% end %>
  </div>

  <%# The table shape is data: @category.columns lists the column keys left→right,
      COL_LABELS maps each to its header, NUMERIC_COLS marks the right-aligned
      number/price columns. A column is sortable iff its key is in the category's
      sorts (e.g. Pricing and Dimensions have no sort axis). %>
  <%
    numeric_cols = %i[input output cached context dimensions native_price]
    col_labels = {
      name: "Model",
      input: "Input /1M", output: "Output /1M", cached: "Cached in /1M",
      context: "Context", provider: "Provider", released: "Released",
      pricing: "Pricing", dimensions: "Dimensions", native_price: "Price"
    }
  %>

  <div class="tp-table-wrap tp-cardify-wrap">
    <div class="tp-table-scroll">
      <table class="tp-data tp-cardify">
        <thead>
          <% th_cls = ->(key) {
               cls = "sortable"
               cls += " sort-active" if @sort == key
               cls += " desc" if @sort == key && @dir == "desc"
               cls
             } %>
          <tr>
            <th scope="col" class="tp-col-select" aria-hidden="true" title="Select to compare"></th>
            <% @category.columns.each do |key| %>
              <% numeric = numeric_cols.include?(key) %>
              <% if @category.sorts.include?(key.to_s) %>
                <th scope="col" class="<%= 'numeric ' if numeric %><%= th_cls.(key.to_s) %>" aria-sort="<%= aria_sort_for(key.to_s, current_sort: @sort, current_dir: @dir) %>">
                  <%= sort_link col_labels[key], key.to_s, current_sort: @sort, current_dir: @dir, filters: filter_params, &cat_path %>
                </th>
              <% elsif numeric %>
                <th scope="col" class="numeric"><%= col_labels[key] %></th>
              <% else %>
                <th scope="col"><%= col_labels[key] %></th>
              <% end %>
            <% end %>
            <th scope="col" class="tp-col-go" aria-hidden="true"></th>
          </tr>
        </thead>
        <tbody>
          <% if @models.empty? %>
            <tr>
              <td colspan="<%= @category.table_colspan %>">
                <div class="tp-empty">
                  <div class="tp-empty-icon">
                    <%= icon(:empty, size: 26) %>
                  </div>
                  <p class="text-base font-semibold text-slate-700 mb-2">No models match your filters</p>
                  <%= link_to "Clear all filters", cat_path.call(sort_params), class: "text-sm font-medium text-indigo-600 hover:underline" %>
                </div>
              </td>
            </tr>
          <% else %>
            <% @models.each do |model| %>
              <%# Highlight the sorted column %>
              <% sort_col = @sort %>
              <%# Russian-doll cache: the row content is keyed on the model and its
                  latest price point, plus the active sort — the sorted column gets
                  a `tp-col-highlight` class, so a sort-blind key would serve a row
                  highlighting the wrong column. Key on the price point's updated_at
                  (not effective_on) so a same-day in-place correction busts the row. %>
              <%# @category.slug rides in the key so the language and image column
                  layouts (different cells for the same model) can't collide. %>
              <% cache [ model, model.current_price&.updated_at, sort_col, @category.slug ] do %>
              <tr class="clickable <%= 'tp-row-suspended' if model.suspended? %>"
                  data-model-path="<%= model_path(model) %>"
                  data-action="click->compare-tray#rowClick">
                <td class="tp-col-select">
                  <button type="button" class="tp-select-btn"
                          data-action="click->compare-tray#toggle:stop"
                          data-slug="<%= model.slug %>"
                          data-name="<%= model.name %>"
                          data-provider-name="<%= model.provider.name %>"
                          aria-pressed="false"
                          aria-label="Select <%= model.name %> to compare">
                    <%= icon(:check, size: 13) %>
                  </button>
                </td>
                <% @category.columns.each do |key| %>
                  <% if key == :name %>
                      <td class="tp-card-title <%= sort_col == 'name' ? 'tp-col-highlight' : '' %>">
                        <div class="tp-model-cell" data-controller="hovercard"
                             aria-haspopup="true" aria-expanded="false"
                             data-action="pointerenter->hovercard#show pointerleave->hovercard#hide
                                          focusin->hovercard#show focusout->hovercard#hide">
                          <%= link_to model_path(model) do %>
                            <%= provider_square(model.provider, size: :md) %>
                          <% end %>
                          <div class="tp-model-meta">
                            <div class="tp-model-name">
                              <%= link_to model.name, model_path(model), style: "color:inherit;text-decoration:none" %>
                            </div>
                            <div class="tp-model-sub">
                              <%= link_to model.provider.name, provider_path(model.provider),
                                    class: "tp-prov-name hover:underline" %>
                              <%= status_badge(model.status) %>
                              <%= modality_badge(model) %>
                            </div>
                          </div>
                          <% if model.description.present? %>
                            <div class="tp-hovercard" popover="manual" data-hovercard-target="card"
                                 data-action="toggle->hovercard#position click->hovercard#swallow:stop">
                              <p class="tp-hovercard-desc"><%= model.description %></p>
                              <div class="tp-hovercard-facts">
                                <span class="tp-hovercard-fact"><%= io_price(model, tag: true) %></span>
                                <% if model.context_window %>
                                  <span class="tp-hovercard-fact num"><%= tokens_short(model.context_window) %> ctx</span>
                                <% end %>
                                <% if model.released_on %>
                                  <span class="tp-hovercard-fact"><%= fmt_date(model.released_on) %></span>
                                <% end %>
                              </div>
                              <div class="tp-hovercard-footer">
                                <%= link_to model_path(model), class: "tp-hovercard-view" do %>
                                  View model <%= icon(:chevron_right, size: 12) %>
                                <% end %>
                              </div>
                            </div>
                          <% end %>
                        </div>
                      </td>
                  <% else %>
                    <%= render "models/data_cell", model: model, key: key, sort_col: sort_col %>
                  <% end %>
                <% end %>
                <%# Hover-revealed "open page" chevron — the row's navigation
                    affordance. Hidden in compare mode, where a row click selects. %>
                <td class="tp-col-go">
                  <span class="tp-go-chevron"><%= icon(:chevron_right, size: 16) %></span>
                </td>
              </tr>
              <% end %>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<% if @category.columns.include?(:output) %>
  <p class="mt-4 text-xs text-slate-400">
    Sorted by output price by default — output tokens are typically 3–5× more expensive than input and dominate the bill for generation-heavy workloads. Sort by input or cached input when your mix differs.
  </p>
<% end %>

<%# ── COMPARE TRAY ──────────────────────────────────────────────────
    Hidden (via .tp-tray:not(:has(.tp-tray-slot.filled))) until at least one
    model is selected. Slot contents are cloned from the selected row's own
    markup in JS — no second client-side model-data source. %>
<div class="tp-tray" data-compare-tray-target="tray" hidden>
  <%# A slot's remove button clones this rather than reaching into the dialog's
      unrelated close button for its icon — keeps the two independent. %>
  <template data-compare-tray-target="removeIconTemplate"><%= icon(:close, size: 14) %></template>
  <div class="tp-tray-inner">
    <div class="tp-tray-slots">
      <div class="tp-tray-slot" data-compare-tray-target="slot" data-slot-index="0">
        <span class="tp-tray-slot-empty">Select a model</span>
      </div>
      <div class="tp-tray-slot" data-compare-tray-target="slot" data-slot-index="1">
        <span class="tp-tray-slot-empty">Select a model</span>
      </div>
    </div>
    <div class="tp-tray-actions">
      <button type="button" class="tp-btn tp-btn-ghost tp-btn-sm" data-action="click->compare-tray#clear">
        Clear
      </button>
      <button type="button" class="tp-btn tp-btn-primary tp-btn-sm" data-compare-tray-target="compareBtn"
              data-action="click->compare-tray#openCompare" disabled>
        Pick one more
      </button>
    </div>
  </div>
</div>

<%# ── COMPARE DIALOG ────────────────────────────────────────────────
    Native <dialog>: Esc-to-close and focus trap come free from showModal().
    Backdrop-click-to-close and the open trigger are the only behaviour this
    needs to wire up; the comparison content itself is the existing /compare
    page, loaded into the nested frame so nothing about the comparison logic
    is duplicated here. %>
<dialog class="tp-compare-dialog" data-compare-tray-target="dialog" data-action="click->compare-tray#backdropClose" aria-label="Compare models">
  <div class="tp-compare-dialog-inner">
    <button type="button" class="tp-compare-dialog-close" data-action="click->compare-tray#closeDialog" aria-label="Close comparison">
      <%= icon(:close, size: 18) %>
    </button>
    <%= turbo_frame_tag "comparison", data: { compare_tray_target: "frame" } %>
  </div>
</dialog>

</div><%# /[data-controller="compare-tray"] %>
