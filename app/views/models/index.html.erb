<% content_for :title, "LLM API price tracker — tokenprice.fyi" %>
<%# Canonicalise away the sort/dir permutations so they don't read as duplicates. %>
<% content_for :canonical, root_url(tier: @tier) %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "LLM API pricing",
        itemListElement: @models.each_with_index.map { |m, i|
          { "@type": "ListItem", position: i + 1, name: m.name, url: model_url(m) }
        }
      }) %>
<% end %>

<section class="mb-8">
  <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">What does a million tokens cost?</h1>
  <p class="mt-3 max-w-2xl text-slate-600">
    Live-ish pricing for every frontier LLM, side by side. Sort by input, output, or a blended rate,
    and see how prices have moved over time.
  </p>
</section>

<% if @cheapest_frontier %>
  <%= link_to model_path(@cheapest_frontier), class: "group mb-8 flex items-center justify-between gap-4 rounded-xl border border-indigo-100 bg-gradient-to-br from-indigo-50 to-white p-5 hover:border-indigo-200" do %>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Cheapest frontier model</p>
      <p class="mt-1 text-xl font-semibold"><%= @cheapest_frontier.name %></p>
      <p class="text-sm text-slate-500"><%= @cheapest_frontier.provider.name %> · <%= usd(@cheapest_frontier.blended_per_mtok) %> blended / 1M tokens</p>
    </div>
    <div class="text-right">
      <p class="text-sm text-slate-500">in <%= usd(@cheapest_frontier.current_input) %> · out <%= usd(@cheapest_frontier.current_output) %></p>
      <span class="text-sm font-medium text-indigo-600 group-hover:underline">View history →</span>
    </div>
  <% end %>
<% end %>

<% pill_classes = "cursor-pointer rounded-full px-3 py-1 ring-1 ring-inset bg-white text-slate-600 ring-slate-200 hover:bg-slate-100 peer-checked:bg-indigo-600 peer-checked:text-white peer-checked:ring-indigo-600 peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-indigo-600 forced-colors:peer-checked:[background:SelectedItem] forced-colors:peer-checked:[color:SelectedItemText]" %>
<%# Sort/dir live as hidden inputs inside the frame (see below), so the form
    always submits whatever sort the table is currently showing. The form
    replaces history rather than advancing it: each debounced keystroke and
    pill toggle would otherwise become its own back-button stop. %>
<%= form_with url: root_path, method: :get, id: "filters", role: "search", "aria-label": "Filter models",
      data: { controller: "filters",
              action: "submit->filters#clearPending formdata->filters#clean turbo:frame-load@document->filters#announce",
              turbo_frame: "models", turbo_action: "replace" },
      class: "mb-4 space-y-3" do %>
  <p class="sr-only" role="status" data-filters-target="status"></p>
  <div class="max-w-xs">
    <label for="q" class="sr-only">Search models or providers</label>
    <%= search_field_tag :q, @query, placeholder: "Search models or providers…", autocomplete: "off",
          data: { action: "input->filters#search" },
          class: "w-full rounded-lg border-0 bg-white px-3 py-2 text-sm ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600" %>
  </div>

  <fieldset class="flex flex-wrap items-center gap-2 text-sm">
    <legend class="sr-only">Filter by provider</legend>
    <span aria-hidden="true" class="text-slate-500">Provider:</span>
    <% @providers.each do |provider| %>
      <label>
        <%= check_box_tag "providers[]", provider.slug, @provider_slugs.include?(provider.slug),
              id: "provider_#{provider.slug}", class: "peer sr-only", data: { action: "change->filters#submit" } %>
        <span class="<%= pill_classes %>"><%= provider.name %></span>
      </label>
    <% end %>
  </fieldset>

  <fieldset class="flex flex-wrap items-center gap-2 text-sm">
    <legend class="sr-only">Filter by tier</legend>
    <span aria-hidden="true" class="text-slate-500">Tier:</span>
    <% [["All", ""], ["Frontier", "frontier"], ["Mid", "mid"], ["Small / fast", "small"]].each do |label, value| %>
      <label>
        <%= radio_button_tag :tier, value, @tier == value.presence, class: "peer sr-only", data: { action: "change->filters#submit" } %>
        <span class="<%= pill_classes %>"><%= label %></span>
      </label>
    <% end %>
  </fieldset>

  <noscript>
    <%= submit_tag "Apply filters", name: nil,
          class: "cursor-pointer rounded-full bg-indigo-600 px-3 py-1 text-sm font-medium text-white hover:bg-indigo-500" %>
  </noscript>
<% end %>

<% filter_params = { tier: @tier, q: @query.presence, providers: @provider_slugs.presence }.compact %>
<% sort_params = { sort: (@sort unless @sort == "blended"), dir: (@dir unless @dir == "asc") }.compact %>
<%# target="_top": links in here (model/provider rows, clear-filters) are real
    page navigations — only the sort links opt back into the frame. %>
<%= turbo_frame_tag "models", target: "_top" do %>
<%# Default sort travels implicitly, keeping filter-submit URLs clean. %>
<%= hidden_field_tag :sort, @sort, form: "filters", id: nil if sort_params.key?(:sort) %>
<%= hidden_field_tag :dir, @dir, form: "filters", id: nil if sort_params.key?(:dir) %>

<div class="mb-2 flex items-baseline justify-between text-sm text-slate-500">
  <p data-models-count><%= pluralize(@models.size, "model") %></p>
  <% if filter_params.any? %>
    <%= link_to "Clear filters", root_path(sort_params), class: "font-medium text-indigo-600 hover:underline" %>
  <% end %>
</div>

<div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
      <tr>
        <th scope="col" aria-sort="<%= aria_sort_for("name", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium"><%= sort_link "Model", "name", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
        <th scope="col" aria-sort="<%= aria_sort_for("tier", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium"><%= sort_link "Tier", "tier", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
        <th scope="col" aria-sort="<%= aria_sort_for("input", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium text-right"><%= sort_link "Input", "input", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
        <th scope="col" aria-sort="<%= aria_sort_for("output", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium text-right"><%= sort_link "Output", "output", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
        <th scope="col" aria-sort="<%= aria_sort_for("cached", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium text-right"><%= sort_link "Cached in", "cached", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
        <th scope="col" aria-sort="<%= aria_sort_for("context", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium text-right"><%= sort_link "Context", "context", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
        <th scope="col" aria-sort="<%= aria_sort_for("blended", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium text-right" title="Blended $/1M tokens at a 3:1 input:output mix">
          <%= sort_link "Blended", "blended", current_sort: @sort, current_dir: @dir, filters: filter_params %>
        </th>
        <th scope="col" aria-sort="<%= aria_sort_for("released", current_sort: @sort, current_dir: @dir) %>" class="px-4 py-3 font-medium text-right"><%= sort_link "Released", "released", current_sort: @sort, current_dir: @dir, filters: filter_params %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @models.each do |model| %>
        <tr class="hover:bg-slate-50">
          <th scope="row" class="px-4 py-3 text-left font-normal">
            <%= link_to model.name, model_path(model), class: "font-medium text-slate-900 hover:text-indigo-600" %>
            <div class="mt-0.5 flex items-center gap-1.5 text-xs text-slate-500">
              <%= link_to model.provider.name, provider_path(model.provider), class: "hover:underline" %>
              <%= status_badge(model.status) %>
            </div>
          </th>
          <td class="px-4 py-3"><%= tier_badge(model.tier) %></td>
          <td class="px-4 py-3 text-right tabular-nums"><%= usd(model.current_input) %></td>
          <td class="px-4 py-3 text-right tabular-nums"><%= usd(model.current_output) %></td>
          <td class="px-4 py-3 text-right tabular-nums text-slate-500"><%= usd(model.current_cached_input) %></td>
          <td class="px-4 py-3 text-right tabular-nums text-slate-500"><%= tokens_short(model.context_window) %></td>
          <td class="px-4 py-3 text-right font-semibold tabular-nums"><%= usd(model.blended_per_mtok) %></td>
          <td class="px-4 py-3 text-right text-slate-500 tabular-nums"><%= model.released_on&.strftime("%b %Y") || "—" %></td>
        </tr>
      <% end %>
      <% if @models.empty? %>
        <tr>
          <td colspan="8" class="px-4 py-12 text-center text-slate-500">
            No models match your filters.
            <%= link_to "Clear filters", root_path(sort_params), class: "font-medium text-indigo-600 hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<p class="mt-4 text-xs text-slate-500">
  Blended price assumes a 3:1 input-to-output token mix — a rough stand-in for a typical chat/agent workload, so models with different input vs output pricing can be ranked on one number.
</p>
