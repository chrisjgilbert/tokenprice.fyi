<% content_for :title, "#{@model.name} pricing — tokenprice.fyi" %>
<% content_for :description, [ "#{@model.name} (#{@model.provider.name}) API pricing: #{usd_plain(@model.current_input)} input / #{usd_plain(@model.current_output)} output per 1M tokens.", @insights.summary_sentence ].compact.join(" ") %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "Product",
        name: @model.name,
        category: "LLM API model",
        description: @model.long_description,
        brand: { "@type": "Brand", name: @model.provider.name },
        releaseDate: @model.released_on&.iso8601,
        offers: ([ @model.current_input, @model.current_output ].compact.min && {
          "@type": "Offer",
          priceCurrency: "USD",
          price: @model.current_input&.to_s,
          description: "Per 1M input tokens (output #{usd_plain(@model.current_output)} / 1M)",
          availability: "https://schema.org/InStock"
        })
      }.compact) %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Models", item: root_url },
          { "@type": "ListItem", position: 2, name: @model.name, item: model_url(@model) }
        ]
      }) %>
<% end %>

<nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500">
  <%= link_to "← All models", root_path, class: "hover:text-indigo-600" %>
</nav>

<header class="mb-8 flex flex-wrap items-start justify-between gap-4">
  <div>
    <div class="flex items-center gap-2">
      <h1 class="text-3xl font-bold tracking-tight"><%= @model.name %></h1>
      <%= status_badge(@model.status) %>
    </div>
    <p class="mt-1 flex items-center gap-2 text-slate-500">
      <%= link_to @model.provider.name, provider_path(@model.provider), class: "hover:underline" %>
      <span>·</span>
      <%= tier_badge(@model.tier) %>
    </p>
  </div>
  <%= link_to "Compare →", compare_path(a: @model.slug), class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
</header>

<% editorial = { "Strengths" => @model.strengths, "Best for" => @model.best_for, "Limitations" => @model.limitations }.select { |_, v| v.present? } %>
<% if @model.description.present? || editorial.any? %>
  <section class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
    <% if @model.description.present? %>
      <p class="max-w-2xl text-slate-600"><%= @model.description %></p>
    <% end %>
    <% if editorial.any? %>
      <dl class="<%= "mt-5" if @model.description.present? %> grid gap-4 sm:grid-cols-3">
        <% editorial.each do |label, value| %>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= label %></dt>
            <dd class="mt-1 text-sm text-slate-700"><%= value %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>
  </section>
<% end %>

<div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
  <% [
       ["Input / 1M", usd(@model.current_input)],
       ["Output / 1M", usd(@model.current_output)],
       ["Cached input / 1M", usd(@model.current_cached_input)],
       ["Context window", tokens_short(@model.context_window)]
     ].each do |label, value| %>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= label %></p>
      <p class="mt-1 text-2xl font-semibold tabular-nums"><%= value %></p>
    </div>
  <% end %>
</div>

<%# ── Estimate embed: a compact mini-estimator pre-filled with this model as
    the baseline, riding the model page's traffic into /cost. ── %>
<% if @catalog_entry %>
  <% frame_id = "estimate_embed_#{@model.slug}" %>
  <% in0 = CostEstimate.embed_slider(1500) %>
  <% out0 = CostEstimate.embed_slider(600) %>
  <section class="embed-wrap">
    <div class="card emb-card">
      <div class="emb-head">
        <span class="emb-tag"><%= co_icon(:spark, size: 14) %>Estimate your monthly cost</span>
        <h3>What would <span class="emb-model"><%= provider_square(@model.provider) %><%= @model.name %></span> cost you?</h3>
        <p class="emb-sub">Live pricing for this model. Open the full estimator for caching, reused context, and capability filtering.</p>
      </div>
      <%= form_with url: model_estimate_path(@model), method: :get,
            data: { controller: "cost-form", turbo_frame: frame_id, turbo_action: "replace" } do %>
        <div class="emb-grid">
          <div class="emb-controls">
            <div class="emb-field">
              <label for="in_pos">Input tokens / request <span class="emb-v num"><%= co_kfmt(1500) %></span></label>
              <%= range_field_tag :in_pos, in0, min: 0, max: 100, id: "in_pos", class: "emb-range", data: { action: "input->cost-form#token input->cost-form#edit" } %>
            </div>
            <div class="emb-field">
              <label for="out_pos">Output tokens / request <span class="emb-v num"><%= co_kfmt(600) %></span></label>
              <%= range_field_tag :out_pos, out0, min: 0, max: 100, id: "out_pos", class: "emb-range", data: { action: "input->cost-form#token input->cost-form#edit" } %>
            </div>
            <div class="emb-field">
              <label>Requests / month</label>
              <div class="emb-presets" role="radiogroup" aria-label="Requests per month">
                <% [["10K", 10_000], ["100K", 100_000], ["500K", 500_000], ["2M", 2_000_000]].each do |lbl, v| %>
                  <label class="emb-chip <%= 'on' if v == 100_000 %>">
                    <%= radio_button_tag :req, v, v == 100_000, class: "sr-only", data: { action: "change->cost-form#submit" } %><%= lbl %>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
          <%= turbo_frame_tag frame_id, src: model_estimate_path(@model, in_pos: in0, out_pos: out0, req: 100_000), loading: "eager" do %>
            <div class="emb-out"><span class="emb-out-l">Pricing…</span></div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div>
      <%= render "signal_signups/probe", frame_id: "probe_alert_model_#{@model.slug}", variant: "alert",
            payload: "model=#{@model.slug}",
            title: "Alert me when #{@model.name}'s price changes",
            body: "Get an email when #{@model.name}'s price changes. No dashboard to check — we watch every provider.", error: nil %>
    </div>
  </section>
<% end %>

<% if @insights.facts.any? %>
  <section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold">Where it sits</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <% @insights.facts.each do |fact| %>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-sm font-semibold text-slate-900"><%= fact.label %></p>
          <p class="mt-1 text-xs text-slate-500"><%= fact.detail %></p>
        </div>
      <% end %>
    </div>
    <p class="mt-3 text-xs text-slate-400">Computed live from current prices — updates as prices move.</p>
  </section>
<% end %>

<section class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-lg font-semibold">Price history</h2>
    <% if @price_points.size > 1 %><div><%= chart_legend %></div><% end %>
  </div>
  <%= price_history_chart(@price_points) %>

  <% if @model.price_changed? %>
    <div class="mt-5 border-t border-slate-100 pt-4">
      <p class="mb-3 text-xs font-medium uppercase tracking-wide text-slate-500">
        Blended price change
        <span class="ml-1 font-normal normal-case tracking-normal text-slate-400">(3:1 I/O mix)</span>
      </p>
      <dl class="flex flex-wrap gap-x-8 gap-y-3">
        <% @model.blended_changes.each do |label, pct| %>
          <div>
            <dt class="mb-1 text-xs text-slate-400"><%= label %></dt>
            <dd>
              <% if pct %>
                <%= price_change_badge(pct) %>
              <% else %>
                <span class="tp-muted-dash">—</span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  <% end %>
</section>

<section class="mb-10">
  <h2 class="mb-3 text-lg font-semibold">Snapshots</h2>
  <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3 font-medium">Effective</th>
          <th class="px-4 py-3 font-medium text-right">Input</th>
          <th class="px-4 py-3 font-medium text-right">Output</th>
          <th class="px-4 py-3 font-medium text-right">Cached in</th>
          <th class="px-4 py-3 font-medium">Note</th>
          <th class="px-4 py-3 font-medium">Source</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @price_points.reverse_each do |pp| %>
          <tr>
            <td class="px-4 py-3 whitespace-nowrap"><%= pp.effective_on.strftime("%-d %b %Y") %></td>
            <td class="px-4 py-3 text-right tabular-nums"><%= usd(pp.input_per_mtok) %></td>
            <td class="px-4 py-3 text-right tabular-nums"><%= usd(pp.output_per_mtok) %></td>
            <td class="px-4 py-3 text-right tabular-nums text-slate-500"><%= usd(pp.cached_input_per_mtok) %></td>
            <td class="px-4 py-3 text-slate-500"><%= pp.note %></td>
            <td class="px-4 py-3 text-slate-500"><%= pp.source %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% if @related.any? %>
  <section>
    <h2 class="mb-3 text-lg font-semibold">More from <%= @model.provider.name %></h2>
    <div class="grid gap-3 sm:grid-cols-2">
      <% @related.each do |rel| %>
        <%= link_to model_path(rel), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 hover:border-indigo-200" do %>
          <div>
            <p class="font-medium"><%= rel.name %></p>
            <p class="mt-1 text-xs text-slate-500"><%= tier_badge(rel.tier) %></p>
          </div>
          <p class="text-sm tabular-nums text-slate-600">in <%= usd(rel.current_input) %> · out <%= usd(rel.current_output) %></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
