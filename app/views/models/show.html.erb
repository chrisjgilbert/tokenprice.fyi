<% content_for :title, "#{@model.name} pricing — tokenprice.fyi" %>
<% content_for :description, "#{@model.name} (#{@model.provider.name}) API pricing: #{usd_plain(@model.current_input)} input / #{usd_plain(@model.current_output)} output per 1M tokens, and how it has changed over time." %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "Product",
        name: @model.name,
        category: "LLM API model",
        description: @model.description,
        brand: { "@type": "Brand", name: @model.provider.name },
        releaseDate: @model.released_on&.iso8601,
        offers: ([ @model.current_input, @model.current_output ].compact.min && {
          "@type": "Offer",
          priceCurrency: "USD",
          price: @model.current_input&.to_s,
          description: "Per 1M input tokens (output #{usd_plain(@model.current_output)} / 1M)",
          availability: "https://schema.org/InStock"
        })
      }.compact) %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Models", item: root_url },
          { "@type": "ListItem", position: 2, name: @model.name, item: model_url(@model) }
        ]
      }) %>
<% end %>

<nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500">
  <%= link_to "← All models", root_path, class: "hover:text-indigo-600" %>
</nav>

<header class="mb-8 flex flex-wrap items-start justify-between gap-4">
  <div>
    <div class="flex items-center gap-2">
      <h1 class="text-3xl font-bold tracking-tight"><%= @model.name %></h1>
      <%= status_badge(@model.status) %>
    </div>
    <p class="mt-1 flex items-center gap-2 text-slate-500">
      <%= link_to @model.provider.name, provider_path(@model.provider), class: "hover:underline" %>
      <span>·</span>
      <%= tier_badge(@model.tier) %>
    </p>
  </div>
  <%= link_to "Compare →", compare_path(a: @model.slug), class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
</header>

<% if @model.description.present? %>
  <p class="mb-8 max-w-2xl text-slate-600"><%= @model.description %></p>
<% end %>

<div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
  <% [
       ["Input / 1M", usd(@model.current_input)],
       ["Output / 1M", usd(@model.current_output)],
       ["Cached input / 1M", usd(@model.current_cached_input)],
       ["Context window", tokens_short(@model.context_window)]
     ].each do |label, value| %>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= label %></p>
      <p class="mt-1 text-2xl font-semibold tabular-nums"><%= value %></p>
    </div>
  <% end %>
</div>

<section class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-lg font-semibold">Price history</h2>
    <% if @price_points.size > 1 %><div><%= chart_legend %></div><% end %>
  </div>
  <%= price_history_chart(@price_points) %>

  <% if @model.blended_change_since_launch %>
    <p class="mt-4 text-sm text-slate-600">
      Since launch, the blended price has moved
      <%= price_change_badge(@model.blended_change_since_launch) %>.
    </p>
  <% end %>
</section>

<section class="mb-10">
  <h2 class="mb-3 text-lg font-semibold">Snapshots</h2>
  <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3 font-medium">Effective</th>
          <th class="px-4 py-3 font-medium text-right">Input</th>
          <th class="px-4 py-3 font-medium text-right">Output</th>
          <th class="px-4 py-3 font-medium text-right">Cached in</th>
          <th class="px-4 py-3 font-medium">Note</th>
          <th class="px-4 py-3 font-medium">Source</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @price_points.reverse_each do |pp| %>
          <tr>
            <td class="px-4 py-3 whitespace-nowrap"><%= pp.effective_on.strftime("%-d %b %Y") %></td>
            <td class="px-4 py-3 text-right tabular-nums"><%= usd(pp.input_per_mtok) %></td>
            <td class="px-4 py-3 text-right tabular-nums"><%= usd(pp.output_per_mtok) %></td>
            <td class="px-4 py-3 text-right tabular-nums text-slate-500"><%= usd(pp.cached_input_per_mtok) %></td>
            <td class="px-4 py-3 text-slate-500"><%= pp.note %></td>
            <td class="px-4 py-3 text-slate-500"><%= pp.source %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% if @related.any? %>
  <section>
    <h2 class="mb-3 text-lg font-semibold">More from <%= @model.provider.name %></h2>
    <div class="grid gap-3 sm:grid-cols-2">
      <% @related.each do |rel| %>
        <%= link_to model_path(rel), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 hover:border-indigo-200" do %>
          <div>
            <p class="font-medium"><%= rel.name %></p>
            <p class="mt-1 text-xs text-slate-500"><%= tier_badge(rel.tier) %></p>
          </div>
          <p class="text-sm tabular-nums text-slate-600">in <%= usd(rel.current_input) %> · out <%= usd(rel.current_output) %></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
