<% content_for :title, "#{@model.name} pricing — tokenprice.fyi" %>
<% content_for :description,
     if @model.native_priced?
       "#{@model.name} (#{@model.provider.name}) #{ModalityClass.label(@model.modality_class).downcase} pricing: #{@model.price_headline}."
     elsif @model.directory_listing?
       "#{@model.name} (#{@model.provider.name}) — #{ModalityClass.label(@model.modality_class).downcase} model. #{@model.price_detail.presence || "Its price isn't tracked here yet."}"
     else
       "#{@model.name} (#{@model.provider.name}) API pricing: #{usd_plain(@model.current_input)} input / #{usd_plain(@model.current_output)} output per 1M tokens."
     end %>
<% content_for :canonical, model_url(@model) %>
<% content_for :head do %>
  <%
    parts = {
      "input" => @model.current_input,
      "output" => @model.current_output,
      "cached input" => @model.current_cached_input
    }.compact
    prices = parts.values
    price_breakdown = parts.map { |label, value| "#{label} #{usd_plain(value)}" }.join(", ")
    aggregate_offer =
      if prices.any?
        {
          "@type": "AggregateOffer",
          priceCurrency: "USD",
          availability: "https://schema.org/InStock",
          lowPrice: prices.min.to_s,
          highPrice: prices.max.to_s,
          offerCount: prices.size,
          description: "List price per 1M tokens — #{price_breakdown}.",
          priceSpecification: {
            "@type": "UnitPriceSpecification",
            priceCurrency: "USD",
            unitText: "per 1M tokens",
            referenceQuantity: {
              "@type": "QuantitativeValue",
              value: 1_000_000,
              unitText: "tokens"
            }
          }
        }
      end
  %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "Product",
        name: @model.name,
        category: "LLM API model",
        description: @model.long_description,
        brand: { "@type": "Brand", name: @model.provider.name },
        releaseDate: @model.released_on&.iso8601,
        offers: aggregate_offer
      }.compact) %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Models", item: root_url },
          { "@type": "ListItem", position: 2, name: @model.name, item: model_url(@model) }
        ]
      }) %>
<% end %>

<nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500">
  <%= link_to "← All models", root_path, class: "hover:text-indigo-600" %>
</nav>

<header class="mb-8 flex flex-wrap items-start justify-between gap-4">
  <div class="flex items-start gap-4">
    <%= link_to provider_path(@model.provider), class: "mt-1 shrink-0", aria: { label: @model.provider.name } do %>
      <%= provider_square(@model.provider, size: :lg) %>
    <% end %>
    <div>
      <div class="flex items-center gap-2">
        <h1 class="text-3xl font-bold tracking-tight"><%= @model.name %></h1>
        <%= status_badge(@model.status) %>
      </div>
      <p class="mt-1 flex items-center gap-2 text-slate-500">
        <%= link_to @model.provider.name, provider_path(@model.provider), class: "hover:underline" %>
        <% if @model.provider.flag_emoji %><span aria-hidden="true"><%= @model.provider.flag_emoji %></span><% end %>
        <span>·</span>
        <%= tier_badge(@model.tier) %>
        <% if (badge = modality_badge(@model)) %>
          <span>·</span>
          <%= badge %>
        <% end %>
      </p>
    </div>
  </div>
  <%= link_to compare_path(a: @model.slug), class: "inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" do %>
    <%= icon(:swap, size: 15) %> Compare
  <% end %>
</header>

<% editorial = {
     "Strengths"   => [ @model.strengths,   :bolt ],
     "Best for"    => [ @model.best_for,    :target ],
     "Limitations" => [ @model.limitations, :warn ]
   }.select { |_, (v, _)| v.present? } %>
<% if @model.description.present? || editorial.any? %>
  <section class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
    <% if @model.description.present? %>
      <p class="max-w-2xl text-slate-600"><%= @model.description %></p>
    <% end %>
    <% if editorial.any? %>
      <dl class="<%= "mt-5" if @model.description.present? %> grid gap-4 sm:grid-cols-3">
        <% editorial.each do |label, (value, ic)| %>
          <div>
            <dt class="flex items-center gap-1.5 text-xs font-medium uppercase tracking-wide text-slate-500">
              <span class="text-slate-400" aria-hidden="true"><%= icon(ic, size: 14) %></span><%= label %>
            </dt>
            <dd class="mt-1 text-sm text-slate-700"><%= value %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>
  </section>
<% end %>

<% if @model.priced? %>
  <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
    <% [
         ["Input / 1M", usd(@model.current_input), :arrow_in],
         ["Output / 1M", usd(@model.current_output), :arrow_out],
         ["Cached input / 1M", usd(@model.current_cached_input), :cache],
         ["Context window", tokens_short(@model.context_window), :brackets]
       ].each do |label, value, ic| %>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="flex items-center justify-between">
          <p class="text-xs uppercase tracking-wide text-slate-500"><%= label %></p>
          <span class="text-slate-300" aria-hidden="true"><%= icon(ic, size: 15) %></span>
        </div>
        <p class="mt-1 text-2xl font-semibold tabular-nums"><%= value %></p>
      </div>
    <% end %>
  </div>
<% elsif @model.native_priced? %>
  <div class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <p class="text-xs uppercase tracking-wide text-slate-500">Pricing</p>
      <% if @model.pricing_model_label %>
        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600"><%= @model.pricing_model_label %></span>
      <% end %>
    </div>
    <p class="mt-1 text-2xl font-semibold tabular-nums text-slate-900"><%= @model.price_headline %></p>
    <% if @model.price_detail.present? %>
      <p class="mt-2 max-w-xl text-sm text-slate-600"><%= @model.price_detail %></p>
    <% end %>
    <% if @model.price_source.present? %>
      <p class="mt-3 text-xs text-slate-400">
        Source: <%= link_to @model.price_source, @model.price_source, class: "underline hover:text-slate-600", target: "_blank", rel: "noopener" %><% if @model.priced_as_of %>, as of <%= fmt_date_full(@model.priced_as_of) %><% end %>
      </p>
    <% end %>
  </div>
<% else %>
  <div class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
    <p class="text-xs uppercase tracking-wide text-slate-500">Pricing</p>
    <p class="mt-1 text-lg font-semibold text-slate-600"><%= @model.price_detail.present? ? "Pricing not published" : "Priced per image — not yet tracked" %></p>
    <p class="mt-2 max-w-xl text-sm text-slate-500"><%= @model.price_detail.presence || "Image-generation models are priced per image, not per token. That price isn't in the catalogue yet." %></p>
  </div>
<% end %>

<% if @catalog_entry && (billing = @catalog_entry.extra_billing).any? %>
  <div class="tp-also-billed mb-8 rounded-xl border border-slate-200 bg-white p-5">
    <p class="mb-3 text-xs font-medium uppercase tracking-wide text-slate-500">Also billed</p>
    <dl class="grid gap-x-8 gap-y-2 sm:grid-cols-2">
      <% billing.each do |line| %>
        <div class="flex items-baseline justify-between gap-4">
          <dt class="text-sm text-slate-600"><%= line.label %></dt>
          <dd class="text-sm font-semibold tabular-nums">
            <%= usd(line.value, decimals: line.decimals) %><% if line.unit %> <span class="font-normal text-slate-400"><%= line.unit %></span><% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>
<% end %>

<% if @catalog_entry %>
  <section class="mb-8">
    <%= link_to trends_path, class: "group flex items-center justify-between gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-200" do %>
      <div class="flex items-start gap-3">
        <span class="mt-0.5 shrink-0 text-indigo-500" aria-hidden="true"><%= icon(:trend_down, size: 20) %></span>
        <div>
          <h2 class="font-semibold">Flagship prices over time</h2>
          <p class="mt-1 text-sm text-slate-600">Every provider's most-powerful model, priced at launch, charted on one log axis.</p>
        </div>
      </div>
      <span class="shrink-0 text-slate-400 group-hover:text-indigo-500" aria-hidden="true"><%= icon(:chevron_right, size: 18) %></span>
    <% end %>
  </section>
<% end %>

<% if @model.priced? %>
<section class="mb-8 rounded-xl border border-slate-200 bg-white p-5">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-lg font-semibold">Price history</h2>
    <% if @price_points.size > 1 %><div><%= chart_legend %></div><% end %>
  </div>
  <%= price_history_chart(@price_points) %>

  <% if @model.price_changed? %>
    <div class="mt-5 border-t border-slate-100 pt-4">
      <p class="mb-3 text-xs font-medium uppercase tracking-wide text-slate-500">Price change</p>
      <dl class="flex flex-wrap gap-x-8 gap-y-3">
        <% @model.price_changes.each do |change| %>
          <div>
            <dt class="mb-1 text-xs text-slate-400"><%= change.label %></dt>
            <dd class="flex flex-col gap-1.5">
              <% [ [ "in", change.input ], [ "out", change.output ] ].each do |dim, pct| %>
                <span class="flex items-center gap-1.5 text-xs">
                  <span class="w-7 text-slate-400"><%= dim %></span>
                  <% if pct %><%= price_change_badge(pct) %><% else %><span class="tp-muted-dash">—</span><% end %>
                </span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  <% end %>
</section>

<section class="mb-10">
  <h2 class="mb-3 text-lg font-semibold">Snapshots</h2>
  <div class="tp-cardify-wrap overflow-x-auto rounded-xl border border-slate-200 bg-white">
    <table class="tp-cardify min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3 font-medium">Effective</th>
          <th class="px-4 py-3 font-medium text-right">Input</th>
          <th class="px-4 py-3 font-medium text-right">Output</th>
          <th class="px-4 py-3 font-medium text-right">Cached in</th>
          <th class="px-4 py-3 font-medium">Note</th>
          <th class="px-4 py-3 font-medium">Source</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @price_points.reverse_each do |pp| %>
          <tr>
            <td class="tp-card-title px-4 py-3 whitespace-nowrap"><%= pp.effective_on.strftime("%-d %b %Y") %></td>
            <td data-label="Input" class="px-4 py-3 text-right tabular-nums"><%= usd(pp.input_per_mtok) %></td>
            <td data-label="Output" class="px-4 py-3 text-right tabular-nums"><%= usd(pp.output_per_mtok) %></td>
            <td data-label="Cached in" class="px-4 py-3 text-right tabular-nums text-slate-500"><%= usd(pp.cached_input_per_mtok) %></td>
            <td data-label="Note" class="px-4 py-3 text-slate-500"><%= pp.note %></td>
            <td data-label="Source" class="px-4 py-3 text-slate-500"><%= pp.source %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
<% end %>

<% if @related.any? %>
  <section>
    <h2 class="mb-3 text-lg font-semibold">More from <%= @model.provider.name %></h2>
    <div class="grid gap-3 sm:grid-cols-2">
      <% @related.each do |rel| %>
        <%= link_to model_path(rel), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 hover:border-indigo-200" do %>
          <div>
            <p class="font-medium"><%= rel.name %></p>
            <p class="mt-1 text-xs text-slate-500"><%= tier_badge(rel.tier) %></p>
          </div>
          <p class="text-sm tabular-nums text-slate-600">in <%= usd(rel.current_input) %> · out <%= usd(rel.current_output) %></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<div class="mt-10 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-5 text-sm text-slate-500">
  <%= data_updated_tag(@last_updated) %>
  <%= model_report_link(@model, css: "underline decoration-slate-300 underline-offset-2 hover:text-indigo-600") %>
</div>
