<% content_for :title, "The geopolitics of AI — where models come from — tokenprice.fyi" %>
<% content_for :description, "A world map of who builds frontier AI: which countries host the labs behind every tracked model, and how many providers each commands." %>

<div class="map-page">
  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="map-header">
    <div class="map-eyebrow">
      <span class="map-eyebrow-dot"></span>
      Where the models come from
    </div>
    <h1 class="map-h1">The geopolitics of <span class="accent">AI pricing</span></h1>
    <p class="map-subtitle">
      Every model on this site is built somewhere. Mapped by the headquarters of the lab
      behind it, the frontier is a contest between a handful of states<% if @leader %> —
      led by <strong><%= @leader[:providers].first.flag_emoji %> <%= @leader[:name] %></strong>,
      with <%= pluralize(@leader[:provider_count], "lab") %> shipping
      <%= pluralize(@leader[:model_count], "tracked model") %><% end %>.
    </p>
  </div>

  <%# ── Stat row ───────────────────────────────────────────────────────── %>
  <div class="map-stats">
    <div class="map-stat">
      <span class="map-stat-val num"><%= @countries.size %></span>
      <span class="map-stat-label">Countries with labs</span>
    </div>
    <div class="map-stat">
      <span class="map-stat-val num"><%= @located_providers %></span>
      <span class="map-stat-label">Providers mapped</span>
    </div>
    <div class="map-stat">
      <span class="map-stat-val num"><%= @total_models %></span>
      <span class="map-stat-label">Models in play</span>
    </div>
    <% if @leader %>
      <div class="map-stat">
        <span class="map-stat-val"><%= @by_code[@leader[:code]][:providers].first.flag_emoji %> <span class="num"><%= number_to_percentage(100.0 * @leader[:provider_count] / [@located_providers, 1].max, precision: 0) %></span></span>
        <span class="map-stat-label">Share held by <%= @leader[:name] %></span>
      </div>
    <% end %>
  </div>

  <%# ── Map card ───────────────────────────────────────────────────────── %>
  <div class="tp-card map-card">
    <svg
      class="map-svg"
      viewBox="<%= world_map_viewbox %>"
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-label="World map of AI providers by country"
    >
      <%# Base layer: every country, shaded by provider count %>
      <g class="map-land">
        <% world_map["countries"].each do |code, c| %>
          <% entry = @by_code[code] %>
          <% count = entry ? entry[:provider_count] : 0 %>
          <path
            d="<%= c["d"] %>"
            fill="<%= country_fill(count, @max_providers) %>"
            class="map-country<%= ' on' if entry %>"
          ><% if entry %><title><%= entry[:name] %> — <%= pluralize(entry[:provider_count], "provider") %>, <%= pluralize(entry[:model_count], "model") %></title><% end %></path>
        <% end %>
      </g>

      <%# Marker layer: provider counts at country centroids %>
      <g class="map-markers">
        <% @countries.each do |entry| %>
          <% c = world_map["countries"][entry[:code]] %>
          <% next unless c %>
          <g class="map-marker">
            <circle cx="<%= c["cx"] %>" cy="<%= c["cy"] %>" r="13" />
            <text x="<%= c["cx"] %>" y="<%= c["cy"] %>" text-anchor="middle" dominant-baseline="central"><%= entry[:provider_count] %></text>
          </g>
        <% end %>
      </g>
    </svg>

    <div class="map-legend">
      <span class="map-legend-label">Providers per country</span>
      <div class="map-legend-scale">
        <span class="map-legend-swatch" style="background: var(--color-slate-200)"></span>
        <span class="map-legend-min">none</span>
        <% [0.34, 0.55, 0.78, 1.0].each do |t| %>
          <span class="map-legend-swatch" style="background: rgba(79,70,229,<%= t %>)"></span>
        <% end %>
        <span class="map-legend-max">most (<%= @max_providers %>)</span>
      </div>
    </div>
  </div>

  <%# ── Country ranking ────────────────────────────────────────────────── %>
  <p class="tp-section-label map-rank-label">The contenders</p>
  <div class="map-countries">
    <% @countries.each_with_index do |c, i| %>
      <div class="tp-card map-country-card">
        <div class="map-cc-head">
          <span class="map-cc-flag"><%= @by_code[c[:code]][:providers].first.flag_emoji %></span>
          <div class="map-cc-title">
            <div class="map-cc-name"><%= c[:name] %></div>
            <div class="map-cc-rank">#<%= i + 1 %> · <%= c[:code] %></div>
          </div>
          <div class="map-cc-counts">
            <span class="map-cc-big num"><%= c[:provider_count] %></span>
            <span class="map-cc-counts-label"><%= "lab".pluralize(c[:provider_count]) %></span>
          </div>
        </div>

        <%# share bar %>
        <div class="map-cc-bar">
          <div class="map-cc-bar-fill" style="width: <%= (100.0 * c[:provider_count] / [@max_providers, 1].max).round(1) %>%"></div>
        </div>

        <div class="map-cc-meta">
          <div class="map-cc-metric">
            <span class="map-cc-metric-val num"><%= c[:model_count] %></span>
            <span class="map-cc-metric-label">models</span>
          </div>
          <div class="map-cc-metric">
            <span class="map-cc-metric-val num"><%= c[:frontier_count] %></span>
            <span class="map-cc-metric-label">frontier</span>
          </div>
          <% if c[:cheapest] %>
            <div class="map-cc-metric map-cc-metric-cheap">
              <span class="map-cc-metric-val"><%= link_to io_price(c[:cheapest], light: true), model_path(c[:cheapest]), style: "color:inherit;text-decoration:none" %></span>
              <span class="map-cc-metric-label">cheapest I/O</span>
            </div>
          <% end %>
        </div>

        <div class="map-cc-provs">
          <% c[:providers].each do |provider| %>
            <%= link_to provider_path(provider), class: "map-cc-prov", title: provider.name do %>
              <%= provider_square(provider, size: :sm) %>
              <span><%= provider.name %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @unlocated.any? %>
    <p class="map-unlocated">
      <%= pluralize(@unlocated.size, "provider") %> not yet placed on the map:
      <%= safe_join(@unlocated.map { |p| link_to p.name, provider_path(p), class: "map-unlocated-link" }, ", ") %>.
    </p>
  <% end %>
</div>

<style>
.map-page { padding-top: 36px; padding-bottom: 64px; }

/* ── Header ──────────────────────────────────────────────────────────── */
.map-header { margin-bottom: 26px; }
.map-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px;
  background: var(--color-indigo-50); border: 1px solid var(--color-indigo-100);
  font-family: var(--font-mono); font-size: 12px; font-weight: 600;
  color: var(--color-indigo-700); letter-spacing: .04em; margin-bottom: 18px;
}
.map-eyebrow-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--color-indigo-500); box-shadow: 0 0 0 3px var(--color-indigo-200);
  animation: tp-pulse 2.4s var(--ease-default) infinite; flex: none;
}
.map-h1 {
  font-size: clamp(30px, 4vw, 44px); font-weight: 700;
  letter-spacing: -0.033em; line-height: 1.05; color: var(--color-slate-900);
}
.map-h1 .accent { color: var(--color-indigo-600); }
.map-subtitle {
  margin-top: 14px; max-width: 46em; color: var(--color-slate-500);
  font-size: 17px; line-height: 1.6;
}
.map-subtitle strong { color: var(--color-slate-800); font-weight: 600; }

/* ── Stat row ────────────────────────────────────────────────────────── */
.map-stats {
  display: flex; flex-wrap: wrap; gap: 14px; margin: 22px 0 24px;
}
.map-stat {
  flex: 1 1 150px; padding: 16px 18px;
  background: #fff; border: 1px solid var(--color-slate-200);
  border-radius: var(--radius-lg); box-shadow: var(--shadow-xs);
}
.map-stat-val {
  font-family: var(--font-mono); font-size: 24px; font-weight: 700;
  letter-spacing: -0.03em; color: var(--color-slate-900);
  display: block; line-height: 1;
}
.map-stat-label {
  font-size: 12px; color: var(--color-slate-400); font-weight: 500;
  margin-top: 7px; display: block;
}

/* ── Map card ────────────────────────────────────────────────────────── */
.map-card {
  padding: 14px 14px 8px;
  background: linear-gradient(180deg, #fbfcff, #f4f6fc);
  overflow: hidden;
}
.map-svg { width: 100%; height: auto; display: block; }
.map-country {
  stroke: rgba(255,255,255,.85);
  stroke-width: 0.5;
  transition: fill .15s var(--ease-default);
}
.map-country.on {
  stroke: rgba(255,255,255,.95);
  stroke-width: 0.7;
}
.map-country.on:hover { fill: var(--color-indigo-700) !important; }
.map-marker circle {
  fill: #fff;
  stroke: var(--color-indigo-600);
  stroke-width: 2;
  filter: drop-shadow(0 1px 2px rgba(15,23,42,.25));
}
.map-marker text {
  font-family: var(--font-mono); font-size: 14px; font-weight: 700;
  fill: var(--color-indigo-700);
}

/* ── Legend ──────────────────────────────────────────────────────────── */
.map-legend {
  display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  padding: 12px 8px 6px; border-top: 1px solid var(--color-slate-100); margin-top: 6px;
}
.map-legend-label {
  font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .05em;
  text-transform: uppercase; color: var(--color-slate-400);
}
.map-legend-scale { display: inline-flex; align-items: center; gap: 5px; }
.map-legend-swatch {
  width: 18px; height: 12px; border-radius: 3px; display: inline-block;
  border: 1px solid rgba(15,23,42,.06);
}
.map-legend-min, .map-legend-max {
  font-size: 11px; color: var(--color-slate-400); font-family: var(--font-mono);
}
.map-legend-min { margin-right: 4px; }
.map-legend-max { margin-left: 4px; }

/* ── Country ranking ─────────────────────────────────────────────────── */
.map-rank-label { margin: 32px 0 14px; }
.map-countries {
  display: grid; gap: 14px;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
}
.map-country-card { padding: 18px; }
.map-cc-head { display: flex; align-items: center; gap: 12px; }
.map-cc-flag { font-size: 30px; line-height: 1; flex: none; }
.map-cc-title { flex: 1; min-width: 0; }
.map-cc-name {
  font-size: 16px; font-weight: 700; letter-spacing: -0.02em;
  color: var(--color-slate-900);
}
.map-cc-rank {
  font-family: var(--font-mono); font-size: 11px; color: var(--color-slate-400);
  margin-top: 2px;
}
.map-cc-counts { text-align: right; flex: none; }
.map-cc-big {
  font-family: var(--font-mono); font-size: 26px; font-weight: 700;
  letter-spacing: -0.03em; color: var(--color-indigo-600); display: block; line-height: 1;
}
.map-cc-counts-label { font-size: 11px; color: var(--color-slate-400); }

.map-cc-bar {
  height: 6px; border-radius: 999px; background: var(--color-slate-100);
  margin: 14px 0 14px; overflow: hidden;
}
.map-cc-bar-fill {
  height: 100%; border-radius: 999px;
  background: linear-gradient(90deg, var(--color-indigo-400), var(--color-indigo-600));
}

.map-cc-meta {
  display: flex; gap: 18px; padding-bottom: 14px;
  border-bottom: 1px solid var(--color-slate-100); margin-bottom: 12px;
}
.map-cc-metric { display: flex; flex-direction: column; }
.map-cc-metric-cheap { margin-left: auto; text-align: right; }
.map-cc-metric-val {
  font-size: 15px; font-weight: 700; color: var(--color-slate-900);
  letter-spacing: -0.02em;
}
.map-cc-metric-label {
  font-size: 11px; color: var(--color-slate-400); margin-top: 2px;
}

.map-cc-provs { display: flex; flex-wrap: wrap; gap: 6px; }
.map-cc-prov {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 9px 4px 5px; border-radius: 999px;
  background: var(--color-slate-50); border: 1px solid var(--color-slate-200);
  font-size: 12.5px; font-weight: 500; color: var(--color-slate-600);
  transition: all .14s var(--ease-default);
}
.map-cc-prov:hover {
  border-color: var(--color-indigo-300); color: var(--color-indigo-700);
  background: var(--color-indigo-50);
}

.map-unlocated {
  margin-top: 22px; font-size: 13.5px; color: var(--color-slate-500);
}
.map-unlocated-link { color: var(--color-indigo-600); font-weight: 500; }
.map-unlocated-link:hover { text-decoration: underline; }
</style>
