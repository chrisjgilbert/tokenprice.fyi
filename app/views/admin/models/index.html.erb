<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold tracking-tight">Models</h1>
  <%= link_to "+ New model", new_admin_model_path,
        class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
</div>

<div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
      <tr>
        <th scope="col" class="px-4 py-3 font-medium">Model</th>
        <th scope="col" class="px-4 py-3 font-medium text-right">Current in / out</th>
        <th scope="col" class="px-4 py-3 font-medium text-right">As of</th>
        <th scope="col" class="px-4 py-3 font-medium text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @models.each do |model| %>
        <tr>
          <th scope="row" class="px-4 py-3 text-left font-normal">
            <%= link_to model.name, edit_admin_model_path(model), class: "font-medium text-slate-900 hover:text-indigo-600" %>
            <div class="text-xs text-slate-500"><%= model.provider.name %> · <%= model.status %></div>
          </th>
          <td class="px-4 py-3 text-right tabular-nums">
            <%= usd(model.current_input) %> / <%= usd(model.current_output) %>
          </td>
          <td class="px-4 py-3 text-right text-slate-500 tabular-nums">
            <%= model.current_price&.effective_on&.strftime("%-d %b %Y") || "—" %>
          </td>
          <td class="px-4 py-3 text-right whitespace-nowrap">
            <%= link_to "Add price", new_admin_model_price_point_path(model), class: "font-medium text-indigo-600 hover:underline" %>
            <span class="text-slate-300">·</span>
            <%= link_to "Edit", edit_admin_model_path(model), class: "text-slate-500 hover:underline" %>
            <span class="text-slate-300">·</span>
            <%= button_to "Delete", admin_model_path(model), method: :delete,
                  form: { data: { turbo_confirm: "Delete #{model.name} and all its prices?" }, class: "inline" },
                  class: "text-rose-600 hover:underline bg-transparent" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
