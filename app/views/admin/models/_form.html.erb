<%= form_with model: model,
      url: (model.persisted? ? admin_model_path(model) : admin_models_path) do |f| %>
  <%= render "admin/errors", record: model %>

  <div class="space-y-4 rounded-xl border border-slate-200 bg-white p-5">
    <div>
      <%= f.label :provider_id, "Provider", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.collection_select :provider_id, Provider.order(:name), :id, :name,
            { prompt: "Select a provider" }, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :slug, model.persisted? ? "Slug (locked)" : "Slug (optional — auto from name)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <% if model.persisted? %>
          <%= f.text_field :slug, readonly: true, class: "block w-full rounded-lg border-slate-200 bg-slate-50 text-slate-500 shadow-sm cursor-not-allowed" %>
          <p class="mt-1 text-xs text-slate-400">The permanent public URL — locked after creation so links and citations don't break.</p>
        <% else %>
          <%= f.text_field :slug, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
        <% end %>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :tier, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :tier, AiModel.tiers.keys.map { |t| [t.titleize, t] }, {}, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :status, AiModel.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <%= f.label :context_window, "Context window (tokens)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :context_window, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :max_output_tokens, "Max output (tokens)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :max_output_tokens, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :released_on, "Released on", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.date_field :released_on, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :description, "Description (one-line summary)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :description, rows: 2, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
    </div>

    <div>
      <%= f.label :so_what, "So what (why the launch matters — generated, editable)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :so_what, rows: 2, class: "block w-full rounded-lg border-slate-300 shadow-sm",
            placeholder: "Generated via the Regenerate button below once released, or write your own." %>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <%= f.label :strengths, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :strengths, rows: 3, placeholder: "What it's good at", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :best_for, "Best for (use cases)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :best_for, rows: 3, placeholder: "Typical workloads", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :limitations, "Limitations (weaknesses)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :limitations, rows: 3, placeholder: "Trade-offs to know", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>

    <%# Data source — controls how the daily OpenRouter import treats this row. %>
    <div class="border-t border-slate-100 pt-4">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= f.label :source, "Data source", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :source,
                [["Manual (hand-curated)", AiModel::MANUAL_SOURCE], ["OpenRouter (synced)", AiModel::OPENROUTER_SOURCE]],
                {}, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
        </div>
        <div>
          <%= f.label :openrouter_id, "OpenRouter ID (link)", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :openrouter_id, placeholder: "e.g. anthropic/claude-opus-4.8", class: "block w-full rounded-lg border-slate-300 shadow-sm font-mono text-sm" %>
        </div>
      </div>
      <p class="mt-2 text-xs text-slate-400">
        <strong>Manual</strong> protects this model's details from the daily OpenRouter import — only blank fields are ever filled. To also stop automatic <em>price</em> updates, clear the OpenRouter ID (an empty value unlinks it).
      </p>
    </div>
  </div>

  <div class="mt-4 flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 cursor-pointer" %>
    <%= link_to "Cancel", admin_models_path, class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
