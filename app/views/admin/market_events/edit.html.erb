<nav class="mb-4 text-sm text-slate-500"><%= link_to "← Market Events", admin_market_events_path, class: "hover:text-slate-900" %></nav>
<h1 class="mb-6 text-2xl font-bold tracking-tight">Edit event</h1>

<% if @event.status == "draft" %>
  <div class="mb-4 flex items-center gap-3 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
    <span>This is a draft.</span>
    <%= button_to "Publish now →", publish_admin_market_event_path(@event), method: :patch,
          class: "rounded bg-emerald-600 px-3 py-1 text-xs font-medium text-white hover:bg-emerald-500" %>
    <% if @event.source_url.present? %>
      <%= link_to "Open source ↗", @event.source_url, target: "_blank", rel: "noopener",
            class: "ml-auto text-indigo-600 hover:underline" %>
    <% end %>
  </div>
<% end %>

<%= render "form", event: @event %>
