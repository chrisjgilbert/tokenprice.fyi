<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold tracking-tight">Market Events</h1>
  <%= link_to "+ New event", new_admin_market_event_path,
        class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
</div>

<% if @drafts.any? %>
  <h2 class="mb-3 text-lg font-semibold text-amber-700">Draft review queue (<%= @drafts.size %>)</h2>
  <div class="mb-8 overflow-x-auto rounded-xl border border-amber-200 bg-amber-50">
    <table class="min-w-full divide-y divide-amber-200 text-sm">
      <thead class="bg-amber-100 text-left text-xs uppercase tracking-wide text-amber-700">
        <tr>
          <th scope="col" class="px-4 py-3 font-medium">Title</th>
          <th scope="col" class="px-4 py-3 font-medium">Date</th>
          <th scope="col" class="px-4 py-3 font-medium">Source</th>
          <th scope="col" class="px-4 py-3 font-medium text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-amber-100">
        <% @drafts.each do |event| %>
          <tr>
            <th scope="row" class="px-4 py-3 text-left font-normal">
              <%= link_to event.title, edit_admin_market_event_path(event), class: "font-medium text-slate-900 hover:text-indigo-600" %>
              <% if event.note.present? %>
                <div class="text-xs text-slate-500 mt-0.5 max-w-lg"><%= truncate(event.note, length: 100) %></div>
              <% end %>
              <% if event.so_what.present? %>
                <div class="text-xs text-rose-600 mt-0.5 max-w-lg">So what: <%= truncate(event.so_what, length: 100) %></div>
              <% end %>
            </th>
            <td class="px-4 py-3 text-slate-600 tabular-nums whitespace-nowrap"><%= event.event_date.strftime("%-d %b %Y") %></td>
            <td class="px-4 py-3 text-slate-500 whitespace-nowrap">
              <% if event.source_url.present? %>
                <%= link_to event.source.presence || "source", event.source_url,
                      target: "_blank", rel: "noopener",
                      class: "text-indigo-600 hover:underline" %>
              <% else %>
                <%= event.source.presence || "—" %>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right whitespace-nowrap">
              <%= button_to "Publish", publish_admin_market_event_path(event), method: :patch,
                    class: "rounded bg-emerald-600 px-3 py-1 text-xs font-medium text-white hover:bg-emerald-500" %>
              <span class="text-slate-300 mx-1">·</span>
              <%= link_to "Edit", edit_admin_market_event_path(event), class: "text-slate-500 hover:underline text-xs" %>
              <span class="text-slate-300 mx-1">·</span>
              <%= button_to "Discard", admin_market_event_path(event), method: :delete,
                    form: { data: { turbo_confirm: "Discard this draft? Linked news items will be marked not re-draftable." }, class: "inline" },
                    class: "text-rose-600 hover:underline bg-transparent text-xs" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<h2 class="mb-3 text-lg font-semibold text-slate-700">Published (<%= @published.size %>)</h2>
<div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
      <tr>
        <th scope="col" class="px-4 py-3 font-medium">Title</th>
        <th scope="col" class="px-4 py-3 font-medium">Date</th>
        <th scope="col" class="px-4 py-3 font-medium">Source</th>
        <th scope="col" class="px-4 py-3 font-medium text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% if @published.empty? %>
        <tr><td colspan="4" class="px-4 py-6 text-center text-slate-400">No published events yet.</td></tr>
      <% else %>
        <% @published.each do |event| %>
          <tr>
            <th scope="row" class="px-4 py-3 text-left font-normal">
              <%= link_to event.title, edit_admin_market_event_path(event), class: "font-medium text-slate-900 hover:text-indigo-600" %>
              <% if event.note.present? %>
                <div class="text-xs text-slate-500 mt-0.5 max-w-lg"><%= truncate(event.note, length: 100) %></div>
              <% end %>
              <% if event.so_what.present? %>
                <div class="text-xs text-rose-600 mt-0.5 max-w-lg">So what: <%= truncate(event.so_what, length: 100) %></div>
              <% end %>
            </th>
            <td class="px-4 py-3 text-slate-600 tabular-nums whitespace-nowrap"><%= event.event_date.strftime("%-d %b %Y") %></td>
            <td class="px-4 py-3 text-slate-500 whitespace-nowrap">
              <% if event.source_url.present? %>
                <%= link_to event.source.presence || "source", event.source_url,
                      target: "_blank", rel: "noopener",
                      class: "text-indigo-600 hover:underline" %>
              <% else %>
                <%= event.source.presence || "—" %>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right whitespace-nowrap">
              <%= link_to "Edit", edit_admin_market_event_path(event), class: "font-medium text-indigo-600 hover:underline" %>
              <span class="text-slate-300">·</span>
              <%= button_to "Delete", admin_market_event_path(event), method: :delete,
                    form: { data: { turbo_confirm: "Delete #{event.title}?" }, class: "inline" },
                    class: "text-rose-600 hover:underline bg-transparent" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
