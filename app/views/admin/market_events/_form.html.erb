<%= form_with model: event,
      url: (event.persisted? ? admin_market_event_path(event) : admin_market_events_path) do |f| %>
  <%= render "admin/errors", record: event %>

  <div class="space-y-4 rounded-xl border border-slate-200 bg-white p-5">
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :title, class: "block w-full rounded-lg border-slate-300 shadow-sm",
            placeholder: "e.g. GPT-4 Turbo: 3× cheaper" %>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :event_date, "Event date", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.date_field :event_date, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :status, [["Published", "published"], ["Draft", "draft"]], {},
              class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :note, "Note (one sentence with concrete figures)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :note, rows: 3, class: "block w-full rounded-lg border-slate-300 shadow-sm",
            placeholder: "e.g. GPT-4 Turbo launches at $10/$30 with 128K context, making the frontier 3× cheaper overnight." %>
    </div>

    <div>
      <%= f.label :so_what, "So what (why it matters — generated, editable)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :so_what, rows: 2, class: "block w-full rounded-lg border-slate-300 shadow-sm",
            placeholder: "Generated from a web search on save via the Regenerate button, or write your own." %>
      <% if event.citations.present? %>
        <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-slate-500">
          <span class="font-medium uppercase tracking-wide">Sources</span>
          <% event.citations.each do |citation| %>
            <%= link_to citation["title"].presence || citation["url"], citation["url"],
                  target: "_blank", rel: "noopener", class: "text-indigo-600 hover:underline" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :source_url, "Source URL", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.url_field :source_url, class: "block w-full rounded-lg border-slate-300 shadow-sm",
              placeholder: "https://…" %>
      </div>
      <div>
        <%= f.label :source, "Source label", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :source, class: "block w-full rounded-lg border-slate-300 shadow-sm",
              placeholder: "e.g. admin, curation, hn" %>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 cursor-pointer" %>
    <%= link_to "Cancel", admin_market_events_path, class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
