<%= form_with model: provider,
      url: (provider.persisted? ? admin_provider_path(provider) : admin_providers_path) do |f| %>
  <%= render "admin/errors", record: provider %>

  <div class="space-y-4 rounded-xl border border-slate-200 bg-white p-5">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :slug, "Slug (optional — auto from name)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :slug, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :website, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.url_field :website, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :accent, "Accent colour (hex)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :accent, placeholder: "#4f46e5", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 cursor-pointer" %>
    <%= link_to "Cancel", admin_providers_path, class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
