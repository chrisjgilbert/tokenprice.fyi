<%= form_with model: price_point,
      url: (price_point.persisted? ? admin_model_price_point_path(model, price_point) : admin_model_price_points_path(model)) do |f| %>
  <%= render "admin/errors", record: price_point %>

  <div class="space-y-4 rounded-xl border border-slate-200 bg-white p-5">
    <div>
      <%= f.label :effective_on, "Effective on", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :effective_on, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      <p class="mt-1 text-xs text-slate-500">The date you observed this price (one snapshot per model per date).</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <%= f.label :input_per_mtok, "Input $/1M", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :input_per_mtok, step: "any", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :output_per_mtok, "Output $/1M", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :output_per_mtok, step: "any", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :cached_input_per_mtok, "Cached input $/1M (optional)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.number_field :cached_input_per_mtok, step: "any", class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :source, "Source (URL you read it from)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :source, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :note, "Note (optional)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :note, class: "block w-full rounded-lg border-slate-300 shadow-sm" %>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 cursor-pointer" %>
    <%= link_to "Cancel", edit_admin_model_path(model), class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
