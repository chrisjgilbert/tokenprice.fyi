<% content_for :title, "#{@provider.name} model pricing — tokenprice.fyi" %>
<% content_for :description, @provider.description.presence&.truncate(160) ||
     "#{@provider.name} API pricing across #{@models.size} models — per-token rates for language models, native rates for embeddings, rerank, speech, image, and video, with price history where tracked." %>
<% content_for :canonical, provider_url(@provider) %>
<% content_for :head do %>
  <%= json_ld({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Models", item: root_url },
          { "@type": "ListItem", position: 2, name: @provider.name, item: provider_url(@provider) }
        ]
      }) %>
<% end %>

<nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500">
  <%= link_to "← All models", root_path, class: "hover:text-indigo-600" %>
</nav>

<header class="mb-8 flex items-center gap-4">
  <%= provider_square(@provider, size: :lg) %>
  <div>
    <h1 class="text-3xl font-bold tracking-tight"><%= @provider.name %></h1>
    <% if @provider.website || @provider.flag_emoji %>
      <p class="mt-1 flex items-center gap-2 text-sm text-slate-500">
        <% if @provider.flag_emoji %><span aria-hidden="true"><%= @provider.flag_emoji %></span><% end %>
        <% if @provider.website %>
          <%= link_to @provider.website.sub(%r{\Ahttps?://}, ""), @provider.website, class: "hover:underline" %>
        <% end %>
      </p>
    <% end %>
  </div>
</header>

<% if @provider.description.present? %>
  <p class="mb-4 max-w-2xl text-base leading-relaxed text-slate-700"><%= @provider.description %></p>
<% end %>

<p class="mb-8 max-w-2xl text-sm leading-relaxed text-slate-600">
  <%= @provider.name %> API pricing for <%= @models.size %> models. Language models are updated
  daily with full price history; embeddings, rerank, speech, image, and video carry dated list prices. For the
  launches and price moves across the market, see the
  <%= link_to "market-events timeline", events_path, class: "text-indigo-600 hover:underline" %>.
</p>

<%# Grouped by pricing family (in the controller) so a provider's image/speech/
    embedding models get their own columns and native prices, never blank
    per-token cells. Each group uses the category's own column shape and shares
    the price cells with the main table (models/_data_cell). The category heading
    only earns its place when a provider spans more than one family — for the
    single-category provider (most of them) it would just label the only table. %>
<% grouped = @model_groups.size > 1 %>
<% @model_groups.each do |category, models| %>
  <%# The provider column is redundant here — every row is this provider. %>
  <% cols = category.columns - [ :provider ] %>
  <section class="mb-10">
    <% if grouped %>
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500"><%= category.label %></h2>
    <% end %>
    <div class="tp-cardify-wrap overflow-x-auto rounded-xl border border-slate-200 bg-white">
      <table class="tp-cardify min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <% cols.each do |key| %>
              <th scope="col" class="px-4 py-3 font-medium"><%= column_header(key) %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% models.each do |model| %>
            <tr class="hover:bg-slate-50 <%= 'opacity-60 grayscale hover:opacity-100 hover:grayscale-0' if model.suspended? %>">
              <% cols.each do |key| %>
                <% if key == :name %>
                  <td class="tp-card-title px-4 py-3">
                    <%= link_to model.name, model_path(model), class: "font-medium hover:text-indigo-600" %>
                    <%= status_badge(model.status) %>
                  </td>
                <% else %>
                  <%= render "models/data_cell", model: model, key: key %>
                <% end %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<div class="mt-10 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-5 text-sm text-slate-500">
  <%= data_updated_tag(@last_updated) %>
  <%= provider_report_link(@provider, css: "underline decoration-slate-300 underline-offset-2 hover:text-indigo-600") %>
</div>
