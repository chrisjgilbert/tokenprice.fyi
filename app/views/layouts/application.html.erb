<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "tokenprice.fyi — LLM API price tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || 'Token prices for Claude, GPT, Gemini, Grok, DeepSeek, and more LLM APIs. Updated daily, with full price history.' %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="tokenprice.fyi">
    <meta name="mobile-web-app-capable" content="yes">
    <meta property="og:site_name" content="tokenprice.fyi">
    <meta property="og:locale" content="en_US">
    <meta property="og:title" content="<%= content_for(:title) || 'tokenprice.fyi — LLM API price tracker' %>">
    <meta property="og:description" content="<%= content_for(:description) || 'LLM API token prices, tracked daily. Full history, every provider.' %>">
    <meta property="og:type" content="<%= content_for(:og_type).presence || 'website' %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= request.base_url %>/og.svg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || 'tokenprice.fyi — LLM API price tracker' %>">
    <meta name="twitter:description" content="<%= content_for(:description) || 'LLM API token prices, tracked daily. Full history, every provider.' %>">
    <meta name="twitter:image" content="<%= request.base_url %>/og.svg">
    <link rel="canonical" href="<%= content_for(:canonical).presence || request.original_url %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <%# Non-render-blocking webfonts: load as print media (off the critical path),
        then flip to all media on load. <noscript> covers JS-disabled clients.
        Weight list (400;500;600;700 per family) matches actual usage in
        app/assets/tailwind/application.css — every weight is in use, so none can
        be dropped without a visual regression. %>
    <% fonts_href = "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" %>
    <link href="<%= fonts_href %>" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="<%= fonts_href %>" rel="stylesheet"></noscript>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= json_ld({
          "@context": "https://schema.org",
          "@type": "Organization",
          name: "tokenprice.fyi",
          url: root_url,
          logo: "#{request.base_url}/icon.png",
          description: "Independent LLM API pricing tracker — input, output, and cached token prices for 40+ models, updated daily."
        }) %>
    <%= json_ld({
          "@context": "https://schema.org",
          "@type": "WebSite",
          name: "tokenprice.fyi",
          url: root_url
        }) %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900" data-controller="mobile-nav">
    <nav class="tp-nav">
      <div class="tp-nav-inner">
        <div class="tp-brand-group">
          <%= link_to root_path, class: "tp-brand" do %>
            <%= brand_mark(28) %>
            <span>tokenprice<span class="fyi">.fyi</span></span>
          <% end %>
        </div>
        <div class="tp-nav-links">
          <% primary_nav_items.each do |label, path| %>
            <%= nav_link label, path, active: current_page?(path) %>
          <% end %>
          <%# Learn dropdown groups the explainer pages. Stimulus toggles it open;
              on mobile it's replaced by the drawer's Learn section. %>
          <div class="tp-nav-group" data-controller="dropdown">
            <button type="button" class="tp-nav-link tp-nav-trigger<%= " active" if learn_active? %>"
                    data-dropdown-target="trigger" data-action="dropdown#toggle"
                    aria-expanded="false">
              Learn
              <svg class="tp-nav-chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="tp-nav-menu" data-dropdown-target="menu">
              <% learn_nav_items.each do |label, path| %>
                <%= link_to label, path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(path)) } %>
              <% end %>
            </div>
          </div>
        </div>
        <span class="tp-nav-spacer"></span>
        <%= render "shared/prices_synced", css: "tp-nav-sync" %>
        <button type="button" class="tp-nav-toggle" data-mobile-nav-target="toggle"
                data-action="mobile-nav#toggle" aria-expanded="false"
                aria-controls="tp-mobile-menu" aria-label="Menu">
          <span class="tp-nav-toggle-bars" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </nav>

    <%# Mobile drawer. Fixed to the viewport just under the bar; flattens the
        Learn dropdown into a labelled section. Hidden above 760px, where the
        inline nav and dropdown take over. Kept a sibling of <nav> (not a child)
        so it escapes the nav's backdrop-filter, which would otherwise become the
        containing block and anchor the drawer to the bar instead of the
        viewport. %>
    <div class="tp-m-scrim" data-action="click->mobile-nav#close" aria-hidden="true"></div>
    <div class="tp-m-panel" id="tp-mobile-menu" data-mobile-nav-target="panel">
      <nav class="tp-m-links" aria-label="Primary">
        <% primary_nav_items.each do |label, path| %>
          <%= mobile_nav_link label, path, active: current_page?(path) %>
        <% end %>
        <div class="tp-m-section">
          <span class="tp-m-eyebrow">Learn</span>
          <% learn_nav_items.each do |label, path| %>
            <%= mobile_nav_link label, path, active: current_page?(path), sub: true %>
          <% end %>
        </div>
      </nav>
      <div class="tp-m-foot">
        <%= render "shared/prices_synced", css: "tp-m-sync" %>
      </div>
    </div>

    <main class="shell">
      <%= yield %>
    </main>

    <footer class="tp-foot">
      <div class="tp-foot-inner">
        <%= link_to root_path, class: "tp-brand", style: "font-size:14px" do %>
          <%= brand_mark(22) %>
          <span>tokenprice<span class="fyi">.fyi</span></span>
        <% end %>
        <span style="margin-left:auto" class="num"><%= AiModel.listed.count %> models · <%= Provider.count %> providers</span>
        <span>List prices · USD per 1M tokens</span>
        <span>Independent price record, not affiliated with any provider</span>
        <span>sourced from provider price pages · costs are per-call estimates, never a monthly bill</span>
        <%= link_to "Data sources", sources_path, style: "color:var(--color-slate-500);text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--color-slate-300)" %>
        <%= link_to "Contact", "mailto:chris@chrisgilbert.dev", style: "color:var(--color-slate-500);text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--color-slate-300)" %>
      </div>
    </footer>
    <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "724cce37d91248feaa60a420e5cb2c37"}'></script><!-- End Cloudflare Web Analytics -->
  </body>
</html>
