<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "tokenprice.fyi — LLM API price tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || 'Compare the price of every frontier LLM — Claude, GPT, Gemini, Grok, DeepSeek — and track how API token prices change over time.' %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="tokenprice.fyi">
    <meta name="mobile-web-app-capable" content="yes">
    <meta property="og:title" content="<%= content_for(:title) || 'tokenprice.fyi' %>">
    <meta property="og:description" content="<%= content_for(:description) || 'Compare LLM API token prices and track how they change over time.' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= request.base_url %>/og.svg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="<%= request.base_url %>/og.svg">
    <link rel="canonical" href="<%= content_for(:canonical).presence || request.original_url %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900">
    <nav class="tp-nav">
      <div class="tp-nav-inner">
        <%= link_to root_path, class: "tp-brand" do %>
          <%= brand_mark(28) %>
          <span>tokenprice<span class="fyi">.fyi</span></span>
        <% end %>
        <div class="tp-nav-links">
          <%= nav_link "Models", root_path, active: current_page?(root_path) %>
          <%= nav_link "Trends", trends_path, active: current_page?(trends_path) %>
          <%= nav_link "Compare", compare_path, active: current_page?(compare_path) %>
          <%= nav_link "Which model?", which_model_path, active: current_page?(which_model_path) %>
          <%= nav_link "Why", why_path, active: current_page?(why_path) %>
        </div>
        <span class="tp-nav-spacer"></span>
        <span class="tp-nav-sync"><span class="tp-nav-dot"></span>prices synced <%= Date.current.iso8601 %></span>
      </div>
    </nav>

    <main class="shell">
      <%= yield %>
    </main>

    <footer class="tp-foot">
      <div class="tp-foot-inner">
        <%= link_to root_path, class: "tp-brand", style: "font-size:14px" do %>
          <%= brand_mark(22) %>
          <span>tokenprice<span class="fyi">.fyi</span></span>
        <% end %>
        <span style="margin-left:auto" class="num"><%= AiModel.listed.count %> models · <%= Provider.count %> providers</span>
        <span>Representative data · USD per 1M tokens</span>
      </div>
    </footer>
    <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "724cce37d91248feaa60a420e5cb2c37"}'></script><!-- End Cloudflare Web Analytics -->
  </body>
</html>
