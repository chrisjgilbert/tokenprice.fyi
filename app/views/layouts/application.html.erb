<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "tokenprice.fyi — LLM API price tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || 'Token prices for Claude, GPT, Gemini, Grok, DeepSeek, and 40+ others — updated daily with full history.' %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="tokenprice.fyi">
    <meta name="mobile-web-app-capable" content="yes">
    <meta property="og:title" content="<%= content_for(:title) || 'tokenprice.fyi' %>">
    <meta property="og:description" content="<%= content_for(:description) || 'LLM API token prices, tracked daily. Full history, every provider.' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= request.base_url %>/og.svg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="<%= request.base_url %>/og.svg">
    <link rel="canonical" href="<%= content_for(:canonical).presence || request.original_url %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900">
    <nav class="tp-nav" data-controller="mobile-nav">
      <div class="tp-nav-inner">
        <div class="tp-brand-group">
          <%= link_to root_path, class: "tp-brand" do %>
            <%= brand_mark(28) %>
            <span>tokenprice<span class="fyi">.fyi</span></span>
          <% end %>
          <span class="tp-beta" title="Beta — data is still being sense-checked and verified, so figures may change.">beta</span>
        </div>
        <div class="tp-nav-links">
          <%= nav_link "Models", root_path, active: current_page?(root_path) %>
          <%= nav_link "Trends", trends_path, active: current_page?(trends_path) %>
          <%= nav_link "Compare", compare_path, active: current_page?(compare_path) %>
          <%= nav_link "Estimate", cost_path, active: current_page?(cost_path) %>
          <%# Learn dropdown groups the explainer pages. Stimulus toggles it open;
              on the mobile scroll-nav it flattens to inline links via CSS. %>
          <% learn_active = current_page?(learn_path) || current_page?(learn_feature_costs_path) || current_page?(learn_cost_cutting_path) || current_page?(how_pricing_works_path) || current_page?(which_model_path) || current_page?(why_path) || current_page?(map_path) %>
          <div class="tp-nav-group" data-controller="dropdown">
            <button type="button" class="tp-nav-link tp-nav-trigger<%= " active" if learn_active %>"
                    data-dropdown-target="trigger" data-action="dropdown#toggle"
                    aria-expanded="false">
              Learn
              <svg class="tp-nav-chevron" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="tp-nav-menu" data-dropdown-target="menu">
              <%= link_to "All explainers", learn_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(learn_path)) } %>
              <%= link_to "How pricing works", how_pricing_works_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(how_pricing_works_path)) } %>
              <%= link_to "What drives feature cost", learn_feature_costs_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(learn_feature_costs_path)) } %>
              <%= link_to "Cost-cutting strategies", learn_cost_cutting_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(learn_cost_cutting_path)) } %>
              <%= link_to "Which model?", which_model_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(which_model_path)) } %>
              <%= link_to "Where do models come from?", map_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(map_path)) } %>
              <%= link_to "Why this exists", why_path, class: "tp-nav-menu-item", data: { action: "dropdown#hide" }, aria: { current: ("page" if current_page?(why_path)) } %>
            </div>
          </div>
        </div>
        <span class="tp-nav-spacer"></span>
        <%= render "shared/prices_synced", css: "tp-nav-sync" %>
        <button type="button" class="tp-nav-toggle" data-mobile-nav-target="toggle"
                data-action="mobile-nav#toggle" aria-expanded="false"
                aria-controls="tp-mobile-menu" aria-label="Menu">
          <span class="tp-nav-toggle-bars" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>

      <%# Mobile drawer. Slides down under the bar; flattens the Learn dropdown
          into a labelled section. Hidden above 760px, where the inline nav and
          dropdown take over. %>
      <div class="tp-m-scrim" data-action="click->mobile-nav#close" aria-hidden="true"></div>
      <div class="tp-m-panel" id="tp-mobile-menu" data-mobile-nav-target="panel">
        <nav class="tp-m-links" aria-label="Primary">
          <%= mobile_nav_link "Models", root_path, active: current_page?(root_path) %>
          <%= mobile_nav_link "Trends", trends_path, active: current_page?(trends_path) %>
          <%= mobile_nav_link "Compare", compare_path, active: current_page?(compare_path) %>
          <%= mobile_nav_link "Estimate", cost_path, active: current_page?(cost_path) %>
          <div class="tp-m-section">
            <span class="tp-m-eyebrow">Learn</span>
            <%= mobile_nav_link "All explainers", learn_path, active: current_page?(learn_path), sub: true %>
            <%= mobile_nav_link "How pricing works", how_pricing_works_path, active: current_page?(how_pricing_works_path), sub: true %>
            <%= mobile_nav_link "What drives feature cost", learn_feature_costs_path, active: current_page?(learn_feature_costs_path), sub: true %>
            <%= mobile_nav_link "Cost-cutting strategies", learn_cost_cutting_path, active: current_page?(learn_cost_cutting_path), sub: true %>
            <%= mobile_nav_link "Which model?", which_model_path, active: current_page?(which_model_path), sub: true %>
            <%= mobile_nav_link "Where do models come from?", map_path, active: current_page?(map_path), sub: true %>
            <%= mobile_nav_link "Why this exists", why_path, active: current_page?(why_path), sub: true %>
          </div>
        </nav>
        <div class="tp-m-foot">
          <%= render "shared/prices_synced", css: "tp-m-sync" %>
        </div>
      </div>
    </nav>

    <main class="shell">
      <%= yield %>
    </main>

    <footer class="tp-foot">
      <div class="tp-foot-inner">
        <%= link_to root_path, class: "tp-brand", style: "font-size:14px" do %>
          <%= brand_mark(22) %>
          <span>tokenprice<span class="fyi">.fyi</span></span>
        <% end %>
        <span style="margin-left:auto" class="num"><%= AiModel.listed.count %> models · <%= Provider.count %> providers</span>
        <span>List prices · USD per 1M tokens</span>
        <%= link_to "Data sources", sources_path, style: "color:var(--color-slate-500);text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--color-slate-300)" %>
        <%= link_to "Contact", "mailto:chris@chrisgilbert.dev", style: "color:var(--color-slate-500);text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--color-slate-300)" %>
        <span class="tp-foot-beta">Beta — data is still being sense-checked and verified, so figures may change.</span>
      </div>
    </footer>
    <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "724cce37d91248feaa60a420e5cb2c37"}'></script><!-- End Cloudflare Web Analytics -->
  </body>
</html>
