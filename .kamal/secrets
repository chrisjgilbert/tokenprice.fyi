# This file is committed to git and MUST NOT contain real credentials.
#
# Secret layout for this app:
#
#   * Runtime secrets — anything the running app reads (anthropic_api_key,
#     honeybadger_api_key, slack_webhook_url) — live in Rails encrypted
#     credentials (`bin/rails credentials:edit`). They are decrypted at runtime
#     via RAILS_MASTER_KEY and are NOT injected as env vars.
#
#   * Deploy-only secrets — only Kamal needs them, the app never reads them
#     (RAILS_MASTER_KEY, KAMAL_REGISTRY_PASSWORD) — live in the gitignored
#     `.kamal/secrets.local` (dotenv format, real values, unquoted), e.g.:
#
#       KAMAL_REGISTRY_PASSWORD=dckr_pat_xxxxx
#       RAILS_MASTER_KEY=xxxxxxxx        # optional; config/master.key wins if present
#
# Kamal only loads `.kamal/secrets-common` and `.kamal/secrets` (see
# Kamal::Secrets#secrets_filenames in the gem) — it does NOT read
# `.kamal/secrets.local`. So this committed file is what Kamal parses, and it
# resolves each value itself: prefer an already-exported environment variable
# (how CI injects them), otherwise fall back to a local source. Kamal's dotenv
# does NOT support ${VAR:-default}, so the fallback is written out explicitly.

# env var (CI) -> config/master.key (standard Rails local) -> .kamal/secrets.local
RAILS_MASTER_KEY=$(test -n "${RAILS_MASTER_KEY}" && printf %s "${RAILS_MASTER_KEY}" || { cat config/master.key 2>/dev/null || sed -n 's/^RAILS_MASTER_KEY=//p' .kamal/secrets.local 2>/dev/null; })

# env var (CI) -> .kamal/secrets.local (local)
KAMAL_REGISTRY_PASSWORD=$(test -n "${KAMAL_REGISTRY_PASSWORD}" && printf %s "${KAMAL_REGISTRY_PASSWORD}" || sed -n 's/^KAMAL_REGISTRY_PASSWORD=//p' .kamal/secrets.local 2>/dev/null)

# Litestream replication to Hetzner Object Storage — add real values to .kamal/secrets.local
LITESTREAM_ACCESS_KEY_ID=$(test -n "${LITESTREAM_ACCESS_KEY_ID}" && printf %s "${LITESTREAM_ACCESS_KEY_ID}" || sed -n 's/^LITESTREAM_ACCESS_KEY_ID=//p' .kamal/secrets.local 2>/dev/null)
LITESTREAM_SECRET_ACCESS_KEY=$(test -n "${LITESTREAM_SECRET_ACCESS_KEY}" && printf %s "${LITESTREAM_SECRET_ACCESS_KEY}" || sed -n 's/^LITESTREAM_SECRET_ACCESS_KEY=//p' .kamal/secrets.local 2>/dev/null)
